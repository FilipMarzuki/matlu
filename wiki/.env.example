NOTION_API_KEY=secret_...

# Supabase — used by the /playtest feedback form (client-side, baked in at build time)
# Get from: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Supabase service-role key — server-side ONLY, bypasses RLS for moderation API routes.
# Get from: Supabase dashboard → Settings → API → Service role key
# NEVER expose this to the client. Add to Vercel environment settings (not baked into the bundle).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Password gate for the /admin/creatures moderation page.
# Pick any strong password. Add to Vercel environment settings before deploy.
ADMIN_PASSWORD=change-me

# Cross-site link — Agentic Experiments dev log
PUBLIC_DEV_URL=https://agentic-experiments.vercel.app
# Core Warden game URL (used for World Forge link)
PUBLIC_GAME_URL=https://matlu.vercel.app
