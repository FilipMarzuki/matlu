NOTION_API_KEY=secret_...

# Supabase — used by the /playtest feedback form (client-side, baked in at build time)
# Get from: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Supabase service role — NEVER expose to the client; used by /api/creatures/* endpoints
# Get from: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GitHub token — Fine-grained PAT scoped to issues:write on FilipMarzuki/matlu only
# Create at: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
GH_TRACKER_TOKEN=github_pat_...

# Admin secret — shared with the admin UI to authenticate creature approval endpoints
# Generate any long random string; must match what the admin UI sends in Authorization: Bearer <secret>
ADMIN_SECRET=...

# Public URL of this wiki (no trailing slash)
WIKI_BASE_URL=https://wiki.matlu.app

# Cross-site link — Agentic Experiments dev log
PUBLIC_DEV_URL=https://agentic-experiments.vercel.app
# Core Warden game URL (used for World Forge link)
PUBLIC_GAME_URL=https://matlu.vercel.app
