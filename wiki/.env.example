NOTION_API_KEY=secret_...

# Supabase — used by the /playtest feedback form (client-side, baked in at build time)
# Get from: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Supabase service-role key — server-side only, NEVER expose to client
# Used by /api/creatures/approve and /api/creatures/reject (SSR admin routes).
# Get from: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin password gate for /admin/creatures moderation page (SSR).
# Set in Vercel project settings for production. Min 16 characters recommended.
ADMIN_PASSWORD=change-me-before-deploy

# GitHub tracker token — fine-grained PAT, issues:write on FilipMarzuki/matlu.
# Used by /api/creatures/approve (creates tracker issue) and
# /api/creatures/tracker-scrub (GDPR erasure). Set in Vercel project env vars.
# The creature-tracker-sync.yml workflow uses GH_TRACKER_TOKEN as a repo secret.
GH_TRACKER_TOKEN=github_pat_...

# Cross-site link — Agentic Experiments dev log
PUBLIC_DEV_URL=https://agentic-experiments.vercel.app
# Core Warden game URL (used for World Forge link)
PUBLIC_GAME_URL=https://corewarden.app
