NOTION_API_KEY=secret_...

# Supabase — used by /playtest, /creatures/submit, /admin/creatures (client-side, baked in at build time)
# Get from: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Supabase service-role key — used ONLY by /admin/creatures to approve/reject submissions.
# This key bypasses RLS. Keep it out of the repo. Add to Vercel env vars.
# Get from: Supabase dashboard → Settings → API → service_role key
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Admin password — gates /admin/creatures. Set a strong value in Vercel env vars.
VITE_ADMIN_PASSWORD=

# Cross-site link — Agentic Experiments dev log
PUBLIC_DEV_URL=https://agentic-experiments.vercel.app
# Core Warden game URL (used for World Forge link)
PUBLIC_GAME_URL=https://matlu.vercel.app
