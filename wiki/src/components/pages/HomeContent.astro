---
import Base from '../../layouts/Base.astro';
import CreatureParade from '../CreatureParade.astro';
import { fetchAllLore, TYPE_LABELS } from '../../lib/notion-lore';
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const gameUrl = import.meta.env.PUBLIC_GAME_URL ?? 'https://corewarden.app';

const allLore = await fetchAllLore();
const recentLore = allLore.slice(0, 3);

function jaggedPath(): string {
  const W = 1200, H = 32, sw = 16;
  const ys = [0, 8, 16, 24];
  const seq = [2, 0, 3, 1, 2, 3, 0, 1, 3, 2, 0, 3, 1, 0, 2, 3, 1, 0, 2, 1];
  let d = `M0,${H}`;
  let x = 0;
  let i = 0;
  while (x < W) {
    const y = H - ys[seq[i % seq.length]];
    d += ` L${x},${y} L${Math.min(x + sw, W)},${y}`;
    x += sw;
    i++;
  }
  d += ` L${W},${H} Z`;
  return d;
}
const dividerPath = jaggedPath();

const loreHref = lang === 'sv' ? '/sv/lore' : '/lore';
const creaturesSubmitHref = '/creatures/submit';
const playtestHref = lang === 'sv' ? '/sv/playtest' : '/playtest';
---

<Base
  title="Matlu Codex"
  description={t(lang, 'Matlu Codex — lore, biomes, and creatures for Core Warden.', 'Matlu Codex — lore, biomer och väsen för Core Warden.')}
  lang={lang}
>
  <Fragment slot="hero">
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <h1>{t(lang, 'The Matlu Multiworld', 'Matlu-multiversum')}</h1>
      <p class="lead">
        {lang === 'en'
          ? <>The world companion for <strong>Core Warden</strong> — lore, biomes, creatures, and more. Explore the world, meet its peoples, and help bring its creatures to life.</>
          : <>Världsguiden för <strong>Core Warden</strong> — lore, biomer, väsen och mer. Utforska världen, möt dess folk och hjälp till att skapa väsen.</>
        }
      </p>
      <a href={gameUrl} class="cta" target="_blank" rel="noopener">
        {t(lang, 'Play Core Warden →', 'Spela Core Warden →')}
      </a>
    </div>
    <div class="hero-divider" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 32"
        preserveAspectRatio="none"
        width="100%"
        height="32"
      >
        <path fill="#080d08" d={dividerPath} />
      </svg>
    </div>
  </section>
  <CreatureParade />
  </Fragment>

  <section class="section">
    <div class="section-head">
      <h2>📖 Lore</h2>
      <a href={loreHref} class="see-all">
        {t(lang, 'Browse all →', 'Visa alla →')}
      </a>
    </div>

    {recentLore.length > 0 ? (
      <div class="card-grid">
        {recentLore.map((entry) => (
          <a href={`${loreHref}/${entry.slug}`} class="card">
            <div class="card-top">
              <span class="badge">{TYPE_LABELS[entry.type]}</span>
              {entry.world && <span class="world-tag">{entry.world}</span>}
            </div>
            <h3>{entry.title}</h3>
            {entry.summary && <p class="card-p">{entry.summary}</p>}
          </a>
        ))}
      </div>
    ) : (
      <div class="coming-soon">
        {t(lang, 'Lore entries coming soon.', 'Lore-inlägg kommer snart.')}
        <a href={loreHref}>
          {t(lang, 'Visit the lore section →', 'Besök lore-sektionen →')}
        </a>
      </div>
    )}
  </section>

  <section class="section">
    <div class="section-head">
      <h2>{t(lang, '🌍 Biomes', '🌍 Biomer')}</h2>
    </div>
    <div class="coming-soon">
      {t(lang, 'Biome cards coming soon — from Meadow to Deep Sea.', 'Biomkort kommer snart — från äng till djuphav.')}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>{t(lang, '🦎 Creatures', '🦎 Väsen')}</h2>
    </div>
    <div class="coming-soon">
      {t(lang, 'Creature gallery coming soon.', 'Väsensgalleri kommer snart.')}
      <a href={creaturesSubmitHref}>
        {t(lang, 'Submit a creature →', 'Skicka in ett väsen →')}
      </a>
    </div>
  </section>

  <section class="contribute">
    <h2>{t(lang, 'Contribute to the World', 'Bidra till världen')}</h2>
    <p>
      {t(
        lang,
        'The Matlu multiworld grows with the community. Submit a creature you\'ve dreamed up, or play the game and share your feedback.',
        'Matlu-multiversum växer med gemenskapen. Skicka in ett väsen du drömt om, eller spela och dela din feedback.',
      )}
    </p>
    <div class="cta-row">
      <a href={creaturesSubmitHref} class="btn btn-primary">
        {t(lang, 'Submit a creature', 'Skicka in ett väsen')}
      </a>
      <a href={playtestHref} class="btn btn-secondary">
        {t(lang, 'Give feedback', 'Ge feedback')}
      </a>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 75vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/assets/hero-banner.png') center 35% / cover no-repeat;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8, 13, 8, 0.05) 0%,
      rgba(8, 13, 8, 0.35) 45%,
      rgba(8, 13, 8, 0.82) 78%,
      #080d08 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem 3.5rem;
  }

  .hero-content h1 {
    font-size: 2.6rem;
    color: var(--gold);
    text-shadow: 0 0 32px rgba(255, 224, 102, 0.35);
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.05rem;
    color: var(--text-dim);
    max-width: 500px;
    margin-bottom: 1.75rem;
    line-height: 1.7;
  }

  .lead strong { color: var(--text); }

  a.cta {
    display: inline-block;
    background: var(--gold);
    color: #1a1200;
    font-size: 0.9rem;
    font-family: 'Pixelify Sans', monospace;
    font-weight: 700;
    padding: 0.6rem 1.4rem;
    border-radius: 0;
    text-decoration: none;
    box-shadow: 3px 3px 0 var(--gold-dim);
    transition: box-shadow 0.08s, transform 0.08s;
  }

  a.cta:hover  { box-shadow: 4px 4px 0 var(--gold-dim); text-decoration: none; }
  a.cta:active { box-shadow: 1px 1px 0 var(--gold-dim); transform: translate(2px, 2px); }

  .hero-divider {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 3;
    line-height: 0;
  }

  .section { margin-bottom: 3rem; }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-head h2 { font-size: 1.25rem; color: var(--text); }

  .see-all { font-size: 0.85rem; color: var(--accent-hi); }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 12px rgba(95, 168, 95, 0.1);
    text-decoration: none;
  }

  .card-top { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }

  .badge {
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--badge-bg);
    color: var(--badge-text);
    border-radius: 4px;
    padding: 0.12rem 0.45rem;
  }

  .world-tag { font-size: 0.74rem; color: var(--text-dim); }

  .card h3 {
    font-size: 0.95rem;
    color: var(--gold);
    font-family: 'Pixelify Sans', monospace;
    font-weight: 700;
  }

  .card-p {
    font-size: 0.84rem;
    color: var(--text-dim);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .coming-soon {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
  }

  .coming-soon a { color: var(--accent-hi); font-size: 0.875rem; }

  .contribute {
    margin-top: 1rem;
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-align: center;
  }

  .contribute h2 { font-size: 1.3rem; margin-bottom: 0.75rem; }

  .contribute p {
    color: var(--text-dim);
    max-width: 480px;
    margin: 0 auto 1.5rem;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .cta-row {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.55rem 1.2rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
  }

  .btn-primary {
    background: var(--gold);
    color: #1a1200;
    border-radius: 0;
    box-shadow: 3px 3px 0 var(--gold-dim);
    transition: box-shadow 0.08s, transform 0.08s;
  }

  .btn-primary:hover  { text-decoration: none; box-shadow: 4px 4px 0 var(--gold-dim); }
  .btn-primary:active { box-shadow: 1px 1px 0 var(--gold-dim); transform: translate(2px, 2px); }

  .btn-secondary {
    background: var(--surface-hi);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent-hi);
    color: var(--accent-hi);
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .hero { min-height: 60vh; }
    .hero-content h1 { font-size: 1.9rem; }
    .hero-bg { background-position: 65% 35%; }
  }
</style>
