---
import type { Lang } from '../lib/i18n-codex';
import { t } from '../lib/i18n-codex';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const gameUrl = import.meta.env.PUBLIC_GAME_URL ?? 'https://corewarden.app';

const navItems = [
  { path: '/',               key: 'nav.home'        },
  { path: '/lore',           key: 'nav.lore'        },
  { path: '/biomes',         key: 'nav.biomes'      },
  { path: '/creatures',      key: 'nav.creatures'   },
  { path: '/backlog/board',  key: 'nav.backlog'     },
  { path: '/playtest',       key: 'nav.playtest'    },
  { path: '/screenshots',    key: 'nav.screenshots' },
  { path: '/credits',        key: 'nav.credits'     },
];

const pathname = Astro.url.pathname;
// Locale-neutral base path (strip /sv prefix for active link detection)
const basePath = lang === 'sv' ? (pathname.replace(/^\/sv/, '') || '/') : pathname;

// Build a locale-prefixed href
function localHref(path: string): string {
  if (lang === 'sv') return path === '/' ? '/sv' : `/sv${path}`;
  return path;
}

// Language switcher: link to the same page in the other locale
const switchHref = lang === 'en'
  ? (pathname === '/' ? '/sv' : `/sv${pathname}`)
  : basePath;
const switchLabel = lang === 'en' ? 'SV' : 'EN';
---

<nav>
  <a href={localHref('/')} class="site-title">Matlu Codex</a>
  <ul>
    {navItems.map(item => (
      <li>
        <a
          href={localHref(item.path)}
          class={basePath.startsWith(item.path) && item.path !== '/' ? 'active' : basePath === item.path ? 'active' : ''}
        >
          {t(item.key, lang)}
        </a>
      </li>
    ))}
  </ul>
  <div class="right-group">
    <!-- Language switcher: links to the equivalent page in the other locale -->
    <a href={switchHref} class="lang-link">{switchLabel}</a>
    <!-- Cross-links to other Matlu projects -->
    <a href={`${gameUrl}/biome`} class="dev-link" target="_blank" rel="noopener">
      {t('nav.world_forge', lang)}
    </a>
    <a href={`${gameUrl}/sf`} class="dev-link" target="_blank" rel="noopener">
      Settlement Forge →
    </a>
    <a href={`${gameUrl}/bf`} class="dev-link" target="_blank" rel="noopener">
      Building Forge →
    </a>
    <a href={import.meta.env.PUBLIC_DEV_URL ?? 'https://agentic-experiments.vercel.app'} class="dev-link" target="_blank" rel="noopener">
      {t('nav.dev_log', lang)}
    </a>
  </div>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    box-shadow: 0 1px 0 rgba(168, 85, 247, 0.12);
  }
  .site-title {
    color: var(--accent-hi);
    font-family: 'Syne', sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    white-space: nowrap;
    text-shadow: 0 0 16px rgba(192, 132, 252, 0.4);
    letter-spacing: 0.02em;
  }
  ul { display: flex; gap: 1.25rem; list-style: none; }
  a { color: var(--text-dim); font-size: 0.9rem; font-family: 'Outfit', sans-serif; }
  a:hover, a.active { color: var(--text); text-decoration: none; }
  a.active { color: var(--accent-hi); }

  .right-group {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lang-link {
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-dim);
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    transition: border-color 0.15s, color 0.15s;
  }
  .lang-link:hover { border-color: var(--accent); color: var(--accent-hi); text-decoration: none; }

  .dev-link {
    color: var(--text-dim);
    font-size: 0.82rem;
    white-space: nowrap;
    border: 1px solid var(--border);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }
  .dev-link:hover { color: var(--text); text-decoration: none; border-color: var(--accent); }
</style>
