---
const gameUrl = import.meta.env.PUBLIC_GAME_URL ?? 'https://corewarden.app';

const navItems = [
  { href: '/',            en: 'Home',         sv: 'Hem'          },
  { href: '/lore',        en: 'Lore',         sv: 'Lore'         },
  { href: '/biomes',      en: 'Biomes',       sv: 'Biomer'       },
  { href: '/creatures',   en: 'Creatures',    sv: 'Väsen'        },
  { href: '/backlog',     en: 'Backlog',      sv: 'Backlog'      },
  { href: '/playtest',    en: 'Playtest',     sv: 'Testa spelet' },
  { href: '/screenshots', en: 'Screenshots',  sv: 'Bilder'       },
  { href: '/credits',     en: 'Credits',      sv: 'Skapare'      },
];

const pathname = Astro.url.pathname;
---

<nav>
  <a href="/" class="site-title">Matlu Codex</a>
  <ul>
    {navItems.map(item => (
      <li>
        <a href={item.href} class={pathname.startsWith(item.href) && item.href !== '/' ? 'active' : pathname === item.href ? 'active' : ''}>
          <span lang="en">{item.en}</span>
          <span lang="sv">{item.sv}</span>
        </a>
      </li>
    ))}
  </ul>
  <div class="right-group">
    <!-- Language toggle: shows the OTHER language as the button label -->
    <button id="lang-toggle" class="lang-btn" title="Switch language / Byt språk">
      <span lang="en">SV</span>
      <span lang="sv">EN</span>
    </button>
    <!-- Cross-links to other Matlu projects -->
    <a href={`${gameUrl}/biome`} class="dev-link" target="_blank" rel="noopener">
      World Forge →
    </a>
    <a href={`${gameUrl}/sf`} class="dev-link" target="_blank" rel="noopener">
      Settlement Forge →
    </a>
    <a href={`${gameUrl}/bf`} class="dev-link" target="_blank" rel="noopener">
      Building Forge →
    </a>
    <a href={import.meta.env.PUBLIC_DEV_URL ?? 'https://agentic-experiments.vercel.app'} class="dev-link" target="_blank" rel="noopener">
      Dev Log →
    </a>
  </div>
</nav>

<script>
  document.getElementById('lang-toggle')!.addEventListener('click', () => {
    const html = document.documentElement;
    const next = html.lang === 'sv' ? 'en' : 'sv';
    html.lang = next;
    document.dispatchEvent(new CustomEvent('langchange', { detail: { lang: next } }));
  });
</script>

<style>
  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    box-shadow: 0 1px 0 rgba(168, 85, 247, 0.12);
  }
  .site-title {
    color: var(--accent-hi);
    font-family: 'Syne', sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    white-space: nowrap;
    text-shadow: 0 0 16px rgba(192, 132, 252, 0.4);
    letter-spacing: 0.02em;
  }
  ul { display: flex; gap: 1.25rem; list-style: none; }
  a { color: var(--text-dim); font-size: 0.9rem; font-family: 'Outfit', sans-serif; }
  a:hover, a.active { color: var(--text); text-decoration: none; }
  a.active { color: var(--accent-hi); }

  .right-group {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lang-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-dim);
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    transition: border-color 0.15s, color 0.15s;
  }
  .lang-btn:hover { border-color: var(--accent); color: var(--accent-hi); }

  .dev-link {
    color: var(--text-dim);
    font-size: 0.82rem;
    white-space: nowrap;
    border: 1px solid var(--border);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }
  .dev-link:hover { color: var(--text); text-decoration: none; border-color: var(--accent); }
</style>
