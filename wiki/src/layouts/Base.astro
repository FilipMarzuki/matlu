---
/**
 * Base layout — used by every wiki page.
 *
 * Props:
 *   title       — injected into <title> and og:title
 *   description — optional meta description
 */
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Matlu Codex — lore, biomes, and creatures for Core Warden.' } = Astro.props;
const siteTitle = 'Matlu Codex';
const pageTitle = title === siteTitle ? siteTitle : `${title} — ${siteTitle}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Must run before body renders to avoid flash of wrong language -->
    <script is:inline>
      (function(){
        var l = localStorage.getItem('matlu-lang') || 'en';
        document.documentElement.setAttribute('data-lang', l);
        document.documentElement.lang = l;
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <title>{pageTitle}</title>

    <!-- Google Fonts: Pixelify Sans (pixel headings) + Outfit (body text) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;500;700&family=Outfit:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Apply stored language before first paint to minimise text flash -->
    <script is:inline>
      (function () {
        const lang = localStorage.getItem('codex_lang');
        if (lang) document.documentElement.setAttribute('lang', lang);
      })();
    </script>

    <style is:global>
      /* ── Design tokens — Core Warden game palette ────────────────────────── */
      :root {
        /* Backgrounds — dark forest, matches game MainMenuScene panel */
        --bg:         #080d08;
        --surface:    #0e160e;
        --surface-hi: #162016;
        --border:     #2a3d2a;
        /* Text — matches game UI text exactly */
        --text:       #f0ead6;
        --text-dim:   #7a9a7a;
        /* Accent — muted forest green */
        --accent:     #3d7a3d;
        --accent-hi:  #5fa85f;
        /* Gold — matches game button text color; used for CTAs and highlights */
        --gold:       #ffe066;
        --gold-dim:   #b89e3a;
        /* Status */
        --green:      #4ade80;
        --red:        #f87171;
        --amber:      #fbbf24;
        /* Badge tint */
        --badge-bg:   rgba(95, 168, 95, 0.12);
        --badge-text: #88cc88;
      }

      /* ── Reset / base ────────────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        background-color: var(--bg);
        /* Subtle 8-pixel grid — evokes the pixel art tile grid */
        background-image:
          linear-gradient(rgba(95,168,95,0.022) 1px, transparent 1px),
          linear-gradient(90deg, rgba(95,168,95,0.022) 1px, transparent 1px);
        background-size: 8px 8px;
        color: var(--text);
        font-family: 'Outfit', sans-serif;
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      body { min-height: 100vh; position: relative; }

      /* Scanline overlay — CRT-lite texture, very faint */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 3px,
          rgba(0, 0, 0, 0.04) 3px,
          rgba(0, 0, 0, 0.04) 4px
        );
        pointer-events: none;
        z-index: 9998;
      }

      /* ── Typography ──────────────────────────────────────────────────────── */
      /* Pixelify Sans gives headings the pixel-art game feel */
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Pixelify Sans', monospace;
        line-height: 1.3;
        color: var(--text);
      }

      h1 { font-size: 1.9rem; font-weight: 700; letter-spacing: 0.01em; }
      h2 { font-size: 1.3rem; font-weight: 700; }
      h3 { font-size: 1.05rem; font-weight: 500; }

      p { margin-bottom: 1rem; }
      p:last-child { margin-bottom: 0; }

      a {
        color: var(--accent-hi);
        text-decoration: none;
      }
      a:hover { text-decoration: underline; }

      /* ── Language toggle ────────────────────────────────────────────────── */
      /* .t-en shown by default; .t-sv hidden. Flip when html[data-lang="sv"]. */
      .t-sv { display: none; }
      [data-lang="sv"] .t-en { display: none; }
      [data-lang="sv"] .t-sv { display: inline; }

      /* ── Main content wrapper ────────────────────────────────────────────── */
      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      /* ── Code ────────────────────────────────────────────────────────────── */
      /* ── Footer ──────────────────────────────────────────────────────────── */
      footer {
        border-top: 1px solid var(--border);
        padding: 1.25rem 1.5rem;
        font-size: 0.8rem;
        color: var(--text-dim);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      footer a { color: var(--text-dim); font-size: 0.8rem; }
      footer a:hover { color: var(--accent-hi); text-decoration: none; }
      footer .sep { opacity: 0.4; }

      /* ── Code ────────────────────────────────────────────────────────────── */
      code {
        font-family: 'Cascadia Code', 'Fira Code', monospace;
        font-size: 0.88em;
        background: var(--surface-hi);
        border: 1px solid var(--border);
        border-radius: 0;   /* square corners = pixel feel */
        padding: 0.15em 0.4em;
        color: var(--accent-hi);
      }
      pre {
        background: var(--surface);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        border-radius: 0;
        padding: 1.25rem;
        overflow-x: auto;
        margin-bottom: 1.5rem;
      }
      pre code {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.9em;
        color: var(--text);
      }

      /* ── Pixel-art card border utility ───────────────────────────────────── */
      /* Double-line border mimics pixel art UI frames */
      .pixel-card {
        border: 2px solid var(--border);
        box-shadow:
          inset 0 0 0 1px var(--bg),
          0 0 0 1px var(--border);
        border-radius: 0;
      }

      /* ── Global pixel button ─────────────────────────────────────────────── */
      /* Applied to primary CTA buttons across all pages */
      .btn-pixel-primary {
        background: var(--gold);
        color: #1a1200;
        font-family: 'Pixelify Sans', monospace;
        font-weight: 700;
        border: none;
        border-radius: 0;
        box-shadow: 3px 3px 0 var(--gold-dim);
        transition: box-shadow 0.08s, transform 0.08s;
      }
      .btn-pixel-primary:hover {
        box-shadow: 4px 4px 0 var(--gold-dim);
        text-decoration: none;
      }
      .btn-pixel-primary:active {
        box-shadow: 1px 1px 0 var(--gold-dim);
        transform: translate(2px, 2px);
      }
    </style>
  </head>

  <body>
    <Nav />
    <!-- Named slot for full-bleed sections (hero etc.) that must escape main's max-width -->
    <slot name="hero" />
    <main>
      <slot />
    </main>
    <footer>
      <span class="t-en">Matlu Codex &mdash; a Core Warden community hub.</span>
      <span class="t-sv">Matlu Codex &mdash; en Core Warden-gemenskap.</span>
      <span class="sep">&middot;</span>
      <a href="/privacy">
        <span class="t-en">Privacy Policy</span>
        <span class="t-sv">Integritetspolicy</span>
      </a>
      <span class="sep">&middot;</span>
      <a href="/creatures/license">
        <span class="t-en">Creature License</span>
        <span class="t-sv">Väsenslicens</span>
      </a>
      <span class="sep">&middot;</span>
      <a href="/account/signin">
        <span class="t-en">Creator Account</span>
        <span class="t-sv">Skaparkonto</span>
      </a>
    </footer>
  </body>
</html>

<script>
  // Re-apply translations every page load (handles SPA-style navigation and
  // direct URL visits after the user has already chosen a language).
  import { getLanguage, applyTranslations } from '../lib/i18n-codex';
  document.addEventListener('DOMContentLoaded', () => {
    const lang = getLanguage();
    if (lang !== 'en') applyTranslations(lang);
  });
</script>
