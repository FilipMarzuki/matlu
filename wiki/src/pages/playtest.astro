---
/**
 * Playtest page — lets visitors try the game and submit structured feedback
 * that lands in the same Supabase `matlu_feedback` table used by the in-game
 * widget. The `source` column distinguishes wiki submissions ("wiki_form")
 * from in-game ones. Requires FIL-200's migration (source + metadata columns).
 *
 * Session correlation: if the game links here with ?session=<id>, the row is
 * tagged with that session_id so both feedback rows can be joined in Supabase.
 */
import Base from '../layouts/Base.astro';

// These are baked in at Vercel build time — safe to expose (publishable key).
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY ?? '';
---

<Base title="Playtest" description="Play Matlu and share your feedback">
  <h1 data-i18n="playtest.title">Playtest Matlu</h1>
  <p class="lead" data-i18n="playtest.lead">
    Try the game in your browser, then share what worked and what didn't.
    Feedback goes directly to the development team.
  </p>

  <a
    href="https://corewarden.app"
    target="_blank"
    rel="noopener noreferrer"
    class="play-btn"
    data-i18n="playtest.play_btn"
  >
    Play Matlu &rarr;
  </a>

  <section class="feedback-section">
    <h2 data-i18n="playtest.feedback_heading">Share your feedback</h2>
    <p class="section-desc" data-i18n="playtest.feedback_desc">Takes about 60 seconds. No account needed.</p>

    <!--
      Hidden element to bridge server-side env vars into the client script.
      Astro processes <script> tags as ES modules via Vite, so VITE_* vars
      are available directly in <script> via import.meta.env — but to stay
      explicit and avoid any SSG edge cases, we also pass them via data attrs.
    -->
    <div id="supa-cfg" data-url={supabaseUrl} data-key={supabaseKey} hidden></div>

    <form id="feedback-form" novalidate>
      <div class="field">
        <label for="combat_feel_rating"><span data-i18n="playtest.combat_label">How did combat feel?</span> <span class="hint" data-i18n="playtest.combat_hint">(1 = terrible, 5 = great)</span></label>
        <div class="rating-row">
          {[1, 2, 3, 4, 5].map(n => (
            <label class="radio-label">
              <input type="radio" name="combat_feel_rating" value={String(n)} required />
              {n}
            </label>
          ))}
        </div>
      </div>

      <div class="field">
        <label for="frustration_text"><span data-i18n="playtest.frustration_label">What frustrated you most?</span> <span class="hint">(optional)</span></label>
        <textarea id="frustration_text" name="frustration_text" rows={3} placeholder="e.g. controls feel slippery, enemies too fast…"></textarea>
      </div>

      <div class="field">
        <label for="bug_text"><span data-i18n="playtest.bug_label">Any bugs?</span> <span class="hint">(optional)</span></label>
        <textarea id="bug_text" name="bug_text" rows={3} placeholder="e.g. crashed when pressing X, stuck on Y screen…"></textarea>
      </div>

      <div class="field">
        <label for="overall_text"><span data-i18n="playtest.overall_label">Overall thoughts</span> <span class="hint">(optional)</span></label>
        <textarea id="overall_text" name="overall_text" rows={3} placeholder="Anything else you'd like us to know…"></textarea>
      </div>

      <button type="submit" id="submit-btn" data-i18n="playtest.submit_btn">Submit feedback</button>
    </form>

    <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
  </section>
</Base>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { t } from '../lib/i18n-codex';

  const cfg = document.getElementById('supa-cfg') as HTMLElement;
  const url = cfg.dataset.url ?? '';
  const key = cfg.dataset.key ?? '';

  // Untyped client — wiki doesn't import the game's database.types.ts
  const supabase = createClient(url, key);

  const form = document.getElementById('feedback-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  // Read optional session_id from ?session= query param (set by the game's end screen)
  const sessionId = new URLSearchParams(window.location.search).get('session') ?? null;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const ratingRaw = data.get('combat_feel_rating');
    if (!ratingRaw) {
      statusEl.textContent = t('playtest.rating_required');
      statusEl.className = 'form-status error';
      return;
    }

    const combatFeelRating = parseInt(ratingRaw as string, 10);
    const frustrationText = (data.get('frustration_text') as string | null) ?? '';
    const bugText = (data.get('bug_text') as string | null) ?? '';
    const overallText = (data.get('overall_text') as string | null) ?? '';

    // Compact summary stored in feedback_text for quick scanning in the dashboard
    const feedbackText = [
      `Rating: ${combatFeelRating}/5`,
      frustrationText ? `Frustration: ${frustrationText}` : null,
      bugText ? `Bug: ${bugText}` : null,
      overallText ? `Overall: ${overallText}` : null,
    ].filter(Boolean).join(' | ');

    submitBtn.disabled = true;
    statusEl.textContent = t('playtest.submitting');
    statusEl.className = 'form-status';

    const { error } = await supabase.from('matlu_feedback').insert({
      feedback_text: feedbackText,
      // source and metadata require FIL-200's migration to be applied
      source: 'wiki_form',
      metadata: {
        combat_feel_rating: combatFeelRating,
        frustration_text: frustrationText,
        bug_text: bugText,
        overall_text: overallText,
      },
      user_agent: navigator.userAgent,
      session_id: sessionId,
      // game_version is NOT NULL in the current schema; use a sentinel value
      game_version: 'wiki',
    });

    if (error) {
      console.error('Feedback submit error:', error);
      statusEl.textContent = t('playtest.error');
      statusEl.className = 'form-status error';
      submitBtn.disabled = false;
    } else {
      statusEl.textContent = t('playtest.success');
      statusEl.className = 'form-status success';
      form.reset();
    }
  });
</script>

<style>
  h1 { font-size: 2rem; margin-top: 1.5rem; }
  .lead { color: var(--text-dim); max-width: 540px; margin-bottom: 2rem; }

  .play-btn {
    display: inline-block;
    background: var(--gold);
    color: #1a1200;
    font-family: 'Pixelify Sans', monospace;
    font-weight: 700;
    font-size: 1rem;
    padding: 0.75rem 2rem;
    border-radius: 0;
    text-decoration: none;
    box-shadow: 4px 4px 0 var(--gold-dim);
    transition: box-shadow 0.08s, transform 0.08s;
    margin-bottom: 3rem;
  }
  .play-btn:hover {
    text-decoration: none;
    box-shadow: 5px 5px 0 var(--gold-dim);
  }
  .play-btn:active {
    box-shadow: 1px 1px 0 var(--gold-dim);
    transform: translate(3px, 3px);
  }

  .feedback-section { margin-top: 1rem; }
  .section-desc { color: var(--text-dim); font-size: 0.9rem; margin-bottom: 1.5rem; }

  .field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.25rem; }

  label { font-size: 0.95rem; color: var(--text); }
  .hint { color: var(--text-dim); font-size: 0.85rem; font-weight: 400; }

  textarea, input[type="number"] {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    padding: 0.6rem 0.8rem;
    resize: vertical;
    transition: border-color 0.15s;
  }
  textarea:focus, input[type="number"]:focus {
    outline: none;
    border-color: var(--accent);
  }

  /* Star-style radio row */
  .rating-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    cursor: pointer;
    font-size: 1rem;
    color: var(--text-dim);
  }
  .radio-label:has(input:checked) { color: var(--accent-hi); }
  input[type="radio"] { accent-color: var(--accent-hi); width: 1rem; height: 1rem; cursor: pointer; }

  button[type="submit"] {
    background: var(--accent);
    border: none;
    border-radius: 6px;
    color: #fff;
    cursor: pointer;
    font-family: 'Pixelify Sans', monospace;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.65rem 1.75rem;
    transition: background 0.15s;
    margin-top: 0.5rem;
  }
  button[type="submit"]:hover { background: var(--accent-hi); }
  button[type="submit"]:disabled { opacity: 0.55; cursor: not-allowed; }

  .form-status { margin-top: 1rem; font-size: 0.9rem; min-height: 1.4em; }
  .form-status.success { color: var(--green); }
  .form-status.error { color: var(--red); }

  @media (max-width: 480px) {
    .play-btn { width: 100%; text-align: center; }
  }
</style>
