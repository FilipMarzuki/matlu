---
/**
 * Admin pipeline editor — issue #332.
 *
 * SSR-only (prerender = false). Password-gated.
 * Shows all creature submissions grouped into pipeline-stage tabs:
 *   Inbox → Approved → Balanced → Lore-ready → Queue → Spriting → Shipped
 *
 * Each tab renders appropriate edit controls for its stage.
 * API routes handle the data mutations; the DB trigger writes audit history.
 */
export const prerender = false;

import Base from '../../layouts/Base.astro';
import CreatureDetails from '../../components/CreatureDetails.astro';
import {
  validatePassword,
  sessionCookieValue,
  isAuthorized,
} from '../../lib/admin-session';
import { imageUrl } from '../../lib/supabase-creatures';

const supabaseUrl = import.meta.env.VITE_SUPABASE_URL ?? '';
const serviceKey  = import.meta.env.SUPABASE_SERVICE_ROLE_KEY ?? '';

// ── POST: login ───────────────────────────────────────────────────────────────
let loginError: string | null = null;
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const submitted = data.get('password')?.toString() ?? '';
  if (validatePassword(submitted)) {
    Astro.response.headers.set('Set-Cookie', sessionCookieValue(submitted));
    return Astro.redirect('/admin/creatures', 303);
  }
  loginError = 'Incorrect password.';
}

// ── Auth ──────────────────────────────────────────────────────────────────────
const authed = isAuthorized(Astro.request.headers.get('cookie'));

// ── Types ─────────────────────────────────────────────────────────────────────
type C = {
  id: string;
  creature_name: string;
  creator_name: string;
  maker_age: number | null;
  slug: string | null;
  status: string;
  world_name: string | null;
  kind_size: string | null;
  kind_diet: string | null;
  kind_movement: string[] | null;
  kind_solitary: boolean | null;
  habitat_biome: string[] | null;
  habitat_climate: string | null;
  habitat_notes: string | null;
  behaviour_threat: string | null;
  behaviour_notes: string | null;
  food_notes: string | null;
  special_ability: string | null;
  lore_description: string | null;
  lore_origin: string | null;
  art_path: string | null;
  credits_opt_in: boolean;
  license_accepted: boolean;
  parental_consent: boolean;
  completion_score: number | null;
  created_at: string;
  approved_at: string | null;
  contact_email: string | null;
  // pipeline fields
  balance_notes: string | null;
  balance_tier: string | null;
  biome_affinity: string[] | null;
  lore_entry_id: string | null;
  lore_entry_url: string | null;
  graphics_difficulty: number | null;
  graphics_notes: string | null;
  queue_priority: number | null;
  queued_at: string | null;
  entity_id: string | null;
  shipped_at: string | null;
};

// ── Fetch pipeline data ───────────────────────────────────────────────────────
type GroupKey = 'inbox' | 'approved' | 'balanced' | 'lore-ready' | 'queued' | 'spriting' | 'in-game';
type Groups = Record<GroupKey, C[]>;
const groups: Groups = {
  inbox:        [],
  approved:     [],
  balanced:     [],
  'lore-ready': [],
  queued:       [],
  spriting:     [],
  'in-game':    [],
};

if (authed && serviceKey) {
  try {
    // Inbox: unmoderated submissions
    const inboxRes = await fetch(
      `${supabaseUrl}/rest/v1/creature_submissions?approved=eq.false&moderation_note=is.null&order=created_at.asc`,
      { headers: { apikey: serviceKey, Authorization: `Bearer ${serviceKey}` } }
    );
    if (inboxRes.ok) groups.inbox = await inboxRes.json();

    // Pipeline: all other active statuses
    const pipelineRes = await fetch(
      `${supabaseUrl}/rest/v1/creature_submissions?status=in.(approved,balanced,lore-ready,queued,spriting,in-game)&order=queue_priority.asc.nullslast,created_at.asc`,
      { headers: { apikey: serviceKey, Authorization: `Bearer ${serviceKey}` } }
    );
    if (pipelineRes.ok) {
      const rows: C[] = await pipelineRes.json();
      for (const row of rows) {
        if (row.status in groups) {
          groups[row.status as GroupKey].push(row);
        }
      }
    }
  } catch { /* network error — show empty */ }
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function timeAgo(iso: string): string {
  const diff = Date.now() - new Date(iso).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 2)  return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}

const DIFF_LABELS = ['', 'Trivial', 'Easy', 'Standard', 'Complex', 'Hard'];
const TABS: Array<{ id: string; label: string; key: GroupKey }> = [
  { id: 'inbox',      label: 'Inbox',      key: 'inbox'      },
  { id: 'approved',   label: 'Approved',   key: 'approved'   },
  { id: 'balanced',   label: 'Balanced',   key: 'balanced'   },
  { id: 'lore-ready', label: 'Lore-ready', key: 'lore-ready' },
  { id: 'queued',     label: 'Queue',      key: 'queued'     },
  { id: 'spriting',   label: 'Spriting',   key: 'spriting'   },
  { id: 'in-game',    label: 'Shipped',    key: 'in-game'    },
];
---

<Base title="Admin — Creature Pipeline">
  <h1>Admin — Creature Pipeline</h1>

  {!authed ? (
    <div class="gate">
      <p class="gate-desc">Enter the admin password to access the pipeline.</p>
      <form method="POST" class="gate-form">
        <input type="password" name="password" placeholder="Password" autofocus
               autocomplete="current-password" required />
        {loginError && <p class="error">{loginError}</p>}
        <button type="submit">Unlock</button>
      </form>
    </div>
  ) : (
    <div>
      <!-- Tab navigation -->
      <nav class="tabs" role="tablist">
        {TABS.map((t, i) => {
          const count = groups[t.key].length;
          return (
            <button
              class={`tab${i === 0 ? ' active' : ''}`}
              data-tab={t.id}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              {t.label}
              {count > 0 && <span class="badge">{count}</span>}
            </button>
          );
        })}
      </nav>

      <!-- ── INBOX ─────────────────────────────────────────────────────────── -->
      <section id="tab-inbox" class="tab-section" role="tabpanel">
        {groups.inbox.length === 0
          ? <p class="empty">No pending submissions.</p>
          : groups.inbox.map(c => {
            const img = imageUrl(supabaseUrl, c.art_path);
            return (
              <article class="card" id={c.id}>
                {img && <img src={img} alt={c.creature_name} class="card-img" />}
                <div class="card-body">
                  <div class="card-hd">
                    <h2 class="card-name">{c.creature_name}</h2>
                    <span class="card-meta">{c.creator_name}{c.maker_age ? ` (age ${c.maker_age})` : ''} · {timeAgo(c.created_at)}</span>
                    {c.completion_score !== null && (
                      <span class={`score-pill ${c.completion_score >= 70 ? 'green' : c.completion_score >= 40 ? 'amber' : 'red'}`}>
                        {c.completion_score}%
                      </span>
                    )}
                  </div>
                  <CreatureDetails creature={c} />
                  <div class="card-actions">
                    <form class="approve-form" data-id={c.id}>
                      <button type="submit" class="btn-ok">Approve</button>
                    </form>
                    <form class="reject-form" data-id={c.id}>
                      <textarea name="note" placeholder="Rejection reason (internal)" rows={2}></textarea>
                      <button type="submit" class="btn-bad">Reject</button>
                    </form>
                  </div>
                  <div class="action-status" id={`s-${c.id}`}></div>
                </div>
              </article>
            );
          })
        }
      </section>

      <!-- ── APPROVED ──────────────────────────────────────────────────────── -->
      <section id="tab-approved" class="tab-section hidden" role="tabpanel">
        <p class="tab-desc">Set balance stats and biome affinity, then mark as Balanced.</p>
        {groups.approved.length === 0
          ? <p class="empty">No creatures awaiting balancing.</p>
          : groups.approved.map(c => (
            <article class="card" id={c.id}>
              {imageUrl(supabaseUrl, c.art_path) && <img src={imageUrl(supabaseUrl, c.art_path)!} alt={c.creature_name} class="card-img" />}
              <div class="card-body">
                <div class="card-hd">
                  <h2 class="card-name">{c.creature_name}</h2>
                  <span class="card-meta">{c.creator_name}{c.maker_age ? ` (age ${c.maker_age})` : ''}</span>
                </div>
                <CreatureDetails creature={c} />
                <form class="balance-form" data-id={c.id}>
                  <div class="form-row">
                    <label>Tier
                      <select name="balance_tier" required>
                        <option value="">— pick one —</option>
                        {['trivial','minor','standard','elite','boss'].map(t => (
                          <option value={t} selected={c.balance_tier === t}>{t}</option>
                        ))}
                      </select>
                    </label>
                    <label>Biome affinity (comma-separated)
                      <input type="text" name="biome_affinity" value={c.biome_affinity?.join(', ') ?? ''} placeholder="e.g. Forest, Swamp" />
                    </label>
                  </div>
                  <label>Balance notes
                    <textarea name="balance_notes" rows={3} placeholder="Stats, role, spawn rules…">{c.balance_notes ?? ''}</textarea>
                  </label>
                  <button type="submit" class="btn-ok">Mark as Balanced</button>
                </form>
                <div class="action-status" id={`s-${c.id}`}></div>
              </div>
            </article>
          ))
        }
      </section>

      <!-- ── BALANCED ───────────────────────────────────────────────────────── -->
      <section id="tab-balanced" class="tab-section hidden" role="tabpanel">
        <p class="tab-desc">Create a Notion lore page for each creature — auto-advances to Lore-ready.</p>
        {groups.balanced.length === 0
          ? <p class="empty">No creatures awaiting lore.</p>
          : groups.balanced.map(c => (
            <article class="card" id={c.id}>
              {imageUrl(supabaseUrl, c.art_path) && <img src={imageUrl(supabaseUrl, c.art_path)!} alt={c.creature_name} class="card-img" />}
              <div class="card-body">
                <div class="card-hd">
                  <h2 class="card-name">{c.creature_name}</h2>
                  <span class="card-meta">{c.balance_tier && <span class="tier-badge">{c.balance_tier}</span>} {c.biome_affinity?.join(', ')}</span>
                </div>
                <CreatureDetails creature={c} />
                {c.balance_notes && <p class="note-field"><strong>Balance notes:</strong> {c.balance_notes}</p>}
                <div class="card-actions">
                  <button class="lore-page-btn btn-ok" data-id={c.id}>
                    {c.lore_entry_url ? '✓ View Notion page' : 'Create Notion page'}
                  </button>
                  {c.lore_entry_url && (
                    <a href={c.lore_entry_url} target="_blank" rel="noopener" class="btn-dim">Open in Notion ↗</a>
                  )}
                </div>
                <div class="action-status" id={`s-${c.id}`}></div>
              </div>
            </article>
          ))
        }
      </section>

      <!-- ── LORE-READY ─────────────────────────────────────────────────────── -->
      <section id="tab-lore-ready" class="tab-section hidden" role="tabpanel">
        <p class="tab-desc">Rate sprite difficulty 1–5 — saves the score and auto-queues the creature.</p>
        {groups['lore-ready'].length === 0
          ? <p class="empty">No creatures awaiting graphics rating.</p>
          : groups['lore-ready'].map(c => (
            <article class="card" id={c.id}>
              {imageUrl(supabaseUrl, c.art_path) && <img src={imageUrl(supabaseUrl, c.art_path)!} alt={c.creature_name} class="card-img" />}
              <div class="card-body">
                <div class="card-hd">
                  <h2 class="card-name">{c.creature_name}</h2>
                  <span class="card-meta">{c.balance_tier && <span class="tier-badge">{c.balance_tier}</span>}</span>
                  {c.lore_entry_url && <a href={c.lore_entry_url} target="_blank" rel="noopener" class="lore-link">Lore page ↗</a>}
                </div>
                <form class="graphics-form" data-id={c.id}>
                  <fieldset class="diff-picker">
                    <legend>Sprite difficulty</legend>
                    <div class="diff-btns">
                      {[1,2,3,4,5].map(n => (
                        <label class="diff-lbl" title={DIFF_LABELS[n]}>
                          <input type="radio" name="graphics_difficulty" value={n}
                                 checked={c.graphics_difficulty === n} required />
                          <span class="diff-num">{n}</span>
                          <span class="diff-name">{DIFF_LABELS[n]}</span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                  <label>Graphics notes
                    <textarea name="graphics_notes" rows={2}
                              placeholder="Frame count, directions, palette size…">{c.graphics_notes ?? ''}</textarea>
                  </label>
                  <button type="submit" class="btn-ok">Save rating &amp; Queue</button>
                </form>
                <div class="action-status" id={`s-${c.id}`}></div>
              </div>
            </article>
          ))
        }
      </section>

      <!-- ── QUEUE ──────────────────────────────────────────────────────────── -->
      <section id="tab-queued" class="tab-section hidden" role="tabpanel">
        <p class="tab-desc">Ordered by <code>queue_priority</code> (lower = processed first by sprite-credit-burn). Override with the priority input.</p>
        {groups.queued.length === 0
          ? <p class="empty">Sprite queue is empty.</p>
          : groups.queued.map((c, i) => (
            <article class="card queue-card" id={c.id}>
              <div class="queue-pos">#{i + 1}</div>
              {imageUrl(supabaseUrl, c.art_path) && <img src={imageUrl(supabaseUrl, c.art_path)!} alt={c.creature_name} class="card-img-sm" />}
              <div class="card-body">
                <div class="card-hd">
                  <h2 class="card-name">{c.creature_name}</h2>
                  <span class="card-meta">
                    {c.balance_tier && <span class="tier-badge">{c.balance_tier}</span>}
                    {c.graphics_difficulty && <span class="diff-badge">diff {c.graphics_difficulty} — {DIFF_LABELS[c.graphics_difficulty]}</span>}
                  </span>
                </div>
                <div class="card-actions">
                  <form class="priority-form" data-id={c.id}>
                    <label>Priority override
                      <input type="number" name="queue_priority" value={c.queue_priority ?? ''} class="priority-input" />
                    </label>
                    <button type="submit" class="btn-dim">Set</button>
                  </form>
                  {c.lore_entry_url && <a href={c.lore_entry_url} target="_blank" rel="noopener" class="btn-dim">Lore ↗</a>}
                </div>
                <div class="action-status" id={`s-${c.id}`}></div>
              </div>
            </article>
          ))
        }
      </section>

      <!-- ── SPRITING ───────────────────────────────────────────────────────── -->
      <section id="tab-spriting" class="tab-section hidden" role="tabpanel">
        <p class="tab-desc">PixelLab is generating frames. Updated by <code>sprite-credit-burn</code>.</p>
        {groups.spriting.length === 0
          ? <p class="empty">No creatures currently spriting.</p>
          : groups.spriting.map(c => (
            <article class="card" id={c.id}>
              {imageUrl(supabaseUrl, c.art_path) && <img src={imageUrl(supabaseUrl, c.art_path)!} alt={c.creature_name} class="card-img" />}
              <div class="card-body">
                <div class="card-hd">
                  <h2 class="card-name">{c.creature_name}</h2>
                  <span class="status-badge badge-spriting">spriting</span>
                </div>
                {c.graphics_difficulty && <p class="note-field">Difficulty: {c.graphics_difficulty} — {DIFF_LABELS[c.graphics_difficulty]}</p>}
                {c.graphics_notes && <p class="note-field">{c.graphics_notes}</p>}
              </div>
            </article>
          ))
        }
      </section>

      <!-- ── SHIPPED ────────────────────────────────────────────────────────── -->
      <section id="tab-in-game" class="tab-section hidden" role="tabpanel">
        {groups['in-game'].length === 0
          ? <p class="empty">No community creatures shipped yet.</p>
          : groups['in-game'].map(c => (
            <article class="card" id={c.id}>
              {imageUrl(supabaseUrl, c.art_path) && <img src={imageUrl(supabaseUrl, c.art_path)!} alt={c.creature_name} class="card-img" />}
              <div class="card-body">
                <div class="card-hd">
                  <h2 class="card-name">{c.creature_name}</h2>
                  <span class="status-badge badge-shipped">in-game</span>
                  {c.shipped_at && <span class="card-meta">{timeAgo(c.shipped_at)}</span>}
                </div>
                {c.entity_id && <p class="note-field">Entity ID: <code>{c.entity_id}</code></p>}
              </div>
            </article>
          ))
        }
      </section>
    </div>
  )}
</Base>

<script>
// ── Tab switching ──────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('.tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });
    document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));

    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    const target = document.getElementById(`tab-${btn.dataset.tab}`);
    target?.classList.remove('hidden');
  });
});

// ── Helper ─────────────────────────────────────────────────────────────────────
async function apiPost(url: string, body: Record<string, unknown>) {
  return fetch(url, {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify(body),
  });
}

function setStatus(id: string, msg: string, ok: boolean) {
  const el = document.getElementById(`s-${id}`);
  if (!el) return;
  el.textContent = msg;
  el.className   = `action-status ${ok ? 'status-ok' : 'status-err'}`;
}

function removeCard(id: string) {
  document.getElementById(id)?.remove();
}

// ── Inbox: approve ────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLFormElement>('.approve-form').forEach(form => {
  form.addEventListener('submit', async e => {
    e.preventDefault();
    const id = form.dataset.id!;
    const btn = form.querySelector<HTMLButtonElement>('button')!;
    btn.disabled = true;
    setStatus(id, 'Approving…', true);

    const res = await apiPost('/api/creatures/approve', { id });
    if (res.ok) {
      setStatus(id, 'Approved — creature is now public.', true);
      setTimeout(() => removeCard(id), 1200);
    } else {
      const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
      setStatus(id, `Error: ${error}`, false);
      btn.disabled = false;
    }
  });
});

// ── Inbox: reject ─────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLFormElement>('.reject-form').forEach(form => {
  form.addEventListener('submit', async e => {
    e.preventDefault();
    const id   = form.dataset.id!;
    const note = form.querySelector<HTMLTextAreaElement>('[name=note]')?.value.trim() ?? '';
    const btn  = form.querySelector<HTMLButtonElement>('button')!;
    btn.disabled = true;
    setStatus(id, 'Rejecting…', true);

    const res = await apiPost('/api/creatures/reject', { id, note });
    if (res.ok) {
      setStatus(id, 'Rejected.', true);
      setTimeout(() => removeCard(id), 1200);
    } else {
      const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
      setStatus(id, `Error: ${error}`, false);
      btn.disabled = false;
    }
  });
});

// ── Approved: balance ─────────────────────────────────────────────────────────
document.querySelectorAll<HTMLFormElement>('.balance-form').forEach(form => {
  form.addEventListener('submit', async e => {
    e.preventDefault();
    const id             = form.dataset.id!;
    const balance_tier   = (form.querySelector<HTMLSelectElement>('[name=balance_tier]')?.value ?? '').trim();
    const balance_notes  = (form.querySelector<HTMLTextAreaElement>('[name=balance_notes]')?.value ?? '').trim();
    const biomeRaw       = (form.querySelector<HTMLInputElement>('[name=biome_affinity]')?.value ?? '').trim();
    const biome_affinity = biomeRaw ? biomeRaw.split(',').map(b => b.trim()).filter(Boolean) : [];

    const btn = form.querySelector<HTMLButtonElement>('button')!;
    btn.disabled = true;
    setStatus(id, 'Saving…', true);

    const res = await apiPost('/api/creatures/update-balance', { id, balance_tier, balance_notes, biome_affinity });
    if (res.ok) {
      setStatus(id, 'Balanced! Card will move to the Balanced tab on refresh.', true);
      setTimeout(() => removeCard(id), 1800);
    } else {
      const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
      setStatus(id, `Error: ${error}`, false);
      btn.disabled = false;
    }
  });
});

// ── Balanced: create Notion lore page ─────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('.lore-page-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id!;
    btn.disabled = true;
    setStatus(id, 'Creating Notion page…', true);

    const res = await apiPost('/api/creatures/create-lore-page', { id });
    if (res.ok) {
      const { url, existed } = await res.json();
      const msg = existed ? `Lore page already exists: ${url}` : `Created! ${url}`;
      setStatus(id, msg, true);
      if (!existed) setTimeout(() => removeCard(id), 2000);
      else btn.disabled = false;
    } else {
      const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
      setStatus(id, `Error: ${error}`, false);
      btn.disabled = false;
    }
  });
});

// ── Lore-ready: graphics rating ───────────────────────────────────────────────
document.querySelectorAll<HTMLFormElement>('.graphics-form').forEach(form => {
  form.addEventListener('submit', async e => {
    e.preventDefault();
    const id                  = form.dataset.id!;
    const graphics_difficulty = Number(
      form.querySelector<HTMLInputElement>('[name=graphics_difficulty]:checked')?.value
    );
    const graphics_notes = (form.querySelector<HTMLTextAreaElement>('[name=graphics_notes]')?.value ?? '').trim();

    const btn = form.querySelector<HTMLButtonElement>('button')!;
    btn.disabled = true;
    setStatus(id, 'Saving…', true);

    const res = await apiPost('/api/creatures/rate-graphics', { id, graphics_difficulty, graphics_notes });
    if (res.ok) {
      const { queued } = await res.json();
      setStatus(id, queued ? 'Added to queue! Card will move to Queue tab on refresh.' : 'Saved.', true);
      if (queued) setTimeout(() => removeCard(id), 1800);
      else btn.disabled = false;
    } else {
      const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
      setStatus(id, `Error: ${error}`, false);
      btn.disabled = false;
    }
  });
});

// ── Queue: priority override ──────────────────────────────────────────────────
document.querySelectorAll<HTMLFormElement>('.priority-form').forEach(form => {
  form.addEventListener('submit', async e => {
    e.preventDefault();
    const id             = form.dataset.id!;
    const queue_priority = Number(form.querySelector<HTMLInputElement>('[name=queue_priority]')?.value);
    const btn            = form.querySelector<HTMLButtonElement>('button')!;
    btn.disabled = true;
    setStatus(id, 'Updating…', true);

    const res = await apiPost('/api/creatures/update-queue-priority', { id, queue_priority });
    if (res.ok) {
      setStatus(id, `Priority set to ${queue_priority}.`, true);
    } else {
      const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
      setStatus(id, `Error: ${error}`, false);
    }
    btn.disabled = false;
  });
});
</script>

<style>
  h1 { font-size: 1.8rem; margin-bottom: 1.5rem; }

  /* ── Gate ─────────────────────────────────────────────────────────────── */
  .gate { max-width: 360px; margin: 4rem auto; text-align: center; }
