---
/**
 * Admin pipeline workspace — #340 (B2 pipeline redesign).
 *
 * Redesigns the original Inbox-only moderation page into a full tabbed
 * pipeline workspace with per-creature editor panels. Creatures move through:
 *
 *   submitted → approved → balanced → lore-ready → queued → spriting → in-game
 *
 * Each tab shows the creatures at that stage with count badges. Clicking a
 * creature row expands an inline editor with stage-appropriate forms and
 * status-transition buttons.
 *
 * SSR-only. Password-gated via admin_session cookie (see admin-session.ts).
 * All mutations go through /api/creatures/* fetch calls from the client.
 */
export const prerender = false;

import Base from '../../layouts/Base.astro';
import {
  validatePassword,
  sessionCookieValue,
  isAuthorized,
} from '../../lib/admin-session';
import { imageUrl } from '../../lib/supabase-creatures';

const supabaseUrl = import.meta.env.VITE_SUPABASE_URL ?? '';
const serviceKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY ?? '';

// ── POST: login form ─────────────────────────────────────────────────────────
let loginError: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const submitted = data.get('password')?.toString() ?? '';
  if (validatePassword(submitted)) {
    Astro.response.headers.set('Set-Cookie', sessionCookieValue(submitted));
    return Astro.redirect('/admin/creatures', 303);
  }
  loginError = 'Incorrect password.';
}

// ── Auth ─────────────────────────────────────────────────────────────────────
const cookieHeader = Astro.request.headers.get('cookie');
const authed = isAuthorized(cookieHeader);

// ── Types ────────────────────────────────────────────────────────────────────
type Creature = {
  id: string;
  creature_name: string;
  creator_name: string | null;
  maker_age: number | null;
  contact_email: string | null;
  world_name: string | null;
  kind_size: string | null;
  kind_diet: string | null;
  kind_movement: string[] | null;
  kind_solitary: boolean | null;
  habitat_biome: string[] | null;
  habitat_climate: string | null;
  habitat_notes: string | null;
  behaviour_threat: string | null;
  behaviour_notes: string | null;
  food_notes: string | null;
  special_ability: string | null;
  lore_description: string | null;
  lore_origin: string | null;
  art_path: string | null;
  art_credit: string | null;
  credits_opt_in: boolean;
  license_accepted: boolean;
  parental_consent: boolean;
  completion_score: number | null;
  created_at: string;
  slug: string | null;
  status: string;
  balance_tier: string | null;
  balance_notes: string | null;
  biome_affinity: string[] | null;
  lore_entry_id: string | null;
  lore_entry_url: string | null;
  graphics_difficulty: number | null;
  graphics_notes: string | null;
  queue_priority: number | null;
};

// ── Fetch all pipeline creatures (service-role, server-side) ─────────────────
let allCreatures: Creature[] = [];

if (authed && serviceKey) {
  try {
    // Fetch everything except rejected rows in one query
    const res = await fetch(
      `${supabaseUrl}/rest/v1/creature_submissions?status=neq.rejected&order=created_at.asc`,
      {
        headers: {
          apikey: serviceKey,
          Authorization: `Bearer ${serviceKey}`,
        },
      }
    );
    if (res.ok) allCreatures = await res.json();
  } catch { /* network error — show empty list */ }
}

// Group by status
const byStatus = (s: string) => allCreatures.filter(c => c.status === s);
const tabs = [
  { key: 'submitted',  label: 'Inbox',          creatures: byStatus('submitted') },
  { key: 'approved',   label: 'Needs dev work',  creatures: byStatus('approved') },
  { key: 'balanced',   label: 'Balancing',       creatures: byStatus('balanced') },
  { key: 'lore-ready', label: 'Lore-ready',      creatures: byStatus('lore-ready') },
  { key: 'queued',     label: 'Queue',           creatures: byStatus('queued').sort((a, b) => (a.queue_priority ?? 999) - (b.queue_priority ?? 999)) },
  { key: 'spriting',   label: 'Spriting',        creatures: byStatus('spriting') },
  { key: 'in-game',    label: 'Shipped',         creatures: byStatus('in-game') },
] as const;

// ── Helpers ──────────────────────────────────────────────────────────────────
function timeAgo(isoStr: string): string {
  const diff = Date.now() - new Date(isoStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 2) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  return `${Math.floor(hrs / 24)}d ago`;
}

const BIOMES = [
  'Sea','Rocky Shore','Beach','Grassland','Savanna','Desert',
  'Meadow','Woodland','Forest','Rainforest','Tundra','Glacier',
];

const BALANCE_TIERS = ['trivial','minor','standard','elite','boss'];

const GRAPHICS_TOOLTIPS = [
  '1 — Simple shape, solid fills, minimal shading',
  '2 — Some detail, basic shading or texture',
  '3 — Moderate complexity, multiple colours and features',
  '4 — High detail, complex shading, distinct silhouette',
  '5 — Very complex, animated elements or multi-frame sprite expected',
];
---

<Base title="Admin — Creatures Pipeline">
  <h1>Creature Pipeline</h1>

  {!authed ? (
    <!-- Password gate -->
    <div class="gate">
      <p class="gate-desc">Enter the admin password to access the pipeline.</p>
      <form method="POST" class="gate-form">
        <input type="password" name="password" placeholder="Password" autofocus
               autocomplete="current-password" required />
        {loginError && <p class="error">{loginError}</p>}
        <button type="submit">Unlock</button>
      </form>
    </div>
  ) : (
    <!-- Pipeline workspace -->
    <div id="pipeline">

      <!-- Tab nav -->
      <nav class="tab-nav" role="tablist">
        {tabs.map((tab, i) => (
          <button
            class={`tab-btn${i === 0 ? ' active' : ''}`}
            role="tab"
            data-tab={tab.key}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {tab.label}
            <span class={`badge${tab.creatures.length === 0 ? ' zero' : ''}`}>
              {tab.creatures.length}
            </span>
          </button>
        ))}
      </nav>

      <!-- Tab panels -->
      {tabs.map((tab, i) => (
        <div
          class="tab-panel"
          role="tabpanel"
          data-panel={tab.key}
          hidden={i !== 0}
        >
          {tab.creatures.length === 0 ? (
            <p class="empty">Nothing here yet.</p>
          ) : (
            <div class="creature-list">
              {tab.creatures.map(c => {
                const img = c.art_path ? imageUrl(supabaseUrl, c.art_path) : null;
                return (
                  <article class="creature-card" id={`card-${c.id}`} data-status={c.status}>
                    <!-- Clickable header row -->
                    <button class="card-toggle" data-id={c.id} aria-expanded="false">
                      <div class="card-toggle-left">
                        {img && <img src={img} alt={c.creature_name} class="thumb" />}
                        <div>
                          <span class="creature-name">{c.creature_name}</span>
                          {c.world_name && <span class="world-tag">{c.world_name}</span>}
                          <span class="time-tag">{timeAgo(c.created_at)}</span>
                        </div>
                      </div>
                      <div class="card-toggle-right">
                        <span class={`score-pill ${(c.completion_score ?? 0) >= 70 ? 'green' : (c.completion_score ?? 0) >= 40 ? 'amber' : 'red'}`}>
                          {c.completion_score ?? 0}%
                        </span>
                        {c.balance_tier && <span class="tier-pill">{c.balance_tier}</span>}
                        {c.graphics_difficulty && <span class="gfx-pill">gfx {c.graphics_difficulty}/5</span>}
                        <span class="chevron">▾</span>
                      </div>
                    </button>

                    <!-- Expandable editor panel -->
                    <div class="editor-panel" id={`editor-${c.id}`} hidden>

                      <!-- ── Summary (read-only) ──────────────────────────── -->
                      <section class="editor-section">
                        <h3>Submission summary</h3>
                        <div class="summary-body">
                          {img && <img src={img} alt={c.creature_name} class="summary-img" />}
                          <div>
                            <dl>
                              {c.creator_name && <><dt>Creator</dt><dd>{c.creator_name}{c.maker_age ? ` (age ${c.maker_age})` : ''}</dd></>}
                              {c.contact_email && <><dt>Email</dt><dd>{c.contact_email}</dd></>}
                              {c.kind_size && <><dt>Size</dt><dd>{c.kind_size}</dd></>}
                              {(c.kind_movement ?? []).length > 0 && <><dt>Movement</dt><dd>{(c.kind_movement ?? []).join(', ')}</dd></>}
                              {c.kind_diet && <><dt>Diet</dt><dd>{c.kind_diet}</dd></>}
                              {(c.habitat_biome ?? []).length > 0 && <><dt>Biome</dt><dd>{(c.habitat_biome ?? []).join(', ')}</dd></>}
                              {c.habitat_climate && <><dt>Climate</dt><dd>{c.habitat_climate}</dd></>}
                              {c.behaviour_threat && <><dt>Danger</dt><dd>{c.behaviour_threat}</dd></>}
                              {c.special_ability && <><dt>Special</dt><dd>{c.special_ability}</dd></>}
                            </dl>
                            {c.habitat_notes && <p class="note-field"><strong>Habitat:</strong> {c.habitat_notes}</p>}
                            {c.behaviour_notes && <p class="note-field"><strong>Behaviour:</strong> {c.behaviour_notes}</p>}
                            {c.food_notes && <p class="note-field"><strong>Food:</strong> {c.food_notes}</p>}
                            {c.lore_description && (
                              <div class="lore-block">
                                <strong>Story</strong>
                                <p>{c.lore_description}</p>
                              </div>
                            )}
                            {c.lore_origin && (
                              <div class="lore-block">
                                <strong>Origin</strong>
                                <p>{c.lore_origin}</p>
                              </div>
                            )}
                            <div class="consent-flags">
                              <span class={c.license_accepted ? 'flag-ok' : 'flag-bad'}>{c.license_accepted ? '✓' : '✗'} License</span>
                              <span class={c.parental_consent ? 'flag-ok' : 'flag-bad'}>{c.parental_consent ? '✓' : '✗'} Parental consent</span>
                              <span class={c.credits_opt_in ? 'flag-ok' : 'flag-dim'}>{c.credits_opt_in ? '✓' : '–'} Credits opt-in</span>
                            </div>
                          </div>
                        </div>
                      </section>

                      <!-- ── Balance form ────────────────────────────────── -->
                      <section class="editor-section">
                        <h3>Balancing</h3>
                        <form class="balance-form" data-id={c.id}>
                          <div class="field-row">
                            <label>
                              Balance tier
                              <select name="balance_tier">
                                <option value="">— pick one —</option>
                                {BALANCE_TIERS.map(t => (
                                  <option value={t} selected={c.balance_tier === t}>{t}</option>
                                ))}
                              </select>
                            </label>
                          </div>
                          <div class="field-row">
                            <label>
                              Balance notes
                              <textarea name="balance_notes" rows={3} placeholder="Spawn rate, health, damage notes…">{c.balance_notes ?? ''}</textarea>
                            </label>
                          </div>
                          <div class="field-row">
                            <label>Biome affinity</label>
                            <div class="checkbox-grid">
                              {BIOMES.map(b => (
                                <label class="check-label">
                                  <input type="checkbox" name="biome_affinity" value={b}
                                         checked={(c.biome_affinity ?? []).includes(b)} />
                                  {b}
                                </label>
                              ))}
                            </div>
                          </div>
                          <div class="form-actions">
                            <button type="submit" class="btn-secondary">Save balance data</button>
                            <button type="button" class="btn-transition btn-approve"
                                    data-id={c.id} data-to="balanced">
                              Mark balanced →
                            </button>
                          </div>
                          <p class="form-msg" id={`balance-msg-${c.id}`}></p>
                        </form>
                      </section>

                      <!-- ── Lore ────────────────────────────────────────── -->
                      <section class="editor-section">
                        <h3>Lore</h3>
                        {c.lore_entry_url ? (
                          <p class="lore-link">
                            Notion page: <a href={c.lore_entry_url} target="_blank" rel="noopener">{c.lore_entry_url}</a>
                          </p>
                        ) : (
                          <div>
                            <p class="dim-text">No Notion lore page yet. Creates a page in the Characters database and transitions to Lore-ready.</p>
                            <button class="btn-lore btn-secondary" data-id={c.id}>
                              Create Notion lore page
                            </button>
                            <p class="form-msg" id={`lore-msg-${c.id}`}></p>
                          </div>
                        )}
                      </section>

                      <!-- ── Graphics rating ─────────────────────────────── -->
                      <section class="editor-section">
                        <h3>Graphics rating</h3>
                        <form class="rating-form" data-id={c.id}>
                          <div class="gfx-rating-row">
                            {([1,2,3,4,5] as const).map(n => (
                              <button
                                type="button"
                                class={`gfx-btn${c.graphics_difficulty === n ? ' selected' : ''}`}
                                data-rating={n}
                                title={GRAPHICS_TOOLTIPS[n - 1]}
                              >{n}</button>
                            ))}
                            <input type="hidden" name="graphics_difficulty" value={c.graphics_difficulty?.toString() ?? ''} />
                          </div>
                          <div class="field-row">
                            <label>
                              Graphics notes
                              <textarea name="graphics_notes" rows={2} placeholder="Style, colour palette, reference links…">{c.graphics_notes ?? ''}</textarea>
                            </label>
                          </div>
                          <div class="form-actions">
                            <button type="submit" class="btn-secondary">Save rating &amp; move to Queue →</button>
                          </div>
                          <p class="form-msg" id={`rating-msg-${c.id}`}></p>
                        </form>
                      </section>

                      <!-- ── Status transitions ──────────────────────────── -->
                      <section class="editor-section editor-section--actions">
                        <h3>Status transitions</h3>
                        <div class="transition-row">
                          <!-- Inbox actions -->
                          {c.status === 'submitted' && (
                            <>
                              <button class="btn-transition btn-approve" data-id={c.id} data-to="approved">
                                Approve →
                              </button>
                              <form class="reject-inline" data-id={c.id}>
                                <textarea name="note" placeholder="Rejection reason (optional)" rows={2}></textarea>
                                <button type="submit" class="btn-reject">Reject</button>
                              </form>
                            </>
                          )}
                          {c.status === 'queued' && (
                            <button class="btn-transition btn-approve" data-id={c.id} data-to="spriting">
                              Start spriting →
                            </button>
                          )}
                          {c.status === 'spriting' && (
                            <button class="btn-transition btn-approve" data-id={c.id} data-to="in-game">
                              Mark shipped →
                            </button>
                          )}
                        </div>
                        <p class="form-msg" id={`trans-msg-${c.id}`}></p>
                      </section>

                    </div>
                  </article>
                );
              })}
            </div>
          )}
        </div>
      ))}
    </div>
  )}
</Base>

<script>
  // ── Tab switching ──────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll<HTMLElement>('.tab-panel').forEach(p => { p.hidden = true; });

      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      const panel = document.querySelector<HTMLElement>(`.tab-panel[data-panel="${btn.dataset.tab}"]`);
      if (panel) panel.hidden = false;
    });
  });

  // ── Expand / collapse editor panels ────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.card-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.id!;
      const panel = document.getElementById(`editor-${id}`);
      if (!panel) return;
      const open = !panel.hidden;
      panel.hidden = open;
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      btn.querySelector('.chevron')!.textContent = open ? '▾' : '▴';
    });
  });

  // ── Shared helpers ─────────────────────────────────────────────────────────
  function setMsg(el: HTMLElement | null, text: string, ok: boolean) {
    if (!el) return;
    el.textContent = text;
    el.className = `form-msg ${ok ? 'msg-ok' : 'msg-err'}`;
  }

  async function apiPost(path: string, body: Record<string, unknown>): Promise<{ ok: boolean; data: Record<string, unknown> }> {
    const res = await fetch(path, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json().catch(() => ({})) as Record<string, unknown>;
    return { ok: res.ok, data };
  }

  function removeCard(id: string) {
    const card = document.getElementById(`card-${id}`);
    card?.remove();
    // Update badge count on the now-current tab
    const activeTab = document.querySelector<HTMLButtonElement>('.tab-btn.active');
    if (!activeTab) return;
    const panelKey = activeTab.dataset.tab;
    const panel = document.querySelector<HTMLElement>(`.tab-panel[data-panel="${panelKey}"]`);
    const remaining = panel?.querySelectorAll('.creature-card').length ?? 0;
    const badge = activeTab.querySelector('.badge');
    if (badge) {
      badge.textContent = String(remaining);
      badge.classList.toggle('zero', remaining === 0);
    }
    if (remaining === 0 && panel) {
      panel.innerHTML = '<p class="empty">Nothing here yet.</p>';
    }
  }

  // ── Balance form ────────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLFormElement>('.balance-form').forEach(form => {
    form.addEventListener('submit', async e => {
      e.preventDefault();
      const id = form.dataset.id!;
      const msg = document.getElementById(`balance-msg-${id}`);
      const btn = form.querySelector<HTMLButtonElement>('button[type=submit]')!;
      btn.disabled = true;

      const fd = new FormData(form);
      const biome_affinity = fd.getAll('biome_affinity').map(String);
      const { ok, data } = await apiPost('/api/creatures/balance', {
        id,
        balance_tier: fd.get('balance_tier')?.toString() ?? '',
        balance_notes: fd.get('balance_notes')?.toString() ?? '',
        biome_affinity,
      });
      setMsg(msg, ok ? 'Saved.' : `Error: ${data.error ?? 'unknown'}`, ok);
      btn.disabled = false;
    });
  });

  // ── Status transition buttons (generic) ────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.btn-transition').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id!;
      const to = btn.dataset.to!;
      const msg = document.getElementById(`trans-msg-${id}`);
      btn.disabled = true;

      const { ok, data } = await apiPost('/api/creatures/status', { id, status: to });
      if (ok) {
        setMsg(msg, `Moved to ${to}.`, true);
        setTimeout(() => removeCard(id), 800);
      } else {
        setMsg(msg, `Error: ${data.error ?? 'unknown'}`, false);
        btn.disabled = false;
      }
    });
  });

  // ── Reject inline form ──────────────────────────────────────────────────────
  document.querySelectorAll<HTMLFormElement>('.reject-inline').forEach(form => {
    form.addEventListener('submit', async e => {
      e.preventDefault();
      const id = form.dataset.id!;
      const note = (form.querySelector<HTMLTextAreaElement>('[name=note]')?.value ?? '').trim();
      const msg = document.getElementById(`trans-msg-${id}`);
      const btn = form.querySelector<HTMLButtonElement>('button')!;
      btn.disabled = true;

      const { ok, data } = await apiPost('/api/creatures/reject', { id, note });
      if (ok) {
        setMsg(msg, 'Rejected.', true);
        setTimeout(() => removeCard(id), 800);
      } else {
        setMsg(msg, `Error: ${data.error ?? 'unknown'}`, false);
        btn.disabled = false;
      }
    });
  });

  // ── Lore entry creation ─────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.btn-lore').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id!;
      const msg = document.getElementById(`lore-msg-${id}`);
      btn.disabled = true;
      btn.textContent = 'Creating…';

      const { ok, data } = await apiPost('/api/creatures/create-lore-entry', { id });
      if (ok) {
        const url = data.lore_entry_url as string | undefined;
        if (url) {
          const section = btn.closest('section')!;
          section.innerHTML = `<h3>Lore</h3><p class="lore-link">Notion page: <a href="${url}" target="_blank" rel="noopener">${url}</a></p>`;
        } else {
          setMsg(msg, 'Notion page created! Refresh to see the link.', true);
        }
        // Move card to lore-ready tab after brief delay
        setTimeout(() => removeCard(id), 1200);
      } else {
        setMsg(msg, `Error: ${data.error ?? 'unknown'}`, false);
        btn.disabled = false;
        btn.textContent = 'Create Notion lore page';
      }
    });
  });

  // ── Graphics rating picker ──────────────────────────────────────────────────
  document.querySelectorAll<HTMLFormElement>('.rating-form').forEach(form => {
    const hidden = form.querySelector<HTMLInputElement>('[name=graphics_difficulty]')!;

    form.querySelectorAll<HTMLButtonElement>('.gfx-btn').forEach(gfxBtn => {
      gfxBtn.addEventListener('click', () => {
        form.querySelectorAll('.gfx-btn').forEach(b => b.classList.remove('selected'));
        gfxBtn.classList.add('selected');
        hidden.value = gfxBtn.dataset.rating!;
      });
    });

    form.addEventListener('submit', async e => {
      e.preventDefault();
      const id = form.dataset.id!;
      const msg = document.getElementById(`rating-msg-${id}`);
      const btn = form.querySelector<HTMLButtonElement>('button[type=submit]')!;
      const rating = hidden.value;

      if (!rating) {
        setMsg(msg, 'Pick a rating first.', false);
        return;
      }
      btn.disabled = true;

      const { ok, data } = await apiPost('/api/creatures/rating', {
        id,
        graphics_difficulty: Number(rating),
        graphics_notes: form.querySelector<HTMLTextAreaElement>('[name=graphics_notes]')?.value ?? '',
      });
      if (ok) {
        setMsg(msg, 'Rating saved — moved to Queue.', true);
        setTimeout(() => removeCard(id), 800);
      } else {
        setMsg(msg, `Error: ${data.error ?? 'unknown'}`, false);
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  h1 { font-size: 1.8rem; margin-bottom: 1.5rem; }

  /* ── Gate ─────────────────────────────────────────────────────────────────── */
  .gate { max-width: 360px; margin: 4rem auto; text-align: center; }
  .gate-desc { color: var(--text-dim); margin-bottom: 1.5rem; }
  .gate-form { display: flex; flex-direction: column; gap: 0.75rem; }
  .gate-form input[type="password"] {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-size: 1rem;
    padding: 0.6rem 0.85rem;
    text-align: center;
  }
  .gate-form input:focus { outline: none; border-color: var(--accent); }
  .gate-form button {
    background: var(--accent);
    border: none;
    border-radius: 6px;
    color: #fff;
    cursor: pointer;
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.6rem;
    transition: background 0.15s;
  }
  .gate-form button:hover { background: var(--accent-hi); }
  .error { color: var(--red, #f87171); font-size: 0.88rem; margin: 0; }

  /* ── Tab nav ──────────────────────────────────────────────────────────────── */
  .tab-nav {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
