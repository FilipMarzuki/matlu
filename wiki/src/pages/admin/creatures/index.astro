---
/**
 * /admin/creatures — Creature pipeline workspace
 *
 * Tabbed view of every pipeline stage. Clicking a creature opens an inline
 * editor panel on the right with:
 *   - Read-only submission summary + image
 *   - Balance form (tier, notes, biome affinity)
 *   - Lore section (create Notion page / view link)
 *   - Graphics rating (1–5) with tooltips
 *   - Status-transition buttons (context-aware for each stage)
 *
 * All mutations go to /api/creatures/* server routes which use the service-role
 * Supabase client and validate transitions via the creature_status_transition_allowed
 * DB function installed by #339.
 */
export const prerender = false;

import { isAdminAuthenticated } from '../../../lib/adminAuth';
import { getSupabaseAdmin } from '../../../lib/supabaseAdmin';
import type { CreatureSubmission } from '../../../../../src/types/database.types';

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin/login');
}

const supabase = getSupabaseAdmin();
const { data: rows } = await supabase
  .from('creature_submissions')
  .select('*')
  .order('created_at', { ascending: false });

const creatures: CreatureSubmission[] = rows ?? [];

const TABS = [
  { label: 'Inbox',          status: 'submitted'  },
  { label: 'Needs dev work', status: 'approved'   },
  { label: 'Balancing',      status: 'balanced'   },
  { label: 'Lore-ready',     status: 'lore-ready' },
  { label: 'Queue',          status: 'queued'     },
  { label: 'Spriting',       status: 'spriting'   },
  { label: 'Shipped',        status: 'in-game'    },
] as const;

const supabaseUrl = import.meta.env.VITE_SUPABASE_URL || import.meta.env.SUPABASE_URL || '';

type CreatureRow = CreatureSubmission & { artUrl: string | null };

const allRows: CreatureRow[] = creatures.map((c) => ({
  ...c,
  artUrl: c.art_path && supabaseUrl
    ? `${supabaseUrl}/storage/v1/object/public/creature-art/${c.art_path}`
    : null,
}));

function byStatus(status: string): CreatureRow[] {
  const list = allRows.filter((c) => c.status === status);
  // Queue tab: sort by priority ascending (lower number = higher priority)
  if (status === 'queued') {
    return list.sort((a, b) => (a.queue_priority ?? 9999) - (b.queue_priority ?? 9999));
  }
  return list;
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Creature Pipeline — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <style>
    /* ── Design tokens (same palette as Base.astro) ─────────────────────────── */
    :root {
      --bg:         #0d0d14;
      --surface:    #13131e;
      --surface-hi: #1c1c2e;
      --border:     #2a2a3e;
      --text:       #e8e8f0;
      --text-dim:   #9898b0;
      --accent:     #a855f7;
      --accent-hi:  #c084fc;
      --green:      #4ade80;
      --red:        #f87171;
      --amber:      #fbbf24;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { background: var(--bg); color: var(--text); font-family: 'Outfit', sans-serif; font-size: 15px; line-height: 1.55; -webkit-font-smoothing: antialiased; }
    body { display: flex; flex-direction: column; min-height: 100vh; }

    /* ── Admin header ────────────────────────────────────────────────────────── */
    .admin-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1.25rem;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .admin-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.05rem;
      color: var(--accent-hi);
    }
    .admin-header a {
      font-size: 0.82rem;
      color: var(--text-dim);
      text-decoration: none;
      border: 1px solid var(--border);
      padding: 0.25rem 0.6rem;
      border-radius: 4px;
    }
    .admin-header a:hover { color: var(--text); border-color: var(--accent); }

    /* ── Two-column layout ───────────────────────────────────────────────────── */
    .pipeline-layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      flex: 1;
      overflow: hidden;
      height: calc(100vh - 49px); /* subtract header height */
    }

    /* ── Left pane: tab nav + creature list ──────────────────────────────────── */
    .list-pane {
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--border);
      overflow: hidden;
    }

    .tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 2px;
      padding: 0.5rem;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .tab-btn {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.65rem;
      background: none;
      border: 1px solid transparent;
      border-radius: 5px;
      color: var(--text-dim);
      cursor: pointer;
      font-family: 'Outfit', sans-serif;
      font-size: 0.8rem;
      transition: color 0.12s, border-color 0.12s, background 0.12s;
    }
    .tab-btn:hover { color: var(--text); border-color: var(--border); }
    .tab-btn[aria-selected="true"] {
      color: var(--accent-hi);
      background: rgba(168, 85, 247, 0.12);
      border-color: var(--accent);
    }
    .count {
      background: var(--surface-hi);
      border-radius: 999px;
      font-size: 0.7rem;
      padding: 0.05rem 0.4rem;
      color: var(--text-dim);
    }
    .tab-btn[aria-selected="true"] .count { background: rgba(168, 85, 247, 0.25); color: var(--accent-hi); }

    .tab-panel {
      flex: 1;
      overflow-y: auto;
      padding: 0.5rem;
    }
    .tab-panel[hidden] { display: none; }

    .empty-state { color: var(--text-dim); font-size: 0.875rem; padding: 1rem 0.5rem; }

    .creature-row {
      display: flex;
      flex-direction: column;
      width: 100%;
      padding: 0.65rem 0.75rem;
      margin-bottom: 2px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: pointer;
      text-align: left;
      color: var(--text);
      font-family: 'Outfit', sans-serif;
      transition: border-color 0.12s, background 0.12s;
    }
    .creature-row:hover { border-color: var(--accent); background: var(--surface-hi); }
    .creature-row.active { border-color: var(--accent); background: rgba(168, 85, 247, 0.1); }
    .cname { font-size: 0.9rem; font-weight: 600; color: var(--text); }
    .cmeta { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.1rem; }
    .cpri { font-size: 0.72rem; color: var(--amber); margin-top: 0.1rem; }

    /* ── Right pane: editor ──────────────────────────────────────────────────── */
    .editor-pane {
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      padding: 0;
    }
    .editor-pane[hidden] { display: none; }

    .no-selection {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: var(--text-dim);
      font-size: 0.9rem;
    }

    .editor-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem 0.75rem;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 10;
    }
    .editor-header h2 {
      font-family: 'Syne', sans-serif;
      font-size: 1.15rem;
      font-weight: 800;
    }
    .ed-close {
      background: none;
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text-dim);
      cursor: pointer;
      font-size: 0.9rem;
      padding: 0.2rem 0.5rem;
    }
    .ed-close:hover { color: var(--text); border-color: var(--accent); }

    /* ── Editor sections ─────────────────────────────────────────────────────── */
    .ed-section {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--border);
    }
    .ed-section h3 {
      font-family: 'Syne', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--text-dim);
      margin-bottom: 0.75rem;
    }

    /* ── Summary grid ────────────────────────────────────────────────────────── */
    .summary-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.4rem 1rem;
      font-size: 0.85rem;
    }
    .summary-grid dt { color: var(--text-dim); }
    .summary-grid dd { color: var(--text); }
    .art-img {
      max-width: 180px;
      max-height: 180px;
      border-radius: 6px;
      border: 1px solid var(--border);
      margin-top: 0.75rem;
      object-fit: contain;
    }

    /* ── Forms ───────────────────────────────────────────────────────────────── */
    .form-grid {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .form-grid label {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      font-size: 0.85rem;
      color: var(--text-dim);
    }
    .hint { font-size: 0.75rem; }

    select, textarea, input[type="text"] {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 5px;
      color: var(--text);
      font-family: 'Outfit', sans-serif;
      font-size: 0.875rem;
      padding: 0.5rem 0.65rem;
      transition: border-color 0.12s;
    }
    select:focus, textarea:focus, input:focus { outline: none; border-color: var(--accent); }
    textarea { resize: vertical; }

    .form-actions { margin-top: 0.25rem; }

    /* ── Buttons ─────────────────────────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.5rem 1rem;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-family: 'Syne', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      transition: background 0.12s, opacity 0.12s;
    }
    .btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:not(:disabled):hover { background: var(--accent-hi); }
    .btn-success { background: #166534; color: var(--green); border: 1px solid #15803d; }
    .btn-success:not(:disabled):hover { background: #14532d; }
    .btn-danger  { background: #7f1d1d; color: var(--red); border: 1px solid #991b1b; }
    .btn-danger:not(:disabled):hover  { background: #6b1717; }
    .btn-outline { background: none; color: var(--text); border: 1px solid var(--border); }
    .btn-outline:not(:disabled):hover { border-color: var(--accent); color: var(--accent-hi); }

    /* ── Rating buttons ──────────────────────────────────────────────────────── */
    .rating-row { display: flex; gap: 0.4rem; margin-bottom: 0.75rem; }
    .rbt {
      width: 2.4rem;
      height: 2.4rem;
      border-radius: 50%;
      border: 2px solid var(--border);
      background: var(--surface);
      color: var(--text-dim);
      cursor: pointer;
      font-family: 'Syne', sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      transition: background 0.12s, border-color 0.12s, color 0.12s;
    }
    .rbt:hover { border-color: var(--accent); color: var(--accent-hi); }
    .rbt.selected { border-color: var(--accent-hi); background: rgba(168,85,247,0.2); color: var(--accent-hi); }

    /* ── Transitions row ─────────────────────────────────────────────────────── */
    .transition-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }

    /* ── Status feedback ─────────────────────────────────────────────────────── */
    .form-status { font-size: 0.82rem; margin-top: 0.6rem; min-height: 1.2em; }
    .form-status.ok  { color: var(--green); }
    .form-status.err { color: var(--red); }
  </style>
</head>
<body>
  <header class="admin-header">
    <span class="admin-title">Creature Pipeline</span>
    <a href="/">← Matlu Codex</a>
  </header>

  <div class="pipeline-layout">
    <!-- ── Left pane: tabs + creature rows ──────────────────────────────────── -->
    <aside class="list-pane">
      <nav class="tabs" role="tablist" aria-label="Pipeline stages">
        {TABS.map((tab, i) => (
          <button
            role="tab"
            class="tab-btn"
            data-status={tab.status}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${tab.status}`}
          >
            {tab.label}
            <span class="count">{byStatus(tab.status).length}</span>
          </button>
        ))}
      </nav>

      {TABS.map((tab, i) => (
        <div
          id={`panel-${tab.status}`}
          role="tabpanel"
          class="tab-panel"
          hidden={i !== 0}
        >
          {byStatus(tab.status).length === 0 ? (
            <p class="empty-state">No creatures in this stage.</p>
          ) : (
            byStatus(tab.status).map((c) => (
              <button
                class="creature-row"
                data-creature-id={c.id}
              >
                <span class="cname">{c.creature_name}</span>
                <span class="cmeta">
                  {c.creator_name} · {new Date(c.created_at).toLocaleDateString()}
                </span>
                {tab.status === 'queued' && c.queue_priority != null && (
                  <span class="cpri">Priority: {c.queue_priority}</span>
                )}
              </button>
            ))
          )}
        </div>
      ))}
    </aside>

    <!-- ── Right pane: editor ────────────────────────────────────────────────── -->
    <main class="editor-pane" id="editor-pane">
      <div class="no-selection" id="no-selection">
        ← Select a creature to edit
      </div>

      <!-- Editor content (hidden until a creature is selected) -->
      <div id="editor-content" hidden>
        <div class="editor-header">
          <h2 id="ed-title">—</h2>
          <button class="ed-close" id="ed-close" aria-label="Close editor">✕</button>
        </div>

        <!-- Summary -->
        <section class="ed-section">
          <h3>Submission</h3>
          <dl class="summary-grid" id="ed-summary"></dl>
          <div id="ed-art"></div>
        </section>

        <!-- Balance -->
        <section class="ed-section" id="ed-balance-section">
          <h3>Balance</h3>
          <form class="form-grid" id="balance-form">
            <label>
              Tier
              <select id="bal-tier" name="balance_tier">
                <option value="">— select —</option>
                <option value="trivial">Trivial</option>
                <option value="minor">Minor</option>
                <option value="standard">Standard</option>
                <option value="elite">Elite</option>
                <option value="boss">Boss</option>
              </select>
            </label>
            <label>
              Balance notes
              <textarea id="bal-notes" name="balance_notes" rows="3"></textarea>
            </label>
            <label>
              Biome affinity <span class="hint">(comma-separated)</span>
              <input id="biome-aff" name="biome_affinity" type="text" />
            </label>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary" id="save-balance-btn">Save balance</button>
            </div>
            <p class="form-status" id="balance-status"></p>
          </form>
        </section>

        <!-- Lore -->
        <section class="ed-section" id="ed-lore-section">
          <h3>Lore</h3>
          <div id="lore-content">
            <button type="button" class="btn btn-outline" id="create-lore-btn">
              Create Notion lore page
            </button>
            <a id="lore-link" href="#" target="_blank" rel="noopener" hidden
               style="margin-left:0.75rem;color:var(--accent-hi);font-size:0.875rem;">
              View in Notion →
            </a>
            <p class="form-status" id="lore-status"></p>
          </div>
        </section>

        <!-- Graphics rating -->
        <section class="ed-section" id="ed-rating-section">
          <h3>Graphics Rating</h3>
          <div class="rating-row" role="group" aria-label="Graphics difficulty rating">
            <button class="rbt" data-r="1" type="button" title="1 — Simple shape, flat colour">1</button>
            <button class="rbt" data-r="2" type="button" title="2 — Simple with shading or outlines">2</button>
            <button class="rbt" data-r="3" type="button" title="3 — Medium: defined form, some detail">3</button>
            <button class="rbt" data-r="4" type="button" title="4 — Detailed with many colours or features">4</button>
            <button class="rbt" data-r="5" type="button" title="5 — Complex: many parts, intricate detail">5</button>
          </div>
          <div class="form-grid">
            <label>
              Graphics notes
              <textarea id="gfx-notes" rows="2"></textarea>
            </label>
            <div class="form-actions">
              <button type="button" class="btn btn-success" id="save-rating-btn">
                Save rating &amp; move to queue
              </button>
            </div>
            <p class="form-status" id="rating-status"></p>
          </div>
        </section>

        <!-- Pipeline transitions -->
        <section class="ed-section" id="ed-transitions-section">
          <h3>Pipeline actions</h3>
          <div class="transition-row" id="transition-buttons"></div>
          <p class="form-status" id="transition-status"></p>
        </section>
      </div>
    </main>
  </div>

  <!-- ── Embedded creature data for client JS ────────────────────────────────── -->
  <!-- define:vars serialises allRows as a JS literal, making it available below -->
  <script is:inline define:vars={{ allRows }}>
    window.__creatures = allRows;
  </script>

  <script>
    // All creature data fetched server-side; no further network calls needed for reads
    interface CreatureRow {
      id: string;
      creature_name: string;
      creator_name: string;
      created_at: string;
      status: string;
      world_name: string | null;
      kind_size: string | null;
      kind_diet: string | null;
      kind_movement: string[] | null;
      kind_solitary: boolean | null;
      habitat_biome: string[] | null;
      habitat_climate: string | null;
      habitat_notes: string | null;
      behaviour_threat: string | null;
      behaviour_notes: string | null;
      food_notes: string | null;
      special_ability: string | null;
      lore_description: string | null;
      lore_origin: string | null;
      lore_entry_id: string | null;
      lore_entry_url: string | null;
      balance_tier: string | null;
      balance_notes: string | null;
      biome_affinity: string[] | null;
      graphics_difficulty: number | null;
      graphics_notes: string | null;
      queue_priority: number | null;
      moderation_note: string | null;
      artUrl: string | null;
    }

    declare global {
      interface Window { __creatures: CreatureRow[] }
    }

    const creatures = window.__creatures;
    let activeId: string | null = null;
    let selectedRating: number | null = null;

    // ── Tab switching ──────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach((b) => {
          b.setAttribute('aria-selected', 'false');
        });
        document.querySelectorAll<HTMLDivElement>('.tab-panel').forEach((p) => {
          p.hidden = true;
        });
        btn.setAttribute('aria-selected', 'true');
        const panelId = `panel-${btn.dataset.status}`;
        const panel = document.getElementById(panelId);
        if (panel) panel.hidden = false;
        closeEditor();
      });
    });

    // ── Creature row clicks ────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.creature-row').forEach((row) => {
      row.addEventListener('click', () => {
        const id = row.dataset.creatureId;
        if (!id) return;
        openEditor(id);
        document.querySelectorAll('.creature-row').forEach((r) => r.classList.remove('active'));
        row.classList.add('active');
      });
    });

    // ── Editor open / close ────────────────────────────────────────────────────
    function openEditor(id: string) {
      activeId = id;
      selectedRating = null;

      const c = creatures.find((x) => x.id === id);
      if (!c) return;

      document.getElementById('no-selection')!.hidden = true;
      const content = document.getElementById('editor-content')!;
      content.hidden = false;

      (document.getElementById('ed-title') as HTMLElement).textContent = c.creature_name;

      populateSummary(c);
      populateBalance(c);
      populateLore(c);
      populateRating(c);
      populateTransitions(c);
    }

    function closeEditor() {
      activeId = null;
      selectedRating = null;
      document.getElementById('no-selection')!.hidden = false;
      document.getElementById('editor-content')!.hidden = true;
      document.querySelectorAll('.creature-row').forEach((r) => r.classList.remove('active'));
    }

    document.getElementById('ed-close')!.addEventListener('click', closeEditor);

    // ── Summary ────────────────────────────────────────────────────────────────
    function populateSummary(c: CreatureRow) {
      const fields: [string, string | null | undefined][] = [
        ['Status',    c.status],
        ['World',     c.world_name],
        ['Size',      c.kind_size],
        ['Diet',      c.kind_diet],
        ['Movement',  c.kind_movement?.join(', ') ?? null],
        ['Solitary',  c.kind_solitary != null ? (c.kind_solitary ? 'Yes' : 'No') : null],
        ['Climate',   c.habitat_climate],
        ['Biomes',    c.habitat_biome?.join(', ') ?? null],
        ['Threat',    c.behaviour_threat],
        ['Habitat',   c.habitat_notes],
        ['Behaviour', c.behaviour_notes],
        ['Food',      c.food_notes],
        ['Ability',   c.special_ability],
        ['Lore',      c.lore_description],
        ['Origin',    c.lore_origin],
      ];

      const dl = document.getElementById('ed-summary') as HTMLDListElement;
      dl.innerHTML = fields
        .filter(([, v]) => v)
        .map(([k, v]) => `<dt>${k}</dt><dd>${String(v)}</dd>`)
        .join('');

      const artEl = document.getElementById('ed-art') as HTMLDivElement;
      artEl.innerHTML = c.artUrl
        ? `<img src="${c.artUrl}" alt="Creature art" class="art-img" />`
        : '';
    }

    // ── Balance form ───────────────────────────────────────────────────────────
    function populateBalance(c: CreatureRow) {
      (document.getElementById('bal-tier') as HTMLSelectElement).value = c.balance_tier ?? '';
      (document.getElementById('bal-notes') as HTMLTextAreaElement).value = c.balance_notes ?? '';
      (document.getElementById('biome-aff') as HTMLInputElement).value =
        c.biome_affinity?.join(', ') ?? '';
      setStatus('balance-status', '', '');
    }

    document.getElementById('balance-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!activeId) return;

      const tier = (document.getElementById('bal-tier') as HTMLSelectElement).value;
      const notes = (document.getElementById('bal-notes') as HTMLTextAreaElement).value;
      const biomeRaw = (document.getElementById('biome-aff') as HTMLInputElement).value;
      const biomes = biomeRaw.split(',').map((s) => s.trim()).filter(Boolean);

      const btn = document.getElementById('save-balance-btn') as HTMLButtonElement;
      btn.disabled = true;
      setStatus('balance-status', '', '');

      const res = await fetch('/api/creatures/balance', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: activeId, balance_tier: tier, balance_notes: notes, biome_affinity: biomes }),
      });

      btn.disabled = false;
      if (res.ok) {
        setStatus('balance-status', 'Saved.', 'ok');
        // Update local data so the transition buttons see the fresh state
        const c = creatures.find((x) => x.id === activeId);
        if (c) {
          c.balance_tier = tier || null;
          c.balance_notes = notes || null;
          c.biome_affinity = biomes.length ? biomes : null;
        }
      } else {
        setStatus('balance-status', `Error: ${await res.text()}`, 'err');
      }
    });

    // ── Lore section ───────────────────────────────────────────────────────────
    function populateLore(c: CreatureRow) {
      const btn = document.getElementById('create-lore-btn') as HTMLButtonElement;
      const link = document.getElementById('lore-link') as HTMLAnchorElement;

      if (c.lore_entry_url) {
        btn.hidden = true;
        link.hidden = false;
        link.href = c.lore_entry_url;
        link.textContent = 'View in Notion →';
      } else {
        btn.hidden = false;
        link.hidden = true;
      }
      setStatus('lore-status', '', '');
    }

    document.getElementById('create-lore-btn')!.addEventListener('click', async () => {
      if (!activeId) return;
      const btn = document.getElementById('create-lore-btn') as HTMLButtonElement;
      btn.disabled = true;
      setStatus('lore-status', 'Creating…', '');

      const res = await fetch('/api/creatures/create-lore-entry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: activeId }),
      });

      if (res.ok) {
        const data = await res.json() as { ok: boolean; lore_entry_id?: string; lore_entry_url?: string };
        const c = creatures.find((x) => x.id === activeId);
        if (c && data.lore_entry_url) {
          c.lore_entry_id = data.lore_entry_id ?? null;
          c.lore_entry_url = data.lore_entry_url;
          c.status = 'lore-ready';
        }
        setStatus('lore-status', 'Done — reloading…', 'ok');
        setTimeout(() => location.reload(), 800);
      } else {
        setStatus('lore-status', `Error: ${await res.text()}`, 'err');
        btn.disabled = false;
      }
    });

    // ── Graphics rating ────────────────────────────────────────────────────────
    function populateRating(c: CreatureRow) {
      selectedRating = c.graphics_difficulty;
      document.querySelectorAll<HTMLButtonElement>('.rbt').forEach((b) => {
        const n = Number(b.dataset.r);
        b.classList.toggle('selected', n === selectedRating);
      });
      (document.getElementById('gfx-notes') as HTMLTextAreaElement).value = c.graphics_notes ?? '';
      setStatus('rating-status', '', '');

      // Rating section only shown for lore-ready creatures
      const ratingSection = document.getElementById('ed-rating-section') as HTMLElement;
      ratingSection.hidden = c.status !== 'lore-ready';
    }

    document.querySelectorAll<HTMLButtonElement>('.rbt').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedRating = Number(btn.dataset.r);
        document.querySelectorAll('.rbt').forEach((b) => b.classList.remove('selected'));
        btn.classList.add('selected');
      });
    });

    document.getElementById('save-rating-btn')!.addEventListener('click', async () => {
      if (!activeId) return;
      if (!selectedRating) {
        setStatus('rating-status', 'Select a rating first.', 'err');
        return;
      }
      const notes = (document.getElementById('gfx-notes') as HTMLTextAreaElement).value;
      const btn = document.getElementById('save-rating-btn') as HTMLButtonElement;
      btn.disabled = true;
      setStatus('rating-status', 'Saving…', '');

      const res = await fetch('/api/creatures/rating', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: activeId, graphics_difficulty: selectedRating, graphics_notes: notes }),
      });

      if (res.ok) {
        setStatus('rating-status', 'Rated — reloading…', 'ok');
        setTimeout(() => location.reload(), 800);
      } else {
        setStatus('rating-status', `Error: ${await res.text()}`, 'err');
        btn.disabled = false;
      }
    });

    // ── Status transitions ─────────────────────────────────────────────────────
    function populateTransitions(c: CreatureRow) {
      const container = document.getElementById('transition-buttons') as HTMLDivElement;
      container.innerHTML = '';
      setStatus('transition-status', '', '');

      type Btn = { label: string; toStatus: string; cls: string };
      const NEXT: Record<string, Btn[]> = {
        'submitted':  [
          { label: 'Approve',  toStatus: 'approved',  cls: 'btn btn-success' },
          { label: 'Reject',   toStatus: 'rejected',  cls: 'btn btn-danger'  },
        ],
        'approved':   [{ label: 'Mark balanced',      toStatus: 'balanced',  cls: 'btn btn-primary' }],
        'balanced':   [],  // transition handled by Create Lore Page action
        'lore-ready': [],  // transition handled by Save Rating button
        'queued':     [{ label: 'Move to spriting',   toStatus: 'spriting',  cls: 'btn btn-primary' }],
        'spriting':   [{ label: 'Mark shipped',        toStatus: 'in-game',   cls: 'btn btn-success' }],
        'in-game':    [],
        'rejected':   [],
      };

      const buttons = NEXT[c.status] ?? [];
      if (buttons.length === 0) {
        container.innerHTML = '<span style="color:var(--text-dim);font-size:0.82rem">No transitions available from this stage.</span>';
        return;
      }

      buttons.forEach(({ label, toStatus, cls }) => {
        const btn = document.createElement('button');
        btn.textContent = label;
        btn.className = cls;
        btn.addEventListener('click', () => triggerTransition(toStatus, btn));
        container.appendChild(btn);
      });
    }

    async function triggerTransition(toStatus: string, btn: HTMLButtonElement) {
      if (!activeId) return;
      btn.disabled = true;
      setStatus('transition-status', 'Updating…', '');

      const res = await fetch('/api/creatures/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: activeId, status: toStatus }),
      });

      if (res.ok) {
        setStatus('transition-status', 'Done — reloading…', 'ok');
        setTimeout(() => location.reload(), 600);
      } else {
        const msg = await res.text();
        setStatus('transition-status', `Error: ${msg}`, 'err');
        btn.disabled = false;
      }
    }

    // ── Helper ─────────────────────────────────────────────────────────────────
    function setStatus(elId: string, msg: string, cls: 'ok' | 'err' | '') {
      const el = document.getElementById(elId);
      if (!el) return;
      el.textContent = msg;
      el.className = `form-status${cls ? ' ' + cls : ''}`;
    }
  </script>
</body>
</html>
