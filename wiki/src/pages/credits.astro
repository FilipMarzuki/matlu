---
import Base from '../layouts/Base.astro';
import { getWikiSupabase } from '../lib/supabase';
import type { CreatureSubmission } from '../../../src/types/database.types';

type CreditedCreature = CreatureSubmission & { creator_name: string };

interface MakerGroup {
  name: string;
  creatures: CreditedCreature[];
}

let makers: MakerGroup[] = [];
try {
  const sb = getWikiSupabase();
  const { data } = await sb
    .from('creature_submissions')
    .select('*')
    .eq('approved', true)
    .eq('credits_opt_in', true)
    .not('creator_name', 'is', null);

  const rows = (data ?? []).filter(
    (c): c is CreditedCreature => Boolean(c.creator_name),
  );

  // Group by creator_name, sorted alphabetically
  const grouped = new Map<string, CreditedCreature[]>();
  for (const c of rows) {
    const existing = grouped.get(c.creator_name);
    if (existing) {
      existing.push(c);
    } else {
      grouped.set(c.creator_name, [c]);
    }
  }

  makers = [...grouped.entries()]
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([name, creatures]) => ({ name, creatures }));
} catch {
  // Degrades to empty state when Supabase is unavailable
}
---

<Base title="Credits" description="Thank you to everyone who contributed creatures to the Matlu multiworld.">
  <h1>Credits</h1>
  <p class="intro">
    These are the players and creators who contributed creatures to Core Warden.
    Every creature in this list is part of the world because of them.
  </p>

  {makers.length === 0 ? (
    <div class="empty">
      <p>No credits yet — check back after the first creatures are approved.</p>
    </div>
  ) : (
    <div class="makers">
      {makers.map(({ name, creatures }) => (
        <section class="maker-row">
          <h2 class="maker-name">{name}</h2>
          <div class="creature-list">
            {creatures.map((c) => (
              <a href={c.slug ? `/creatures/${c.slug}` : '/creatures'} class="creature-chip">
                {c.art_path && (
                  <img src={c.art_path} alt={c.creature_name} class="chip-thumb" loading="lazy" />
                )}
                <span>{c.creature_name}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</Base>

<style>
  h1 { margin-bottom: 0.5rem; }

  .intro {
    color: var(--text-dim);
    max-width: 560px;
    margin-bottom: 2.5rem;
  }

  .empty {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 1.5rem;
    color: var(--text-dim);
  }

  .empty p { margin: 0; }

  .makers {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .maker-row {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
  }

  .maker-row:last-child { border-bottom: none; }

  .maker-name {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--accent-hi);
  }

  .creature-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .creature-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.35rem 0.75rem 0.35rem 0.35rem;
    text-decoration: none;
    color: var(--text);
    font-size: 0.875rem;
    transition: border-color 0.15s;
  }

  .creature-chip:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .chip-thumb {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    object-fit: cover;
    display: block;
  }
</style>
