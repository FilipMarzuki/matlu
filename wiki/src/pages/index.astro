---
import Base from '../layouts/Base.astro';
import CreatureParade from '../components/CreatureParade.astro';
import { fetchAllLore, TYPE_LABELS } from '../lib/notion-lore';

const gameUrl = import.meta.env.PUBLIC_GAME_URL ?? 'https://corewarden.app';

// 3 most-recent lore entries for the world teaser
const allLore = await fetchAllLore();
const recentLore = allLore.slice(0, 3);

// Generate a pixel-jagged bottom edge for the hero divider.
// Steps are 16px wide × 8px tall on a strict 8px grid, across 1200px.
function jaggedPath(): string {
  const W = 1200, H = 32, sw = 16;
  const ys = [0, 8, 16, 24];
  // Irregular but deterministic step sequence — avoids obvious repeating pattern
  const seq = [2, 0, 3, 1, 2, 3, 0, 1, 3, 2, 0, 3, 1, 0, 2, 3, 1, 0, 2, 1];
  let d = `M0,${H}`;
  let x = 0;
  let i = 0;
  while (x < W) {
    const y = H - ys[seq[i % seq.length]];
    d += ` L${x},${y} L${Math.min(x + sw, W)},${y}`;
    x += sw;
    i++;
  }
  d += ` L${W},${H} Z`;
  return d;
}
const dividerPath = jaggedPath();
---

<Base
  title="Matlu Codex"
  description="Matlu Codex — lore, biomes, and creatures for Core Warden."
>
  <!-- ── Hero + parade live outside <main> via the named slot ───────────── -->
  <Fragment slot="hero">
  <section class="hero">
    <!-- Game art background -->
    <div class="hero-bg" aria-hidden="true"></div>
    <!-- Dark gradient so text at bottom is always readable -->
    <div class="hero-overlay" aria-hidden="true"></div>
    <!-- Content centred to match main's max-width -->
    <div class="hero-content">
      <h1>
        <span class="t-en">The Matlu Multiworld</span>
        <span class="t-sv">Matlu-multiversum</span>
      </h1>
      <p class="lead">
        <span class="t-en">The world companion for <strong>Core Warden</strong> — lore, biomes, creatures, and more.
          Explore the world, meet its peoples, and help bring its creatures to life.</span>
        <span class="t-sv">Världsguiden för <strong>Core Warden</strong> — lore, biomer, väsen och mer.
          Utforska världen, möt dess folk och hjälp till att skapa väsen.</span>
      </p>
      <a href={gameUrl} class="cta" target="_blank" rel="noopener">
        <span class="t-en">Play Core Warden →</span>
        <span class="t-sv">Spela Core Warden →</span>
      </a>
    </div>
    <!-- Pixel-stepped divider blends hero into the page background -->
    <div class="hero-divider" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 32"
        preserveAspectRatio="none"
        width="100%"
        height="32"
      >
        <path fill="#080d08" d={dividerPath} />
      </svg>
    </div>
  </section>
  <CreatureParade />
  </Fragment>

  <!-- ── Lore teaser ───────────────────────────────────────────────────── -->
  <section class="section">
    <div class="section-head">
      <h2>📖 Lore</h2>
      <a href="/lore" class="see-all">
        <span class="t-en">Browse all →</span>
        <span class="t-sv">Visa alla →</span>
      </a>
    </div>

    {recentLore.length > 0 ? (
      <div class="card-grid">
        {recentLore.map((entry) => (
          <a href={`/lore/${entry.slug}`} class="card">
            <div class="card-top">
              <span class="badge">{TYPE_LABELS[entry.type]}</span>
              {entry.world && <span class="world-tag">{entry.world}</span>}
            </div>
            <h3>{entry.title}</h3>
            {entry.summary && <p class="card-p">{entry.summary}</p>}
          </a>
        ))}
      </div>
    ) : (
      <div class="coming-soon">
        <span class="t-en">Lore entries coming soon.</span>
        <span class="t-sv">Lore-inlägg kommer snart.</span>
        <a href="/lore">
          <span class="t-en">Visit the lore section →</span>
          <span class="t-sv">Besök lore-sektionen →</span>
        </a>
      </div>
    )}
  </section>

  <!-- ── Biomes teaser ─────────────────────────────────────────────────── -->
  <section class="section">
    <div class="section-head">
      <h2>
        <span class="t-en">🌍 Biomes</span>
        <span class="t-sv">🌍 Biomer</span>
      </h2>
    </div>
    <div class="coming-soon">
      <span class="t-en">Biome cards coming soon — from Meadow to Deep Sea.</span>
      <span class="t-sv">Biomkort kommer snart — från äng till djuphav.</span>
    </div>
  </section>

  <!-- ── Creatures teaser ──────────────────────────────────────────────── -->
  <section class="section">
    <div class="section-head">
      <h2>
        <span class="t-en">🦎 Creatures</span>
        <span class="t-sv">🦎 Väsen</span>
      </h2>
    </div>
    <div class="coming-soon">
      <span class="t-en">Creature gallery coming soon.</span>
      <span class="t-sv">Väsensgalleri kommer snart.</span>
      <a href="/creatures/submit">
        <span class="t-en">Submit a creature →</span>
        <span class="t-sv">Skicka in ett väsen →</span>
      </a>
    </div>
  </section>

  <!-- ── Contribute CTA ────────────────────────────────────────────────── -->
  <section class="contribute">
    <h2>
      <span class="t-en">Contribute to the World</span>
      <span class="t-sv">Bidra till världen</span>
    </h2>
    <p>
      <span class="t-en">The Matlu multiworld grows with the community. Submit a creature you've dreamed up, or play the game and share your feedback.</span>
      <span class="t-sv">Matlu-multiversum växer med gemenskapen. Skicka in ett väsen du drömt om, eller spela och dela din feedback.</span>
    </p>
    <div class="cta-row">
      <a href="/creatures/submit" class="btn btn-primary">
        <span class="t-en">Submit a creature</span>
        <span class="t-sv">Skicka in ett väsen</span>
      </a>
      <a href="/playtest" class="btn btn-secondary">
        <span class="t-en">Give feedback</span>
        <span class="t-sv">Ge feedback</span>
      </a>
    </div>
  </section>
</Base>

<style>
  /* ── Hero ───────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    min-height: 75vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  /* Game art — cover, anchored so the character silhouettes sit near bottom */
  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/assets/hero-banner.png') center 35% / cover no-repeat;
    z-index: 0;
  }

  /* Gradient: light at top (sky reads through), heavy at bottom (text legible) */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8, 13, 8, 0.05) 0%,
      rgba(8, 13, 8, 0.35) 45%,
      rgba(8, 13, 8, 0.82) 78%,
      #080d08 100%
    );
    z-index: 1;
  }

  /* Text block — centred to match main's 860px max-width */
  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem 3.5rem;
  }

  .hero-content h1 {
    font-size: 2.6rem;
    color: var(--gold);
    text-shadow: 0 0 32px rgba(255, 224, 102, 0.35);
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.05rem;
    color: var(--text-dim);
    max-width: 500px;
    margin-bottom: 1.75rem;
    line-height: 1.7;
  }

  .lead strong { color: var(--text); }

  a.cta {
    display: inline-block;
    background: var(--gold);
    color: #1a1200;
    font-size: 0.9rem;
    font-family: 'Pixelify Sans', monospace;
    font-weight: 700;
    padding: 0.6rem 1.4rem;
    border-radius: 0;
    text-decoration: none;
    box-shadow: 3px 3px 0 var(--gold-dim);
    transition: box-shadow 0.08s, transform 0.08s;
  }

  a.cta:hover  { box-shadow: 4px 4px 0 var(--gold-dim); text-decoration: none; }
  a.cta:active { box-shadow: 1px 1px 0 var(--gold-dim); transform: translate(2px, 2px); }

  /* Pixel-stepped edge — fills with --bg color to mask the image bottom */
  .hero-divider {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 3;
    line-height: 0;
  }

  /* ── Sections ───────────────────────────────────────────────────────── */
  .section { margin-bottom: 3rem; }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-head h2 { font-size: 1.25rem; color: var(--text); }

  .see-all { font-size: 0.85rem; color: var(--accent-hi); }

  /* ── Card grid ──────────────────────────────────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 12px rgba(95, 168, 95, 0.1);
    text-decoration: none;
  }

  .card-top { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }

  .badge {
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--badge-bg);
    color: var(--badge-text);
    border-radius: 4px;
    padding: 0.12rem 0.45rem;
  }

  .world-tag { font-size: 0.74rem; color: var(--text-dim); }

  .card h3 {
    font-size: 0.95rem;
    color: var(--gold);
    font-family: 'Pixelify Sans', monospace;
    font-weight: 700;
  }

  .card-p {
    font-size: 0.84rem;
    color: var(--text-dim);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Coming soon ────────────────────────────────────────────────────── */
  .coming-soon {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
  }

  .coming-soon a { color: var(--accent-hi); font-size: 0.875rem; }

  /* ── Contribute CTA ─────────────────────────────────────────────────── */
  .contribute {
    margin-top: 1rem;
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-align: center;
  }

  .contribute h2 { font-size: 1.3rem; margin-bottom: 0.75rem; }

  .contribute p {
    color: var(--text-dim);
    max-width: 480px;
    margin: 0 auto 1.5rem;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .cta-row {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.55rem 1.2rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
  }

  .btn-primary {
    background: var(--gold);
    color: #1a1200;
    border-radius: 0;
    box-shadow: 3px 3px 0 var(--gold-dim);
    transition: box-shadow 0.08s, transform 0.08s;
  }

  .btn-primary:hover  { text-decoration: none; box-shadow: 4px 4px 0 var(--gold-dim); }
  .btn-primary:active { box-shadow: 1px 1px 0 var(--gold-dim); transform: translate(2px, 2px); }

  .btn-secondary {
    background: var(--surface-hi);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent-hi);
    color: var(--accent-hi);
    text-decoration: none;
  }

  /* ── Mobile ─────────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .hero { min-height: 60vh; }
    .hero-content h1 { font-size: 1.9rem; }
    .hero-bg { background-position: 65% 35%; }
  }
</style>
