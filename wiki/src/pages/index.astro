---
import Base from '../layouts/Base.astro';
---

<Base title="Matlu Codex" description="Matlu Codex — lore, biomes, and creatures for Core Warden.">
  <section class="hero">
    <h1>Matlu Codex</h1>
    <p class="lead">The world companion for <strong>Core Warden</strong> — lore, biomes, creatures, and more.</p>
  </section>

  <nav class="cards">
    <a href="/lore" class="card">
      <span class="icon">📖</span>
      <h2>Lore</h2>
      <p>Stories, history, and the forces shaping the Matlu multiworld.</p>
    </a>
    <a href="/biomes" class="card">
      <span class="icon">🌍</span>
      <h2>Biomes</h2>
      <p>Every terrain type — from Meadow to Deep Sea — with tile previews.</p>
    </a>
    <a href="/creatures" class="card">
      <span class="icon">🦎</span>
      <h2>Creatures</h2>
      <p>The animals, enemies, and NPCs that inhabit each region.</p>
    </a>
    <a href="/playtest" class="card card--cta">
      <span class="icon">🎮</span>
      <h2>Playtest</h2>
      <p>Try Core Warden in your browser and share what you think.</p>
    </a>
  </nav>
</Base>

<style>
  .hero {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .hero h1 {
    font-size: 2.8rem;
    color: var(--accent-hi);
    text-shadow: 0 0 32px rgba(192, 132, 252, 0.3);
    margin-bottom: 0.75rem;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--text-dim);
    max-width: 520px;
  }

  .lead strong { color: var(--text); }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.15);
    text-decoration: none;
  }

  .card--cta {
    border-color: rgba(168, 85, 247, 0.4);
  }

  .icon { font-size: 1.5rem; }

  .card h2 {
    font-size: 1.1rem;
    color: var(--accent-hi);
  }

  .card p {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin: 0;
  }
</style>
