---
import Base from '../../layouts/Base.astro';
import { BIOMES } from '../../data/biomes';

const gameUrl = import.meta.env.PUBLIC_GAME_URL ?? 'https://corewarden.app';
const worldForgeUrl = `${gameUrl}/biome`;

/** Convert a biome name to a URL-safe slug for anchors and screenshot filenames. */
function slugify(name: string): string {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

/** Render a Phaser hex color (e.g. 0x6abf45) as a CSS hex string (#6abf45). */
function hexColor(c: number): string {
  return '#' + c.toString(16).padStart(6, '0');
}

/** Render a 0–1 value as a CSS width percentage (clamped). */
function pct(v: number): string {
  return `${Math.round(Math.min(1, Math.max(0, v)) * 100)}%`;
}

const biomes = BIOMES.map((b) => ({
  ...b,
  slug: slugify(b.name),
  css: hexColor(b.overlayColor),
}));
---

<Base title="Biomes" description="Every biome in the Matlu multiworld — from Sea to Snow Field.">
  <h1>Biomes</h1>
  <p class="subtitle">The twelve terrain types of Mistheim, from sea level to permanent snowfield.</p>

  <!-- World Forge promo -->
  <div class="world-forge-card">
    <div class="world-forge-info">
      <h2>World Forge</h2>
      <p>Explore every biome in Core Warden — inspect tile palettes, decoration scatter, and biome boundaries in real time. Works in your browser.</p>
    </div>
    <a href={worldForgeUrl} class="world-forge-btn" target="_blank" rel="noopener">
      Open World Forge →
    </a>
  </div>

  <!-- Biome card grid -->
  <div class="grid">
    {biomes.map((b) => (
      <article id={b.slug} class="card">
        <!-- Color swatch -->
        <div class="swatch" style={`background: ${b.css};`}>
          <!-- Screenshot if it exists — served from public/assets/screenshots/biomes/<slug>.png -->
          <img
            src={`/assets/screenshots/biomes/${b.slug}.png`}
            alt={`${b.name} screenshot`}
            class="screenshot"
            onerror="this.style.display='none'"
            loading="lazy"
          />
        </div>

        <div class="body">
          <h2>
            <span class="name">{b.name}</span>
            <a href={`#${b.slug}`} class="anchor" aria-label={`Link to ${b.name}`}>#</a>
          </h2>

          <!-- Env stats: elev / temp / moist -->
          <div class="stats">
            <div class="stat">
              <span class="stat-label">Elev</span>
              <div class="bar-track">
                <div class="bar-fill" style={`width: ${pct(b.elev)};`} />
              </div>
              <span class="stat-val">{Math.round(b.elev * 100)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Temp</span>
              <div class="bar-track">
                <div class="bar-fill bar-temp" style={`width: ${pct(b.temp)};`} />
              </div>
              <span class="stat-val">{Math.round(b.temp * 100)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Moist</span>
              <div class="bar-track">
                <div class="bar-fill bar-moist" style={`width: ${pct(b.moist)};`} />
              </div>
              <span class="stat-val">{Math.round(b.moist * 100)}</span>
            </div>
          </div>

          <p class="desc">{b.description}</p>
        </div>
      </article>
    ))}
  </div>
</Base>

<style>
  h1 { margin-bottom: 0.4rem; }

  .subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }

  /* ── World Forge promo ──────────────────────────────────────────────── */
  .world-forge-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent-hi);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
    background: rgba(192, 132, 252, 0.04);
    flex-wrap: wrap;
  }

  .world-forge-info h2 {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--accent-hi);
    margin: 0 0 0.3rem 0;
  }

  .world-forge-info p {
    font-family: 'Outfit', sans-serif;
    font-size: 0.87rem;
    color: var(--text-dim);
    margin: 0;
    max-width: 460px;
  }

  .world-forge-btn {
    display: inline-block;
    white-space: nowrap;
    background: var(--accent);
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.6rem 1.25rem;
    border-radius: 5px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .world-forge-btn:hover { background: var(--accent-hi); text-decoration: none; }

  /* ── Biome card grid ────────────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .card:target {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(168, 85, 247, 0.25);
  }

  /* ── Swatch / screenshot ────────────────────────────────────────────── */
  .swatch {
    height: 100px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .screenshot {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Card body ──────────────────────────────────────────────────────── */
  .body { padding: 1rem; }

  h2 {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    font-size: 1rem;
  }

  .name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    color: var(--text);
  }

  .anchor {
    font-size: 0.75rem;
    color: var(--text-dim);
    opacity: 0;
    transition: opacity 0.15s;
    text-decoration: none;
  }

  .card:hover .anchor { opacity: 1; }

  /* ── Env stat bars ──────────────────────────────────────────────────── */
  .stats {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 0.85rem;
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .stat-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    color: var(--text-dim);
    width: 32px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .bar-track {
    flex: 1;
    height: 5px;
    background: var(--surface-hi);
    border-radius: 3px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.3s;
  }

  .bar-temp  { background: var(--amber); }
  .bar-moist { background: #4ab0d0; }

  .stat-val {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    color: var(--text-dim);
    width: 24px;
    text-align: right;
  }

  /* ── Description ────────────────────────────────────────────────────── */
  .desc {
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin: 0;
  }
</style>
