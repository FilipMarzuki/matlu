---
import LoreDetailContent from '../../../components/pages/LoreDetailContent.astro';
import { fetchAllLore, fetchLoreBody } from '../../../lib/notion-lore';
import { marked } from 'marked';

export async function getStaticPaths() {
  const entries = await fetchAllLore();
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const rawMd = await fetchLoreBody(entry.id);
const bodyHtml = rawMd ? String(await marked(rawMd)) : '';
---
<LoreDetailContent lang="sv" entry={entry} bodyHtml={bodyHtml} />
