---
import Base from '../../layouts/Base.astro';
import { fetchAllLore, TYPE_LABELS } from '../../lib/notion-lore';
import type { LoreType } from '../../lib/notion-lore';

const entries = await fetchAllLore();

// Group by type in display order
const ORDER: LoreType[] = ['characters', 'locations', 'factions', 'worlds'];
const grouped = ORDER.map((type) => ({
  type,
  label: TYPE_LABELS[type] + 's',
  entries: entries.filter((e) => e.type === type),
})).filter((g) => g.entries.length > 0);

const hasData = entries.length > 0;
---

<Base title="Lore" description="Lore of the Matlu multiworld — characters, locations, factions, and worlds.">
  <h1 data-i18n="lore.title">Lore</h1>
  <p class="subtitle" data-i18n="lore.subtitle">Stories, history, and the forces shaping the Matlu multiworld.</p>

  {!hasData && (
    <div class="empty">
      <p data-i18n="lore.coming_soon">Lore entries coming soon.</p>
      <p class="hint">Data loads from Notion at build time — set <code>NOTION_API_KEY</code> to see entries.</p>
    </div>
  )}

  {grouped.map(({ label, entries: group }) => (
    <section class="group">
      <h2>{label}</h2>
      <div class="card-grid">
        {group.map((entry) => (
          <a href={`/lore/${entry.slug}`} class="card">
            <div class="card-top">
              <span class="badge">{TYPE_LABELS[entry.type]}</span>
              {entry.world && <span class="world">{entry.world}</span>}
            </div>
            <h3>{entry.title}</h3>
            {entry.summary && <p class="summary">{entry.summary}</p>}
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  h1 { margin-bottom: 0.4rem; }

  .subtitle {
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .empty {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 1.5rem;
    color: var(--text-dim);
  }

  .empty p { margin-bottom: 0.5rem; }
  .empty p:last-child { margin-bottom: 0; }

  .hint {
    font-size: 0.85rem;
    color: var(--text-dim);
    opacity: 0.7;
  }

  .group { margin-bottom: 2.5rem; }

  h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 12px rgba(95, 168, 95, 0.1);
    text-decoration: none;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .badge {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--badge-bg);
    color: var(--badge-text);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
  }

  .world {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .card h3 {
    font-size: 1rem;
    color: var(--gold);
    font-family: 'Pixelify Sans', monospace;
    font-weight: 700;
  }

  .summary {
    font-size: 0.875rem;
    color: var(--text-dim);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
