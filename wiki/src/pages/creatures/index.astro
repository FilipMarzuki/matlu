---
import { readFile } from 'node:fs/promises';
import Base from '../../layouts/Base.astro';

interface RegistryEntity {
  class: string;
  type: 'enemy' | 'hero' | 'summon' | string;
  category?: string;
  world?: string;
  personality?: string;
  spritesheetJson?: string | null;
  name_en?: string;
  name_sv?: string;
  submissionCreator?: string;
}

interface RegistryData {
  entities: RegistryEntity[];
}

interface CreatureCard {
  id: string;
  name: string;
  world: string;
  typeLabel: string;
  personality: string | null;
  spritePreview: string | null;
  creator: string | null;
}

function humanize(value: string): string {
  return value
    .replace(/([a-z0-9])([A-Z])/g, '$1 $2')
    .replace(/[-_]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function isCreatureEntity(entity: RegistryEntity): boolean {
  if (entity.type === 'enemy' || entity.type === 'summon') return true;
  return entity.type === 'hero' && entity.category === 'npc-world-character';
}

function resolveTypeLabel(entity: RegistryEntity): string {
  if (entity.type === 'enemy') return 'Enemy';
  if (entity.type === 'summon') return 'Summon';
  if (entity.type === 'hero' && entity.category === 'npc-world-character') return 'NPC';
  return humanize(entity.type);
}

function resolveDisplayName(entity: RegistryEntity): string {
  return entity.name_en ?? humanize(entity.class);
}

function resolveSpritePreview(entity: RegistryEntity): string | null {
  if (!entity.spritesheetJson) return null;
  if (!entity.spritesheetJson.startsWith('public/')) return null;
  return `/${entity.spritesheetJson.slice('public/'.length).replace(/\.json$/, '.png')}`;
}

const registryText = await readFile(
  new URL('../../../../src/entities/entity-registry.json', import.meta.url),
  'utf8'
);
const registry = JSON.parse(registryText) as RegistryData;

const creatures: CreatureCard[] = registry.entities
  .filter((entity: RegistryEntity): boolean => isCreatureEntity(entity))
  .map((entity: RegistryEntity): CreatureCard => ({
    id: entity.class,
    name: resolveDisplayName(entity),
    world: entity.world ? humanize(entity.world) : 'Unknown',
    typeLabel: resolveTypeLabel(entity),
    personality: entity.personality ?? null,
    spritePreview: resolveSpritePreview(entity),
    creator: entity.submissionCreator ?? null,
  }))
  .sort((a: CreatureCard, b: CreatureCard): number => {
    const worldCompare = a.world.localeCompare(b.world);
    return worldCompare !== 0 ? worldCompare : a.name.localeCompare(b.name);
  });
---

<Base title="Creatures" description="Animals, enemies, and NPCs that inhabit each region of the Matlu multiworld.">
  <h1>
    <span class="t-en">Creatures</span>
    <span class="t-sv">Väsen</span>
  </h1>
  <p class="lead">
    <span class="t-en">A registry-backed field guide of creatures across Matlu worlds.</span>
    <span class="t-sv">En registerbaserad fälthandbok över väsen i Matlus världar.</span>
  </p>

  <div class="grid">
    {creatures.map((creature) => (
      <article id={creature.id} class="card">
        <div class="card-img">
          {creature.spritePreview
            ? (
              <img
                src={creature.spritePreview}
                alt={`${creature.name} sprite`}
                loading="lazy"
                decoding="async"
                onerror="this.style.display='none'; this.nextElementSibling?.classList.add('show')"
              />
            )
            : null}
          <div class:list={['card-img-placeholder', !creature.spritePreview && 'show']}>?</div>
        </div>

        <div class="card-body">
          <h2 class="card-name">{creature.name}</h2>

          <div class="card-tags">
            <span class="tag">{creature.typeLabel}</span>
            <span class="tag tag--world">{creature.world}</span>
          </div>

          {creature.personality ? <p class="card-excerpt">{creature.personality}</p> : null}
          {creature.creator ? <p class="card-credit">Creator: {creature.creator}</p> : null}
        </div>
      </article>
    ))}
  </div>
</Base>

<style>
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }

  .lead {
    color: var(--text-dim);
    font-size: 1rem;
    margin-bottom: 2rem;
    max-width: 560px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .card-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--surface-hi, rgba(255, 255, 255, 0.04));
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    background: rgba(0, 0, 0, 0.18);
  }

  .card-img-placeholder {
    display: none;
    font-size: 2.4rem;
    color: var(--border);
  }

  .card-img-placeholder.show { display: block; }

  .card-body {
    padding: 0.9rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-name {
    font-family: 'Pixelify Sans', monospace;
    font-size: 1.05rem;
    color: var(--accent-hi);
    margin: 0;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--mono, monospace);
    font-size: 0.72rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: rgba(168, 85, 247, 0.1);
    color: var(--accent-hi);
    border: 1px solid rgba(168, 85, 247, 0.25);
  }

  .tag--world {
    background: rgba(74, 222, 128, 0.08);
    color: var(--green, #4ade80);
    border-color: rgba(74, 222, 128, 0.2);
  }

  .card-excerpt {
    font-size: 0.82rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .card-credit {
    margin: 0;
    font-size: 0.75rem;
    color: var(--text-dim);
  }
</style>
