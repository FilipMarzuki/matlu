---
/**
 * Creature submission form — FIL-432 (Creatures A2).
 *
 * Kid-friendly form for submitting fantasy creatures to the Matlu creature
 * encyclopedia. Features:
 *   - Live completion score (0–100) with colour-coded progress bar
 *   - Submit button disabled until required fields + consent are met
 *   - localStorage draft auto-save (debounce 500 ms), resume banner on reload
 *   - Image upload to Supabase Storage bucket "creature-art/pending/<uuid>.<ext>"
 *   - Row insert into creature_submissions; rollback upload on insert failure
 *
 * Pattern mirrors wiki/src/pages/playtest.astro: Supabase creds are baked in
 * at build time via VITE_* env vars and bridged to <script> via data attributes.
 */
import Base from '../../layouts/Base.astro';
import { LICENSE_VERSION } from './license.astro';

const supabaseUrl = import.meta.env.VITE_SUPABASE_URL ?? '';
const supabaseKey = import.meta.env.VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY ?? '';
---

<Base
  title="Submit a Creature"
  description="Share your fantasy creature with the Matlu world. Upload a drawing and tell us all about it!"
>
  <!-- Supabase config bridge (same pattern as playtest.astro) -->
  <div id="supa-cfg" data-url={supabaseUrl} data-key={supabaseKey} hidden></div>
  <!-- License version passed to the insert -->
  <div id="license-ver" data-version={LICENSE_VERSION} hidden></div>

  <h1>
    <span class="t-en">Submit a Creature</span>
    <span class="t-sv">Skicka in ett väsen</span>
  </h1>
  <p class="lead">
    <span class="t-en">Share your fantasy creature with the Matlu world!
      Fill in as many fields as you can — the more detail you add, the better the chances
      it inspires a real in-game creature.</span>
    <span class="t-sv">Dela ditt fantasiväsen med Matlu-världen!
      Fyll i så många fält du kan — ju mer detaljer, desto större chans att det inspirerar ett riktigt spelväsen.</span>
  </p>

  <!-- Draft resume banner (shown by JS if localStorage draft exists) -->
  <div id="draft-banner" class="draft-banner" hidden>
    <span id="draft-msg"></span>
    <div class="draft-actions">
      <button type="button" id="btn-resume" class="btn-ghost">
        <span class="t-en">Resume</span>
        <span class="t-sv">Fortsätt</span>
      </button>
      <button type="button" id="btn-fresh" class="btn-ghost btn-ghost--warn">
        <span class="t-en">Start fresh</span>
        <span class="t-sv">Börja om</span>
      </button>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="progress-wrap" aria-label="Completion progress">
    <div class="progress-bar-track">
      <div id="progress-bar" class="progress-bar" style="width:0%" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
    <span id="progress-label" class="progress-label">0%</span>
  </div>
  <p id="missing-fields" class="missing-fields" hidden></p>

  <form id="submit-form" novalidate>

    <!-- ── Section 1: Your creature ───────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">Your creature</span>
        <span class="t-sv">Ditt väsen</span>
      </h2>

      <div class="field">
        <label for="creature_name">
          <span class="t-en">Creature name</span>
          <span class="t-sv">Väsenets namn</span>
          <span class="req"> *</span>
        </label>
        <input id="creature_name" name="creature_name" type="text" maxlength="120"
               placeholder="e.g. Gloomfin, Thornback, Velcrid" autocomplete="off" />
      </div>

      <div class="field">
        <label for="world_name">
          <span class="t-en">Which world does it live in?</span>
          <span class="t-sv">Vilken värld lever det i?</span>
          <span class="hint"> (<span class="t-en">optional</span><span class="t-sv">valfritt</span>)</span>
        </label>
        <input id="world_name" name="world_name" type="text" maxlength="120"
               placeholder="e.g. Spinolandet, The Living Sea…" autocomplete="off" />
      </div>
    </section>

    <!-- ── Section 2: About you ───────────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">About you</span>
        <span class="t-sv">Om dig</span>
      </h2>

      <div class="field">
        <label for="creator_name">
          <span class="t-en">Your name</span>
          <span class="t-sv">Ditt namn</span>
          <span class="hint"> (<span class="t-en">optional — used for credits</span><span class="t-sv">valfritt — används i krediter</span>)</span>
        </label>
        <input id="creator_name" name="creator_name" type="text" maxlength="120"
               placeholder="First name or nickname" autocomplete="name" />
      </div>

      <div class="field">
        <label for="maker_age">
          <span class="t-en">Your age</span>
          <span class="t-sv">Din ålder</span>
          <span class="hint"> (<span class="t-en">optional</span><span class="t-sv">valfritt</span>)</span>
        </label>
        <input id="maker_age" name="maker_age" type="number" min="1" max="120"
               placeholder="e.g. 10" style="max-width:120px" />
      </div>

      <div class="field">
        <label for="contact_email">
          <span class="t-en">Parent / guardian email</span>
          <span class="t-sv">Förälder / vårdnadshavares e-post</span>
          <span class="hint"> (<span class="t-en">optional — we may reach out about your creature</span><span class="t-sv">valfritt — vi kan höra av oss om ditt väsen</span>)</span>
        </label>
        <input id="contact_email" name="contact_email" type="email" maxlength="254"
               placeholder="parent@example.com" autocomplete="email" />
      </div>
    </section>

    <!-- ── Section 3: Picture ─────────────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">Picture</span>
        <span class="t-sv">Bild</span>
        <span class="req"> *</span>
      </h2>
      <p class="section-desc">
        <span class="t-en">Upload a drawing, painting, or photo. Any style — pencil sketch, crayon, digital — is great.
          Max 5 MB. Accepted: JPG, PNG, GIF, WebP.
          <strong>Please only upload the drawing — not a photo of a person.</strong></span>
        <span class="t-sv">Ladda upp en teckning, målning eller foto. Alla stilar fungerar — blyerts, krita, digitalt.
          Max 5 MB. Godkänt: JPG, PNG, GIF, WebP.
          <strong>Ladda bara upp teckningen — inte ett foto på en person.</strong></span>
      </p>
      <div id="image-resume-hint" class="info-note" hidden>
        <span class="t-en">Images can't be saved in drafts — please pick your file again.</span>
        <span class="t-sv">Bilder sparas inte i utkast — välj din fil igen.</span>
      </div>
      <div class="field">
        <label for="art_file">
          <span class="t-en">Choose image</span>
          <span class="t-sv">Välj bild</span>
          <span class="req"> *</span>
        </label>
        <input id="art_file" name="art_file" type="file"
               accept="image/jpeg,image/png,image/gif,image/webp" />
        <span id="art_file_error" class="field-error" hidden></span>
      </div>
      <div class="field">
        <label for="art_credit">
          <span class="t-en">Art credit</span>
          <span class="t-sv">Bildkrediter</span>
          <span class="hint"> (<span class="t-en">leave blank to use your name above</span><span class="t-sv">lämna tomt för att använda ditt namn ovan</span>)</span>
        </label>
        <input id="art_credit" name="art_credit" type="text" maxlength="120"
               placeholder="Who made the drawing?" />
      </div>
    </section>

    <!-- ── Section 4: What kind? ──────────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">What kind of creature is it?</span>
        <span class="t-sv">Vad för sorts väsen är det?</span>
      </h2>

      <div class="field">
        <label for="kind_size">
          <span class="t-en">Size</span>
          <span class="t-sv">Storlek</span>
        </label>
        <select id="kind_size" name="kind_size">
          <option value="" data-en="— choose —" data-sv="— välj —">— choose —</option>
          <option value="tiny" data-en="Tiny (fits in your hand)" data-sv="Pytteliten (får plats i handen)">Tiny (fits in your hand)</option>
          <option value="small" data-en="Small (like a cat or dog)" data-sv="Liten (som en katt eller hund)">Small (like a cat or dog)</option>
          <option value="medium" data-en="Medium (like a person)" data-sv="Mellanstor (som en person)">Medium (like a person)</option>
          <option value="large" data-en="Large (like a horse or bear)" data-sv="Stor (som en häst eller björn)">Large (like a horse or bear)</option>
          <option value="huge" data-en="Huge (bigger than a house)" data-sv="Jättelik (större än ett hus)">Huge (bigger than a house)</option>
        </select>
      </div>

      <div class="field">
        <label>
          <span class="t-en">How does it move?</span>
          <span class="t-sv">Hur rör det sig?</span>
          <span class="hint"> (<span class="t-en">pick all that apply</span><span class="t-sv">välj alla som stämmer</span>)</span>
        </label>
        <div class="checkbox-group">
          {([
            ['walk',    'Walk',    'Går'],
            ['swim',    'Swim',    'Simmar'],
            ['fly',     'Fly',     'Flyger'],
            ['burrow',  'Burrow',  'Gräver'],
            ['crawl',   'Crawl',   'Kryper'],
            ['slither', 'Slither', 'Slingrar'],
          ] as [string, string, string][]).map(([v, en, sv]) => (
            <label class="checkbox-label">
              <input type="checkbox" name="kind_movement" value={v} />
              <span class="t-en">{en}</span>
              <span class="t-sv">{sv}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="field">
        <label>
          <span class="t-en">Does it live alone or in groups?</span>
          <span class="t-sv">Lever det ensamt eller i grupp?</span>
        </label>
        <div class="radio-row">
          <label class="radio-label">
            <input type="radio" name="kind_solitary" value="true" />
            <span class="t-en">Alone</span><span class="t-sv">Ensamt</span>
          </label>
          <label class="radio-label">
            <input type="radio" name="kind_solitary" value="false" />
            <span class="t-en">Groups</span><span class="t-sv">Grupp</span>
          </label>
          <label class="radio-label">
            <input type="radio" name="kind_solitary" value="" checked />
            <span class="t-en">Not sure</span><span class="t-sv">Vet ej</span>
          </label>
        </div>
      </div>
    </section>

    <!-- ── Section 5: Habitat ─────────────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">Where does it live?</span>
        <span class="t-sv">Var lever det?</span>
      </h2>

      <div class="field">
        <label>
          <span class="t-en">Biome / habitat</span>
          <span class="t-sv">Biom / livsmiljö</span>
          <span class="hint"> (<span class="t-en">pick all that apply</span><span class="t-sv">välj alla som stämmer</span>)</span>
        </label>
        <div class="checkbox-group">
          {([
            ['forest',      'Forest',           'Skog'],
            ['meadow',      'Meadow',            'Äng'],
            ['mountain',    'Mountain',          'Berg'],
            ['desert',      'Desert',            'Öken'],
            ['ocean',       'Ocean / Sea',       'Hav'],
            ['river',       'River / Lake',      'Å / Sjö'],
            ['swamp',       'Swamp / Bog',       'Träsk / Mosse'],
            ['tundra',      'Tundra / Arctic',   'Tundra / Arktis'],
            ['underground', 'Underground / Cave','Under jord / Grotta'],
            ['sky',         'Sky / Clouds',      'Himmel / Moln'],
          ] as [string, string, string][]).map(([v, en, sv]) => (
            <label class="checkbox-label">
              <input type="checkbox" name="habitat_biome" value={v} />
              <span class="t-en">{en}</span>
              <span class="t-sv">{sv}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="field">
        <label for="habitat_climate">
          <span class="t-en">Climate</span>
          <span class="t-sv">Klimat</span>
        </label>
        <select id="habitat_climate" name="habitat_climate">
          <option value="" data-en="— choose —" data-sv="— välj —">— choose —</option>
          <option value="tropical" data-en="Tropical (hot and wet)" data-sv="Tropiskt (varmt och fuktigt)">Tropical (hot and wet)</option>
          <option value="temperate" data-en="Temperate (mild)" data-sv="Tempererat (milt)">Temperate (mild)</option>
          <option value="arid" data-en="Arid (hot and dry)" data-sv="Torrt (varmt och torrt)">Arid (hot and dry)</option>
          <option value="cold" data-en="Cold / Polar" data-sv="Kallt / Polärt">Cold / Polar</option>
          <option value="any" data-en="Adapts to any climate" data-sv="Anpassar sig till vilket klimat som helst">Adapts to any climate</option>
        </select>
      </div>

      <div class="field">
        <label for="habitat_notes">
          <span class="t-en">Anything else about where it lives?</span>
          <span class="t-sv">Något annat om var det lever?</span>
          <span class="hint"> (<span class="t-en">optional</span><span class="t-sv">valfritt</span>)</span>
        </label>
        <textarea id="habitat_notes" name="habitat_notes" rows={2}
                  placeholder="e.g. 'hides under rocks near waterfalls'"></textarea>
      </div>
    </section>

    <!-- ── Section 6: Behaviour ───────────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">How does it behave?</span>
        <span class="t-sv">Hur beter det sig?</span>
      </h2>

      <div class="field">
        <label for="behaviour_threat">
          <span class="t-en">How dangerous is it?</span>
          <span class="t-sv">Hur farligt är det?</span>
        </label>
        <select id="behaviour_threat" name="behaviour_threat">
          <option value="" data-en="— choose —" data-sv="— välj —">— choose —</option>
          <option value="friendly" data-en="Friendly — won't attack unless provoked" data-sv="Vänligt — attackerar bara om det provoceras">Friendly — won't attack unless provoked</option>
          <option value="shy" data-en="Shy — runs away from people" data-sv="Blygt — springer ifrån människor">Shy — runs away from people</option>
          <option value="neutral" data-en="Neutral — ignores people" data-sv="Neutralt — ignorerar människor">Neutral — ignores people</option>
          <option value="territorial" data-en="Territorial — attacks if you get too close" data-sv="Revirkänsligt — attackerar om du kommer för nära">Territorial — attacks if you get too close</option>
          <option value="aggressive" data-en="Aggressive — attacks on sight" data-sv="Aggressivt — attackerar direkt">Aggressive — attacks on sight</option>
        </select>
      </div>

      <div class="field">
        <label for="behaviour_notes">
          <span class="t-en">Any other behaviour notes?</span>
          <span class="t-sv">Andra beteendeanteckningar?</span>
          <span class="hint"> (<span class="t-en">optional</span><span class="t-sv">valfritt</span>)</span>
        </label>
        <textarea id="behaviour_notes" name="behaviour_notes" rows={2}
                  placeholder="e.g. 'glows at night', 'leaves trails of flowers'"></textarea>
      </div>
    </section>

    <!-- ── Section 7: Food ────────────────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">What does it eat?</span>
        <span class="t-sv">Vad äter det?</span>
      </h2>

      <div class="field">
        <label for="kind_diet">
          <span class="t-en">Diet</span>
          <span class="t-sv">Kost</span>
        </label>
        <select id="kind_diet" name="kind_diet">
          <option value="" data-en="— choose —" data-sv="— välj —">— choose —</option>
          <option value="herbivore" data-en="Herbivore (plants only)" data-sv="Växtätare (bara växter)">Herbivore (plants only)</option>
          <option value="carnivore" data-en="Carnivore (meat only)" data-sv="Köttätare (bara kött)">Carnivore (meat only)</option>
          <option value="omnivore" data-en="Omnivore (plants and meat)" data-sv="Allätare (växter och kött)">Omnivore (plants and meat)</option>
          <option value="insectivore" data-en="Insectivore (insects)" data-sv="Insektsätare (insekter)">Insectivore (insects)</option>
          <option value="other" data-en="Other / Unknown" data-sv="Annat / Okänt">Other / Unknown</option>
        </select>
      </div>

      <div class="field">
        <label for="food_notes">
          <span class="t-en">Favourite food or hunting style</span>
          <span class="t-sv">Favoritmat eller jaktstil</span>
          <span class="hint"> (<span class="t-en">optional</span><span class="t-sv">valfritt</span>)</span>
        </label>
        <textarea id="food_notes" name="food_notes" rows={2}
                  placeholder="e.g. 'loves berries', 'hunts by mimicking sounds'"></textarea>
      </div>
    </section>

    <!-- ── Section 8: Special ─────────────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">Special things</span>
        <span class="t-sv">Speciella egenskaper</span>
      </h2>

      <div class="field">
        <label for="special_ability">
          <span class="t-en">Special ability or power</span>
          <span class="t-sv">Speciell förmåga eller kraft</span>
          <span class="hint"> (<span class="t-en">optional</span><span class="t-sv">valfritt</span>)</span>
        </label>
        <input id="special_ability" name="special_ability" type="text" maxlength="240"
               placeholder="e.g. 'turns invisible in moonlight', 'heals nearby plants'" />
      </div>
    </section>

    <!-- ── Section 9: Story ───────────────────────────────────────── -->
    <section class="form-section">
      <h2>
        <span class="t-en">The story</span>
        <span class="t-sv">Historien</span>
        <span class="req"> *</span>
      </h2>
      <p class="section-desc">
        <span class="t-en">Tell us about your creature in your own words. Where did it come from? What makes it
          special? What's it like to encounter one? At least 20 characters.</span>
        <span class="t-sv">Berätta om ditt väsen med egna ord. Var kom det ifrån? Vad gör det speciellt?
          Hur är det att möta ett? Minst 20 tecken.</span>
      </p>

      <div class="field">
        <label for="lore_description">
          <span class="t-en">Description</span>
          <span class="t-sv">Beskrivning</span>
          <span class="req"> *</span>
        </label>
        <textarea id="lore_description" name="lore_description" rows={6} maxlength="2000"
                  placeholder="Write at least a sentence or two about your creature…"></textarea>
        <span id="story-count" class="char-count">0 / 2000</span>
      </div>

      <div class="field">
        <label for="lore_origin">
          <span class="t-en">Origin story</span>
          <span class="t-sv">Ursprungsberättelse</span>
          <span class="hint"> (<span class="t-en">optional — how did it come to exist?</span><span class="t-sv">valfritt — hur uppstod det?</span>)</span>
        </label>
        <textarea id="lore_origin" name="lore_origin" rows={3} maxlength="1000"
                  placeholder="e.g. 'Created when lightning struck an ancient oak…'"></textarea>
      </div>
    </section>

    <!-- ── Section 10: Consent ────────────────────────────────────── -->
    <section class="form-section form-section--consent">
      <h2>
        <span class="t-en">Consent</span>
        <span class="t-sv">Samtycke</span>
      </h2>

      <div class="field field--check">
        <label class="checkbox-label checkbox-label--block">
          <input type="checkbox" id="credits_opt_in" name="credits_opt_in" checked />
          <span class="t-en">Credit me in the game if my creature is added
            <span class="hint">(your creator name will appear in the in-game credits)</span></span>
          <span class="t-sv">Ge mig krediter om mitt väsen läggs till
            <span class="hint">(ditt skaparnamn visas i spelets krediter)</span></span>
        </label>
      </div>

      <div class="field field--check">
        <label class="checkbox-label checkbox-label--block">
          <input type="checkbox" id="license_accepted" name="license_accepted" />
          <span>
            <span class="t-en">I agree to the <a href="/creatures/license" target="_blank" rel="noopener">Creature Submission License</a></span>
            <span class="t-sv">Jag godkänner <a href="/creatures/license" target="_blank" rel="noopener">Väsensinlämningslicensen</a></span>
            <span class="req"> *</span>
          </span>
        </label>
      </div>

      <div class="field field--check">
        <label class="checkbox-label checkbox-label--block">
          <input type="checkbox" id="parental_consent" name="parental_consent" />
          <span>
            <span class="t-en">A parent or guardian has read the license and gives permission for this submission</span>
            <span class="t-sv">En förälder eller vårdnadshavare har läst licensen och ger tillstånd för denna inlämning</span>
            <span class="req"> *</span>
          </span>
        </label>
      </div>
    </section>

    <!-- Submit -->
    <div class="submit-row">
      <button type="submit" id="submit-btn" disabled title="">
        <span class="t-en">Submit creature</span>
        <span class="t-sv">Skicka in väsen</span>
      </button>
      <span id="submit-hint" class="submit-hint"></span>
    </div>

    <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
  </form>
</Base>

<script>
  import { createClient } from '@supabase/supabase-js';

  // ── Language helper ───────────────────────────────────────────────────────
  // Reads current html[data-lang] at call time so it reacts to live switches.
  const isSv = (): boolean => document.documentElement.getAttribute('data-lang') === 'sv';
  function t(en: string, sv: string): string { return isSv() ? sv : en; }

  // ── Supabase client ───────────────────────────────────────────────────────
  const cfg = document.getElementById('supa-cfg') as HTMLElement;
  const supabase = createClient(cfg.dataset.url ?? '', cfg.dataset.key ?? '');
  const LICENSE_VERSION = (document.getElementById('license-ver') as HTMLElement).dataset.version ?? 'v1-2026-04';

  // ── Translate select options on lang change ───────────────────────────────
  // Options use data-en / data-sv attributes set in the HTML.
  function translateSelects(): void {
    document.querySelectorAll<HTMLOptionElement>('[data-en]').forEach(opt => {
      opt.textContent = isSv() ? (opt.dataset.sv ?? opt.dataset.en ?? '') : (opt.dataset.en ?? '');
    });
  }
  translateSelects();
  document.addEventListener('langchange', translateSelects);

  // ── Form elements ─────────────────────────────────────────────────────────
  const form        = document.getElementById('submit-form') as HTMLFormElement;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitHint  = document.getElementById('submit-hint') as HTMLElement;
  const statusEl    = document.getElementById('form-status') as HTMLElement;
  const progressBar = document.getElementById('progress-bar') as HTMLElement;
  const progressLbl = document.getElementById('progress-label') as HTMLElement;
  const missingEl   = document.getElementById('missing-fields') as HTMLElement;
  const storyCount  = document.getElementById('story-count') as HTMLElement;
  const draftBanner = document.getElementById('draft-banner') as HTMLElement;
  const draftMsg    = document.getElementById('draft-msg') as HTMLElement;
  const imageHint   = document.getElementById('image-resume-hint') as HTMLElement;
  const artFileErr  = document.getElementById('art_file_error') as HTMLElement;

  const DRAFT_KEY = 'creature-draft-v1';
  const ALLOWED_MIME = ['image/jpeg','image/png','image/gif','image/webp'];
  const MAX_SIZE = 5 * 1024 * 1024; // 5 MB

  // ── Draft persistence ─────────────────────────────────────────────────────
  // Captures all text/select/checkbox/radio values; skips the file input.
  function captureDraft(): Record<string, unknown> {
    const data: Record<string, unknown> = { savedAt: new Date().toISOString() };
    const fd = new FormData(form);
    // Multi-value fields (checkboxes)
    const multiKeys = ['kind_movement', 'habitat_biome'];
    for (const key of multiKeys) {
      data[key] = fd.getAll(key);
    }
    // Everything else
    for (const [key, val] of fd.entries()) {
      if (key === 'art_file') continue;
      if (multiKeys.includes(key)) continue;
      data[key] = val;
    }
    return data;
  }

  function restoreDraft(draft: Record<string, unknown>): void {
    for (const [key, val] of Object.entries(draft)) {
      if (key === 'savedAt') continue;

      if (key === 'kind_movement' || key === 'habitat_biome') {
        const values = val as string[];
        form.querySelectorAll<HTMLInputElement>(`input[name="${key}"]`).forEach(cb => {
          cb.checked = values.includes(cb.value);
        });
        continue;
      }

      const el = form.elements.namedItem(key);
      if (!el) continue;
      if (el instanceof HTMLInputElement) {
        if (el.type === 'checkbox') el.checked = val === 'on' || val === true || val === 'true';
        else if (el.type === 'radio') {
          form.querySelectorAll<HTMLInputElement>(`input[name="${key}"]`).forEach(r => {
            r.checked = r.value === val;
          });
        } else el.value = String(val ?? '');
      } else if (el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement) {
        el.value = String(val ?? '');
      }
    }
  }

  // Debounce
  let saveTimer: ReturnType<typeof setTimeout>;
  function scheduleSave(): void {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(() => {
      try { localStorage.setItem(DRAFT_KEY, JSON.stringify(captureDraft())); } catch { /* storage full */ }
    }, 500);
  }

  // ── Progress scoring ──────────────────────────────────────────────────────
  function computeScore(): { score: number; missing: string[] } {
    const fd = new FormData(form);
    const missing: string[] = [];
    let score = 0;

    // Required (40 pts total)
    if (fd.get('creature_name')?.toString().trim()) score += 10; else missing.push(t('Creature name', 'Väsenets namn'));
    const story = fd.get('lore_description')?.toString().trim() ?? '';
    if (story.length >= 20) score += 20; else missing.push(t('Description (min 20 characters)', 'Beskrivning (minst 20 tecken)'));
    const file = (form.elements.namedItem('art_file') as HTMLInputElement).files?.[0];
    if (file) score += 10; else missing.push(t('Picture', 'Bild'));

    // Consent (not in score — just gates submit)
    const licenseOk = (form.elements.namedItem('license_accepted') as HTMLInputElement).checked;
    const parentOk  = (form.elements.namedItem('parental_consent') as HTMLInputElement).checked;
    if (!licenseOk) missing.push(t('License agreement', 'Licensavtal'));
    if (!parentOk)  missing.push(t('Parental consent', 'Föräldrars samtycke'));

    // Optional bonuses (up to 60 pts)
    const opt: [string, string, string][] = [
      ['kind_size',        'Size',           'Storlek'],
      ['habitat_climate',  'Climate',        'Klimat'],
      ['behaviour_threat', 'Danger level',   'Farlighetsnivå'],
      ['kind_diet',        'Diet',           'Kost'],
      ['world_name',       'World name',     'Världsnamn'],
      ['creator_name',     'Your name',      'Ditt namn'],
      ['special_ability',  'Special ability','Speciell förmåga'],
      ['lore_origin',      'Origin story',   'Ursprungsberättelse'],
      ['habitat_notes',    'Habitat notes',  'Livsmiljöanteckningar'],
      ['food_notes',       'Food notes',     'Matanteckningar'],
      ['behaviour_notes',  'Behaviour notes','Beteendeanteckningar'],
    ];
    const ptsEach = Math.floor(60 / opt.length);
    for (const [field] of opt) {
      if (fd.get(field)?.toString().trim()) score += ptsEach;
    }

    // Movement checkboxes
    if (fd.getAll('kind_movement').length > 0) score += ptsEach;
    // Habitat biome checkboxes
    if (fd.getAll('habitat_biome').length > 0) score += ptsEach;
    // Story length bonus (up to 5 extra pts)
    if (story.length >= 200) score += 3;
    if (story.length >= 500) score += 2;

    return { score: Math.min(score, 100), missing };
  }

  function updateProgress(): void {
    const { score, missing } = computeScore();
    const licenseOk = (form.elements.namedItem('license_accepted') as HTMLInputElement).checked;
    const parentOk  = (form.elements.namedItem('parental_consent') as HTMLInputElement).checked;
    const requiredMet = missing.filter(m => !m.includes('consent') && !m.includes('License')).length === 0;
    const canSubmit = requiredMet && licenseOk && parentOk;

    progressBar.style.width = `${score}%`;
    progressBar.setAttribute('aria-valuenow', String(score));
    progressBar.className = 'progress-bar' + (score >= 70 ? ' green' : score >= 40 ? ' amber' : ' red');
    progressLbl.textContent = `${score}% ${t('complete', 'klart')}`;

    if (missing.length) {
      missingEl.textContent = t('Still needed: ', 'Saknas fortfarande: ') + missing.join(', ');
      missingEl.hidden = false;
    } else {
      missingEl.hidden = true;
    }

    submitBtn.disabled = !canSubmit;
    submitBtn.title = canSubmit ? '' : t('Complete the required fields first', 'Fyll i de obligatoriska fälten först');
    submitHint.textContent = canSubmit ? '' : missing.join(' · ');
  }

  // ── Story char counter ────────────────────────────────────────────────────
  const storyEl = document.getElementById('lore_description') as HTMLTextAreaElement;
  storyEl.addEventListener('input', () => {
    storyCount.textContent = `${storyEl.value.length} / 2000`;
  });

  // ── Image validation ──────────────────────────────────────────────────────
  const artFile = document.getElementById('art_file') as HTMLInputElement;
  artFile.addEventListener('change', () => {
    const file = artFile.files?.[0];
    artFileErr.hidden = true;
    if (file) {
      if (!ALLOWED_MIME.includes(file.type)) {
        artFileErr.textContent = t('Please choose a JPG, PNG, GIF, or WebP image.', 'Välj en JPG-, PNG-, GIF- eller WebP-bild.');
        artFileErr.hidden = false;
        artFile.value = '';
      } else if (file.size > MAX_SIZE) {
        artFileErr.textContent = t(
          `Image is too large (${(file.size/1024/1024).toFixed(1)} MB). Max 5 MB.`,
          `Bilden är för stor (${(file.size/1024/1024).toFixed(1)} MB). Max 5 MB.`,
        );
        artFileErr.hidden = false;
        artFile.value = '';
      }
    }
    updateProgress();
  });

  // ── Wire all inputs to progress + auto-save ───────────────────────────────
  form.addEventListener('input',  () => { updateProgress(); scheduleSave(); });
  form.addEventListener('change', () => { updateProgress(); scheduleSave(); });
  updateProgress();

  // Re-run progress labels when the user switches language mid-fill.
  document.addEventListener('langchange', () => updateProgress());

  // ── Draft banner ──────────────────────────────────────────────────────────
  function relativeTime(isoStr: string): string {
    const diff = Date.now() - new Date(isoStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 2) return 'just now';
    if (mins < 60) return `${mins} minutes ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs} hour${hrs !== 1 ? 's' : ''} ago`;
    return `${Math.floor(hrs / 24)} day${Math.floor(hrs/24) !== 1 ? 's' : ''} ago`;
  }

  const savedRaw = localStorage.getItem(DRAFT_KEY);
  if (savedRaw) {
    try {
      const draft = JSON.parse(savedRaw) as Record<string, unknown>;
      draftMsg.textContent = t(
        `You have an unfinished creature from ${relativeTime(draft.savedAt as string)}. Pick up where you left off?`,
        `Du har ett osparat väsen från ${relativeTime(draft.savedAt as string)}. Vill du fortsätta?`,
      );
      draftBanner.hidden = false;

      document.getElementById('btn-resume')!.addEventListener('click', () => {
        restoreDraft(draft);
        imageHint.hidden = false;
        draftBanner.hidden = true;
        updateProgress();
      });

      document.getElementById('btn-fresh')!.addEventListener('click', () => {
        localStorage.removeItem(DRAFT_KEY);
        draftBanner.hidden = true;
      });
    } catch { localStorage.removeItem(DRAFT_KEY); }
  }

  // ── Submit ────────────────────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const file = artFile.files?.[0];
    if (!file) {
      statusEl.textContent = t('Please add a picture.', 'Lägg till en bild.');
      statusEl.className = 'form-status error';
      return;
    }

    submitBtn.disabled = true;
    statusEl.textContent = t('Uploading picture…', 'Laddar upp bild…');
    statusEl.className = 'form-status';

    // Generate upload path
    const ext = file.name.split('.').pop()?.toLowerCase() ?? 'jpg';
    const uuid = crypto.randomUUID();
    const storagePath = `pending/${uuid}.${ext}`;

    // Upload image
    const { error: uploadErr } = await supabase.storage
      .from('creature-art')
      .upload(storagePath, file, { contentType: file.type, upsert: false });

    if (uploadErr) {
      console.error('Upload error:', uploadErr);
      statusEl.textContent = t('Could not upload your picture. Please try again.', 'Kunde inte ladda upp din bild. Försök igen.');
      statusEl.className = 'form-status error';
      submitBtn.disabled = false;
      return;
    }

    // Collect form data
    statusEl.textContent = t('Saving your creature…', 'Sparar ditt väsen…');
    const fd = new FormData(form);
    const { score } = computeScore();

    const solitaryRaw = fd.get('kind_solitary')?.toString();
    const solitary = solitaryRaw === 'true' ? true : solitaryRaw === 'false' ? false : null;

    const row = {
      creature_name:    fd.get('creature_name')?.toString().trim() ?? '',
      creator_name:     fd.get('creator_name')?.toString().trim() || null,
      maker_age:        fd.get('maker_age') ? Number(fd.get('maker_age')) : null,
      contact_email:    fd.get('contact_email')?.toString().trim() || null,
      world_name:       fd.get('world_name')?.toString().trim() || null,
      art_path:         storagePath,
      art_credit:       fd.get('art_credit')?.toString().trim() || fd.get('creator_name')?.toString().trim() || null,
      kind_size:        fd.get('kind_size')?.toString() || null,
      kind_diet:        fd.get('kind_diet')?.toString() || null,
      kind_movement:    fd.getAll('kind_movement').map(String).filter(Boolean),
      kind_solitary:    solitary,
      habitat_biome:    fd.getAll('habitat_biome').map(String).filter(Boolean),
      habitat_climate:  fd.get('habitat_climate')?.toString() || null,
      habitat_notes:    fd.get('habitat_notes')?.toString().trim() || null,
      behaviour_threat: fd.get('behaviour_threat')?.toString() || null,
      behaviour_notes:  fd.get('behaviour_notes')?.toString().trim() || null,
      food_notes:       fd.get('food_notes')?.toString().trim() || null,
      special_ability:  fd.get('special_ability')?.toString().trim() || null,
      lore_description: fd.get('lore_description')?.toString().trim() || null,
      lore_origin:      fd.get('lore_origin')?.toString().trim() || null,
      credits_opt_in:   (form.elements.namedItem('credits_opt_in') as HTMLInputElement).checked,
      license_accepted: true,
      license_version:  LICENSE_VERSION,
      parental_consent: true,
      completion_score: score,
      approved:         false,
    };

    const { error: insertErr } = await supabase.from('creature_submissions').insert(row);

    if (insertErr) {
      console.error('Insert error:', insertErr);
      // Best-effort rollback — delete the uploaded image
      await supabase.storage.from('creature-art').remove([storagePath]);
      statusEl.textContent = t('Something went wrong saving your creature. Please try again.', 'Något gick fel när väsenet sparades. Försök igen.');
      statusEl.className = 'form-status error';
      submitBtn.disabled = false;
      return;
    }

    // Success
    localStorage.removeItem(DRAFT_KEY);
    form.reset();
    updateProgress();
    statusEl.textContent = t(
      '🎉 Thanks! Your creature is waiting to be approved. We\'ll review it soon!',
      '🎉 Tack! Ditt väsen väntar på godkännande. Vi granskar det snart!',
    );
    statusEl.className = 'form-status success';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

<style>
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .lead { color: var(--text-dim); max-width: 580px; margin-bottom: 2rem; font-size: 1rem; }

  /* ── Draft banner ─────────────────────────────────────────────── */
  .draft-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    background: rgba(251,191,36,0.08);
    border: 1px solid rgba(251,191,36,0.35);
    border-radius: 8px;
    padding: 0.85rem 1.1rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: var(--text);
  }
  .draft-actions { display: flex; gap: 0.5rem; }
  .btn-ghost {
    background: none;
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--text);
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    padding: 0.3rem 0.75rem;
    transition: border-color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent-hi); }
  .btn-ghost--warn:hover { border-color: var(--red); color: var(--red); }

  /* ── Progress ─────────────────────────────────────────────────── */
  .progress-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .progress-bar-track {
    flex: 1;
    height: 8px;
    background: var(--surface-hi, rgba(255,255,255,0.06));
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .progress-bar {
    height: 100%;
    border-radius: 4px;
    transition: width 0.25s, background 0.25s;
  }
  .progress-bar.red   { background: var(--red,   #f87171); }
  .progress-bar.amber { background: var(--amber, #fbbf24); }
  .progress-bar.green { background: var(--green, #4ade80); }
  .progress-label { font-size: 0.8rem; color: var(--text-dim); white-space: nowrap; }
  .missing-fields {
    font-size: 0.82rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  /* ── Form sections ────────────────────────────────────────────── */
  .form-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem 1.5rem 0.75rem;
    margin-bottom: 1.25rem;
  }
  .form-section h2 {
    font-size: 1.05rem;
    color: var(--accent-hi);
    margin: 0 0 1.1rem 0;
    font-family: 'Syne', sans-serif;
  }
  .form-section--consent { border-left: 3px solid var(--accent); }
  .section-desc { font-size: 0.875rem; color: var(--text-dim); margin: -0.5rem 0 1rem; }

  /* ── Fields ───────────────────────────────────────────────────── */
  .field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1.1rem; }
  .field--check { flex-direction: row; align-items: flex-start; }

  label { font-size: 0.92rem; color: var(--text); }
  .req { color: var(--red, #f87171); }
  .hint { color: var(--text-dim); font-size: 0.82rem; font-weight: 400; }

  input[type="text"],
  input[type="email"],
  input[type="number"],
  select,
  textarea {
    background: var(--bg, #0f0f13);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    font-size: 0.92rem;
    padding: 0.55rem 0.75rem;
    transition: border-color 0.15s;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  textarea { resize: vertical; min-height: 72px; }
  select { cursor: pointer; }
  input[type="file"] { font-size: 0.88rem; color: var(--text-dim); }

  .char-count { font-size: 0.78rem; color: var(--text-dim); align-self: flex-end; }
  .field-error { font-size: 0.82rem; color: var(--red, #f87171); }

  /* ── Checkboxes / radios ──────────────────────────────────────── */
  .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    cursor: pointer;
    color: var(--text-dim);
  }
  .checkbox-label--block {
    align-items: flex-start;
    color: var(--text);
    line-height: 1.5;
  }
  .checkbox-label--block input { margin-top: 3px; }
  .checkbox-label:has(input:checked) { color: var(--text); }
  .radio-row { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .radio-label { display: flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; cursor: pointer; color: var(--text-dim); }
  .radio-label:has(input:checked) { color: var(--accent-hi); }
  input[type="checkbox"], input[type="radio"] {
    accent-color: var(--accent-hi);
    width: 1rem;
    height: 1rem;
    cursor: pointer;
    flex-shrink: 0;
  }

  .info-note {
    background: rgba(168,85,247,0.07);
    border: 1px solid rgba(168,85,247,0.25);
    border-radius: 6px;
    padding: 0.6rem 0.9rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }

  /* ── Submit ───────────────────────────────────────────────────── */
  .submit-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  button[type="submit"] {
    background: var(--accent);
    border: none;
    border-radius: 7px;
    color: #fff;
    cursor: pointer;
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    padding: 0.7rem 2rem;
    transition: background 0.15s;
  }
  button[type="submit"]:hover:not(:disabled) { background: var(--accent-hi); }
  button[type="submit"]:disabled { opacity: 0.45; cursor: not-allowed; }
  .submit-hint { font-size: 0.82rem; color: var(--text-dim); }

  .form-status { margin-top: 1.25rem; font-size: 0.95rem; min-height: 1.4em; }
  .form-status.success { color: var(--green, #4ade80); font-weight: 600; }
  .form-status.error   { color: var(--red,   #f87171); }

  @media (max-width: 520px) {
    .form-section { padding: 1.1rem 1rem 0.5rem; }
    .progress-wrap { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
  }
</style>
