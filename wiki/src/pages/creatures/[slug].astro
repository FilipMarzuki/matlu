  @media (max-width: 620px) {
    .tracker-card { max-width: 100%; }
  }
</style>

<script>
  const canvas = document.getElementById('sprite-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;

    fetch(canvas.dataset.json!)
      .then(r => r.json())
      .then((data: { frames: Array<{ filename: string; frame: { x: number; y: number; w: number; h: number }; duration: number }> }) => {
        let frames = data.frames.filter(f => f.filename.startsWith('idle_south'));
        if (!frames.length) frames = data.frames.slice(0, 4);
        frames.sort((a, b) => a.filename.localeCompare(b.filename, undefined, { numeric: true }));
        if (!frames.length) return;

        const SCALE = 3;
        canvas.width  = frames[0].frame.w * SCALE;
        canvas.height = frames[0].frame.h * SCALE;
        ctx.imageSmoothingEnabled = false;

        let fi = 0, elapsed = 0, lastTs = 0;
        function draw(ts: number) {
          const dt = lastTs ? ts - lastTs : 0;
          lastTs = ts;
          elapsed += dt;
          if (elapsed >= frames[fi].duration) { elapsed -= frames[fi].duration; fi = (fi + 1) % frames.length; }
          const f = frames[fi].frame;
          ctx.clearRect(0, 0, canvas!.width, canvas!.height);
          ctx.drawImage(img, f.x, f.y, f.w, f.h, 0, 0, f.w * SCALE, f.h * SCALE);
          requestAnimationFrame(draw);
        }

        // Set onload before src so it fires even if image is already cached
        const img = new Image();
        img.onload = () => requestAnimationFrame(draw);
        img.src = canvas.dataset.png!;
        // If already complete (cached), kick off manually
        if (img.complete) requestAnimationFrame(draw);
      })
      .catch(() => {});
  }
</script>
