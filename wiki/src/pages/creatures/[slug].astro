---
/**
 * Creature detail page — FIL-433 (Creatures A3).
 *
 * One page per approved creature slug. `getStaticPaths` fetches all approved
 * rows at build time; unapproved / missing slugs are simply not generated (404).
 *
 * FIL-440 (C1): status ribbon + timeline are rendered server-side at build time.
 * All tracker data (history, queue position, ETA) is fetched once in
 * getStaticPaths and distributed to each page via props to avoid N+1 queries.
 */
import Base from '../../layouts/Base.astro';
import {
  fetchApprovedCreatures,
  fetchAllStatusHistory,
  fetchQueuedPositions,
  computeMedianEtaDays,
  imageUrl,
} from '../../lib/supabase-creatures';
import type { Creature, StatusHistoryEntry } from '../../lib/supabase-creatures';
import { getStatusInfo, getCopy } from '../../lib/creature-status';

export async function getStaticPaths() {
  const [creatures, allHistory, queuedPositions] = await Promise.all([
    fetchApprovedCreatures(),
    fetchAllStatusHistory(),
    fetchQueuedPositions(),
  ]);

  // Group history entries by creature_id (already sorted asc by changed_at)
  const historyByCreature = new Map<string, StatusHistoryEntry[]>();
  for (const entry of allHistory) {
    const arr = historyByCreature.get(entry.creature_id) ?? [];
    arr.push(entry);
    historyByCreature.set(entry.creature_id, arr);
  }

  // Build queue-position map: id → 1-indexed rank (lowest queue_priority first)
  const queuePos = new Map<string, number>();
  queuedPositions.forEach((c, i) => queuePos.set(c.id, i + 1));

  // Median days per status — shared across all pages, computed once
  const etaMap = computeMedianEtaDays(allHistory);

  return creatures.map(c => ({
    params: { slug: c.slug },
    props: {
      creature: c,
      history: historyByCreature.get(c.id) ?? [],
      queuePosition: queuePos.get(c.id) ?? null,
      etaMap,
    },
  }));
}

interface Props {
  creature: Creature;
  history: StatusHistoryEntry[];
  queuePosition: number | null;
  etaMap: Record<string, number>;
}
const { creature: c, history, queuePosition, etaMap } = Astro.props;

// ── Ribbon ────────────────────────────────────────────────────────────────────

const statusInfo = getStatusInfo(c.status);
const ribbonCopy   = getCopy(c.status, statusInfo, queuePosition, c.moderation_note, 'en');
const ribbonCopySv = getCopy(c.status, statusInfo, queuePosition, c.moderation_note, 'sv');
const etaDays = c.status ? (etaMap[c.status] ?? null) : null;
const etaRounded = etaDays !== null ? Math.round(etaDays) : null;

// ── Timeline ──────────────────────────────────────────────────────────────────

/** Human-readable relative date, computed at build time. */
function relativeDate(isoString: string): string {
  const diffMs = Date.now() - new Date(isoString).getTime();
  const days = Math.floor(diffMs / 86_400_000);
  if (days === 0) return 'today';
  if (days === 1) return 'yesterday';
  if (days < 30) return `${days} days ago`;
  const months = Math.floor(days / 30);
  if (months === 1) return '1 month ago';
  if (months < 12) return `${months} months ago`;
  const years = Math.floor(months / 12);
  return years === 1 ? '1 year ago' : `${years} years ago`;
}

interface TimelineEntry {
  label: string;
  labelSv: string;
  emoji: string;
  date: string;
  isCurrent: boolean;
}

const timelineEntries: TimelineEntry[] = history.map((entry, i) => {
  const info = getStatusInfo(entry.to_status);
  return {
    label: info.label,
    labelSv: info.labelSv,
    emoji: info.emoji,
    date: relativeDate(entry.changed_at),
    isCurrent: i === history.length - 1,
  };
});

const supabaseUrl = import.meta.env.VITE_SUPABASE_URL ?? '';
const img = imageUrl(supabaseUrl, c.art_path);

// Derive sprite paths from entity_id, e.g. "earth/enemies/fargglad-kordororn"
const spriteSlug = c.entity_id ? c.entity_id.split('/').pop() : null;
const spritePng  = spriteSlug ? `/assets/sprites/characters/${c.entity_id}/${spriteSlug}.png` : null;
const spriteJson = spriteSlug ? `/assets/sprites/characters/${c.entity_id}/${spriteSlug}.json` : null;

// Helper: render a labelled field only when value is present
function val(v: string | null | undefined): string {
  return v?.trim() ?? '';
}
function arr(v: string[] | null | undefined): string[] {
  return (v ?? []).filter(Boolean);
}

const sizeEn: Record<string, string> = {
  tiny: 'Tiny (fits in your hand)', small: 'Small (like a cat or dog)',
  medium: 'Medium (like a person)', large: 'Large (like a horse or bear)',
  huge: 'Huge (bigger than a house)',
};
const sizeSv: Record<string, string> = {
  tiny: 'Pytteliten (får plats i handen)', small: 'Liten (som en katt eller hund)',
  medium: 'Mellanstor (som en person)', large: 'Stor (som en häst eller björn)',
  huge: 'Jättelik (större än ett hus)',
};
const dietEn: Record<string, string> = {
  herbivore: 'Herbivore (plants only)', carnivore: 'Carnivore (meat only)',
  omnivore: 'Omnivore (plants and meat)', insectivore: 'Insectivore (insects)',
  other: 'Other / Unknown',
};
const dietSv: Record<string, string> = {
  herbivore: 'Växtätare (bara växter)', carnivore: 'Köttätare (bara kött)',
  omnivore: 'Allätare (växter och kött)', insectivore: 'Insektsätare (insekter)',
  other: 'Annat / Okänt',
};
const threatEn: Record<string, string> = {
  friendly: 'Friendly', shy: 'Shy', neutral: 'Neutral',
  territorial: 'Territorial', aggressive: 'Aggressive',
};
const threatSv: Record<string, string> = {
  friendly: 'Vänligt', shy: 'Blygt', neutral: 'Neutralt',
  territorial: 'Revirkänsligt', aggressive: 'Aggressivt',
};
const climateEn: Record<string, string> = {
  tropical: 'Tropical', temperate: 'Temperate', arid: 'Arid / Desert',
  cold: 'Cold / Polar', any: 'Adapts to any climate',
};
const climateSv: Record<string, string> = {
  tropical: 'Tropiskt', temperate: 'Tempererat', arid: 'Torrt / Öken',
  cold: 'Kallt / Polärt', any: 'Anpassar sig till alla klimat',
};
const movementSv: Record<string, string> = {
  walk: 'Går', swim: 'Simmar', fly: 'Flyger',
  burrow: 'Gräver', crawl: 'Kryper', slither: 'Slingrar',
};
const biomeSv: Record<string, string> = {
  forest: 'Skog', meadow: 'Äng', mountain: 'Berg', desert: 'Öken',
  ocean: 'Hav', river: 'Å / Sjö', swamp: 'Träsk / Mosse',
  tundra: 'Tundra / Arktis', underground: 'Under jord / Grotta', sky: 'Himmel / Moln',
};

const movements_en = arr(c.kind_movement).map(m => m.charAt(0).toUpperCase() + m.slice(1));
const movements_sv = arr(c.kind_movement).map(m => movementSv[m] ?? m);
const biomes_en = arr(c.habitat_biome).map(b => b.charAt(0).toUpperCase() + b.slice(1));
const biomes_sv = arr(c.habitat_biome).map(b => biomeSv[b] ?? b);
---

<Base
  title={c.creature_name}
  description={c.lore_description ? c.lore_description.slice(0, 160) : `A creature from the Matlu multiworld.`}
>
  <div class="breadcrumb">
    <a href="/creatures">
      <span class="t-en">&larr; All creatures</span>
      <span class="t-sv">&larr; Alla väsen</span>
    </a>
  </div>

  <!-- ── Status ribbon ──────────────────────────────────────────────────────── -->
  <div class="status-ribbon" style={`--ribbon-color: ${statusInfo.borderColor}`}>
    <div class="ribbon-icon" aria-hidden="true">{statusInfo.emoji}</div>
    <div class="ribbon-body">
      <div class="ribbon-label">
        <span class="t-en">{statusInfo.label}</span>
        <span class="t-sv">{statusInfo.labelSv}</span>
      </div>
      <div class="ribbon-copy">
        <span class="t-en">{ribbonCopy}</span>
        <span class="t-sv">{ribbonCopySv}</span>
      </div>
      {etaRounded !== null && (
        <div class="ribbon-eta">
          <span class="t-en">Usually takes about {etaRounded} {etaRounded === 1 ? 'day' : 'days'} at this stage.</span>
          <span class="t-sv">Tar vanligtvis ungefär {etaRounded} {etaRounded === 1 ? 'dag' : 'dagar'} i det här stadiet.</span>
        </div>
      )}
    </div>
  </div>

  <article class="creature">

    <header class="creature-header">
      <div class="creature-title">
        <h1>{c.creature_name}</h1>
        {c.world_name && <p class="world-tag">{c.world_name}</p>}
        {c.creator_name && (
          <p class="creator">
            <span class="t-en">Created by</span>
            <span class="t-sv">Skapad av</span>
            {' '}<strong>{c.art_credit ?? c.creator_name}</strong>
          </p>
        )}
      </div>
      {c.tracker_issue_number && (
        <aside class="tracker-card">
          <p class="tracker-title">
            <span class="t-en">Follow this creature's progress</span>
            <span class="t-sv">Följ det här väsenets resa</span>
          </p>
          <hr class="tracker-rule" />
          <p class="tracker-body">
            <span class="t-en">This creature has a tracker on GitHub where every update is posted.</span>
            <span class="t-sv">Det här väsenet har en spårare på GitHub där alla uppdateringar publiceras.</span>
          </p>
          <a
            href={`https://github.com/FilipMarzuki/matlu/issues/${c.tracker_issue_number}`}
            class="tracker-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="t-en">Open tracker on GitHub →</span>
            <span class="t-sv">Öppna spåraren på GitHub →</span>
          </a>
          <p class="tracker-hint">
            <span class="t-en">Bookmark or subscribe to get notified when it moves forward.</span>
            <span class="t-sv">Bokmärk eller prenumerera för att få ett meddelande när det går vidare.</span>
          </p>
        </aside>
      )}
    </header>

    <!-- Art + in-game sprite (side by side when both present) -->
    <div class="media-row">
      {img && (
        <div class="art-wrap">
          <img src={img} alt={`Drawing of ${c.creature_name}`} class="art" />
          {c.art_credit && c.art_credit !== c.creator_name && (
            <p class="art-credit">
              <span class="t-en">Art by</span>
              <span class="t-sv">Konst av</span>
              {' '}{c.art_credit}
            </p>
          )}
        </div>
      )}
      {spritePng && spriteJson && (
        <div class="sprite-wrap">
          <p class="sprite-label">
            <span class="t-en">In-game sprite</span>
            <span class="t-sv">Spelsprit</span>
          </p>
          <canvas id="sprite-canvas" data-png={spritePng} data-json={spriteJson} class="sprite-canvas"></canvas>
        </div>
      )}
    </div>

    <!-- What kind -->
    {(val(c.kind_size) || movements_en.length || c.kind_solitary !== null) && (
      <section class="detail-section">
        <h2><span class="t-en">What kind of creature</span><span class="t-sv">Vad för sorts väsen</span></h2>
        <dl>
          {val(c.kind_size) && (
            <>
              <dt><span class="t-en">Size</span><span class="t-sv">Storlek</span></dt>
              <dd>
                <span class="t-en">{sizeEn[c.kind_size!] ?? c.kind_size}</span>
                <span class="t-sv">{sizeSv[c.kind_size!] ?? c.kind_size}</span>
              </dd>
            </>
          )}
          {movements_en.length > 0 && (
            <>
              <dt><span class="t-en">Movement</span><span class="t-sv">Rörelse</span></dt>
              <dd>
                <span class="t-en">{movements_en.join(', ')}</span>
                <span class="t-sv">{movements_sv.join(', ')}</span>
              </dd>
            </>
          )}
          {c.kind_solitary !== null && (
            <>
              <dt><span class="t-en">Social</span><span class="t-sv">Socialt</span></dt>
              <dd>
                <span class="t-en">{c.kind_solitary ? 'Lives alone' : 'Lives in groups'}</span>
                <span class="t-sv">{c.kind_solitary ? 'Lever ensamt' : 'Lever i grupp'}</span>
              </dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Habitat -->
    {(biomes_en.length || val(c.habitat_climate) || val(c.habitat_notes)) && (
      <section class="detail-section">
        <h2><span class="t-en">Where it lives</span><span class="t-sv">Var det lever</span></h2>
        <dl>
          {biomes_en.length > 0 && (
            <>
              <dt><span class="t-en">Biome</span><span class="t-sv">Biom</span></dt>
              <dd>
                <span class="t-en">{biomes_en.join(', ')}</span>
                <span class="t-sv">{biomes_sv.join(', ')}</span>
              </dd>
            </>
          )}
          {val(c.habitat_climate) && (
            <>
              <dt><span class="t-en">Climate</span><span class="t-sv">Klimat</span></dt>
              <dd>
                <span class="t-en">{climateEn[c.habitat_climate!] ?? c.habitat_climate}</span>
                <span class="t-sv">{climateSv[c.habitat_climate!] ?? c.habitat_climate}</span>
              </dd>
            </>
          )}
          {val(c.habitat_notes) && (
            <>
              <dt><span class="t-en">Notes</span><span class="t-sv">Anteckningar</span></dt>
              <dd>{c.habitat_notes}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Behaviour -->
    {(val(c.behaviour_threat) || val(c.behaviour_notes)) && (
      <section class="detail-section">
        <h2><span class="t-en">Behaviour</span><span class="t-sv">Beteende</span></h2>
        <dl>
          {val(c.behaviour_threat) && (
            <>
              <dt><span class="t-en">Danger level</span><span class="t-sv">Farlighetsnivå</span></dt>
              <dd>
                <span class="t-en">{threatEn[c.behaviour_threat!] ?? c.behaviour_threat}</span>
                <span class="t-sv">{threatSv[c.behaviour_threat!] ?? c.behaviour_threat}</span>
              </dd>
            </>
          )}
          {val(c.behaviour_notes) && (
            <>
              <dt><span class="t-en">Notes</span><span class="t-sv">Anteckningar</span></dt>
              <dd>{c.behaviour_notes}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Food -->
    {(val(c.kind_diet) || val(c.food_notes)) && (
      <section class="detail-section">
        <h2><span class="t-en">Food</span><span class="t-sv">Mat</span></h2>
        <dl>
          {val(c.kind_diet) && (
            <>
              <dt><span class="t-en">Diet</span><span class="t-sv">Kost</span></dt>
              <dd>
                <span class="t-en">{dietEn[c.kind_diet!] ?? c.kind_diet}</span>
                <span class="t-sv">{dietSv[c.kind_diet!] ?? c.kind_diet}</span>
              </dd>
            </>
          )}
          {val(c.food_notes) && (
            <>
              <dt><span class="t-en">Notes</span><span class="t-sv">Anteckningar</span></dt>
              <dd>{c.food_notes}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Special -->
    {val(c.special_ability) && (
      <section class="detail-section">
        <h2><span class="t-en">Special ability</span><span class="t-sv">Speciell förmåga</span></h2>
        <p class="prose">{c.special_ability}</p>
      </section>
    )}

    <!-- Story -->
    {val(c.lore_description) && (
      <section class="detail-section">
        <h2><span class="t-en">Story</span><span class="t-sv">Historien</span></h2>
        <p class="prose">{c.lore_description}</p>
        {val(c.lore_origin) && (
          <>
            <h3><span class="t-en">Origin</span><span class="t-sv">Ursprung</span></h3>
            <p class="prose">{c.lore_origin}</p>
          </>
        )}
      </section>
    )}

  </article>

  <!-- ── Status timeline (FIL-440 / C1) ───────────────────────────────────── -->
  {timelineEntries.length > 0 && (
    <section class="timeline-section">
      <h2 class="timeline-heading">
        <span class="t-en">Journey so far</span>
        <span class="t-sv">Resan hittills</span>
      </h2>
      <ol class="timeline">
        {timelineEntries.map(entry => (
          <li class={`timeline-entry${entry.isCurrent ? ' timeline-entry--current' : ''}`}>
            <span class="timeline-dot" aria-hidden="true"></span>
            <span class="timeline-text">
              {entry.isCurrent
                ? <>
                    <strong class="t-en">{entry.emoji} {entry.label}</strong>
                    <strong class="t-sv">{entry.emoji} {entry.labelSv}</strong>
                  </>
                : <>
                    <span class="t-en">{entry.emoji} {entry.label}</span>
                    <span class="t-sv">{entry.emoji} {entry.labelSv}</span>
                  </>
              }
              <span class="timeline-date">{entry.date}</span>
            </span>
          </li>
        ))}
      </ol>
    </section>
  )}

  <div class="back-link">
    <a href="/creatures">
      <span class="t-en">&larr; Back to all creatures</span>
      <span class="t-sv">&larr; Tillbaka till alla väsen</span>
    </a>
  </div>
</Base>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--text-dim); }
  .breadcrumb a:hover { color: var(--accent-hi); }

  /* ── Status ribbon ────────────────────────────────────────────────── */
  .status-ribbon {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--ribbon-color, #9ca3af);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
  }
  .ribbon-icon {
    font-size: 1.6rem;
    line-height: 1.2;
    flex-shrink: 0;
  }
  .ribbon-label {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent-hi);
    margin-bottom: 0.2rem;
  }
  .ribbon-copy {
    font-size: 0.9rem;
    color: var(--text);
    font-style: italic;
  }
  .ribbon-eta {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  /* ── Timeline ─────────────────────────────────────────────────────── */
  .timeline-section {
    margin-top: 2rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
  }
  .timeline-heading {
    font-size: 1.05rem;
    color: var(--accent-hi);
    font-family: 'Syne', sans-serif;
    margin-bottom: 1rem;
  }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  /* Vertical rule running through the dots */
  .timeline::before {
    content: '';
    position: absolute;
    left: 0.4rem;
    top: 0.55rem;
    bottom: 0.55rem;
    width: 2px;
    background: var(--border);
  }
  .timeline-entry {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    padding: 0.4rem 0;
    position: relative;
  }
  .timeline-dot {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    background: var(--border);
    border: 2px solid var(--bg);
    flex-shrink: 0;
    margin-top: 0.2rem;
    position: relative;
    z-index: 1;
  }
  .timeline-entry--current .timeline-dot {
    background: var(--accent-hi);
  }
  .timeline-text {
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.5;
  }
  .timeline-text strong {
    color: var(--accent-hi);
  }
  .timeline-date {
    display: inline-block;
    margin-left: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  /* ── Header ───────────────────────────────────────────────────── */
  .creature-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .creature-title h1 {
    font-size: 2.2rem;
    color: var(--accent-hi);
    margin: 0 0 0.3rem 0;
  }
  .world-tag {
    display: inline-block;
    font-family: var(--mono, monospace);
    font-size: 0.78rem;
    color: var(--green, #4ade80);
    border: 1px solid rgba(74,222,128,0.3);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.4rem;
  }
  .creator { font-size: 0.88rem; color: var(--text-dim); margin: 0; }
  .creator strong { color: var(--text); }

  /* ── Art ──────────────────────────────────────────────────────── */
  .art-wrap {
    margin-bottom: 2rem;
    max-width: 560px;
  }
  .art {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--border);
    display: block;
  }
  .art-credit { font-size: 0.8rem; color: var(--text-dim); margin: 0.4rem 0 0; }

  /* ── Detail sections ──────────────────────────────────────────── */
  .detail-section {
    margin-bottom: 1.75rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }
  .detail-section:last-of-type { border-bottom: none; }

  .detail-section h2 {
    font-size: 1.05rem;
    color: var(--accent-hi);
    font-family: 'Pixelify Sans', monospace;
    margin: 0 0 0.85rem 0;
  }
  .detail-section h3 {
    font-size: 0.95rem;
    color: var(--text);
    margin: 1.1rem 0 0.5rem;
  }

  dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.4rem 1.25rem;
    font-size: 0.9rem;
  }
  dt { color: var(--text-dim); font-weight: 500; white-space: nowrap; padding-top: 0.05em; }
  dd { color: var(--text); margin: 0; line-height: 1.5; }

  .prose {
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.7;
    max-width: 640px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ── Back link ────────────────────────────────────────────────── */
  .back-link { margin-top: 2.5rem; font-size: 0.88rem; }
  .back-link a { color: var(--text-dim); }
  .back-link a:hover { color: var(--accent-hi); }

  /* ── Media row ────────────────────────────────────────────────── */
  .media-row { display: flex; gap: 2rem; align-items: flex-start; flex-wrap: wrap; margin-bottom: 2rem; }
  .art-wrap { flex: 1; min-width: 200px; max-width: 480px; margin-bottom: 0; }
  .sprite-wrap { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; flex-shrink: 0; }
  .sprite-label { font-size: 0.78rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05em; margin: 0; }
  .sprite-canvas { image-rendering: pixelated; border: 1px solid var(--border); border-radius: 6px; background: rgba(0,0,0,0.3); }

  @media (max-width: 520px) {
    dl { grid-template-columns: 1fr; }
    dt { font-size: 0.78rem; color: var(--text-dim); margin-bottom: -0.2rem; }
    .media-row { flex-direction: column; }
  }

  /* ── Tracker sidebar card ─────────────────────────────────────────── */
  .tracker-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.1rem;
    background: var(--surface, rgba(255,255,255,0.03));
    min-width: 200px;
    max-width: 260px;
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .tracker-title {
    font-weight: 600;
    color: var(--accent-hi);
    margin: 0 0 0.5rem;
    font-size: 0.88rem;
  }
  .tracker-rule {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 0.75rem;
  }
