---
/**
 * Detail page for a single approved creature.
 *
 * getStaticPaths() fetches all approved creatures at build time from Supabase
 * and generates a static HTML page for each. If the Supabase URL looks like a
 * CI placeholder, it returns [] so the build still succeeds (no pages generated).
 *
 * Newly approved creatures only get a detail page on the next Vercel rebuild.
 * The gallery at /creatures fetches live (client-side) so new approvals show
 * up there immediately — the detail link just won't resolve until the next deploy.
 */
import { createClient } from '@supabase/supabase-js';
import Base from '../../layouts/Base.astro';

interface CreatureRow {
  id: string;
  creature_name: string;
  creator_name: string;
  maker_age: number | null;
  art_path: string | null;
  slug: string | null;
  kind_size: string | null;
  kind_movement: string[] | null;
  kind_diet: string | null;
  kind_solitary: boolean | null;
  habitat_biome: string[] | null;
  habitat_climate: string | null;
  behaviour_threat: string | null;
  behaviour_notes: string | null;
  food_notes: string | null;
  special_ability: string | null;
  lore_description: string | null;
  credits_opt_in: boolean;
  created_at: string;
}

export async function getStaticPaths() {
  const url = import.meta.env.VITE_SUPABASE_URL ?? '';
  const key = import.meta.env.VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY ?? '';

  // Bail out gracefully in CI where credentials are placeholders.
  // CI sends VITE_SUPABASE_URL=https://example.supabase.co — catch that and any
  // other obviously-fake URL so we don't attempt a doomed network request.
  if (!url || !key || url.includes('<project>') || url.includes('example.supabase.co')) return [];

  try {
    const supabase = createClient(url, key);
    const { data, error } = await supabase
      .from('creature_submissions')
      .select('*')
      .eq('approved', true);

    if (error || !data) return [];

    return data
      .filter((c): c is typeof c & { slug: string } => typeof c.slug === 'string' && c.slug !== '')
      .map(c => ({
        params: { slug: c.slug },
        props: { creature: c as unknown as CreatureRow },
      }));
  } catch {
    return [];
  }
}

const { creature } = Astro.props;
const supabaseUrl = import.meta.env.VITE_SUPABASE_URL ?? '';

function storageUrl(path: string): string {
  return `${supabaseUrl}/storage/v1/object/public/creature-art/${path}`;
}

// Parse behaviour_notes JSON (packed by the submit form) for display
interface BehaviourExtra {
  creature_type?: string;
  intelligence?: string;
  activity_time?: string;
  friendliness?: string;
  social_structure?: string;
  sounds?: string;
  weaknesses?: string;
}

let extra: BehaviourExtra = {};
if (creature.behaviour_notes) {
  try {
    extra = JSON.parse(creature.behaviour_notes) as BehaviourExtra;
  } catch {
    // Not JSON — skip parsing, show raw if needed
  }
}

const LABELS: Record<string, string> = {
  beast: 'Beast', spirit: 'Spirit', fey: 'Fey', 'plant-being': 'Plant-being',
  construct: 'Construct', other: 'Other',
  tiny: 'Tiny', small: 'Small', medium: 'Medium', large: 'Large', huge: 'Huge', enormous: 'Enormous',
  animal: 'Like an animal', 'semi-smart': 'Semi-smart', person: 'As smart as a person', smarter: 'Smarter than a person',
  friendly: 'Friendly', shy: 'Shy', neutral: 'Neutral', grumpy: 'Grumpy', mean: 'Mean', scary: 'Scary',
  day: 'Day', night: 'Night', both: 'Day & night', 'dawn-dusk': 'Dawn & dusk',
  alone: 'Alone', pairs: 'Pairs', 'small-groups': 'Small groups', packs: 'Big packs', swarms: 'Huge swarms',
  harmless: 'Harmless', careful: 'Be careful', dangerous: 'Dangerous', deadly: 'Deadly',
  plants: 'Plants', meat: 'Meat', 'magic-energy': 'Magic energy', rocks: 'Rocks', sunlight: 'Sunlight',
  feelings: 'Feelings', hot: 'Hot', cold: 'Cold', wet: 'Wet', dry: 'Dry', any: 'Any climate',
};

function label(v: string | null | undefined): string {
  if (!v) return '—';
  return LABELS[v] ?? v;
}
---

<Base
  title={creature.creature_name}
  description={creature.lore_description?.substring(0, 160) ?? `A creature in the Matlu world.`}
>
  <a href="/creatures" class="back-link">&larr; All creatures</a>

  <div class="creature-header">
    {creature.art_path && (
      <img
        src={storageUrl(creature.art_path)}
        alt={creature.creature_name}
        class="creature-image"
      />
    )}
    <div class="creature-title">
      <h1>{creature.creature_name}</h1>
      {creature.creator_name && <p class="maker">Created by {creature.creator_name}</p>}
      {creature.maker_age && <p class="age">Age {creature.maker_age}</p>}
    </div>
  </div>

  <div class="stats-grid">
    {extra.creature_type && (
      <div class="stat"><span class="stat-label">Type</span><span class="stat-val">{label(extra.creature_type)}</span></div>
    )}
    {creature.kind_size && (
      <div class="stat"><span class="stat-label">Size</span><span class="stat-val">{label(creature.kind_size)}</span></div>
    )}
    {extra.intelligence && (
      <div class="stat"><span class="stat-label">Intelligence</span><span class="stat-val">{label(extra.intelligence)}</span></div>
    )}
    {creature.habitat_climate && (
      <div class="stat"><span class="stat-label">Climate</span><span class="stat-val">{label(creature.habitat_climate)}</span></div>
    )}
    {creature.behaviour_threat && (
      <div class="stat"><span class="stat-label">Danger</span><span class="stat-val">{label(creature.behaviour_threat)}</span></div>
    )}
    {extra.friendliness && (
      <div class="stat"><span class="stat-label">Friendliness</span><span class="stat-val">{label(extra.friendliness)}</span></div>
    )}
    {extra.activity_time && (
      <div class="stat"><span class="stat-label">Active</span><span class="stat-val">{label(extra.activity_time)}</span></div>
    )}
    {creature.kind_diet && (
      <div class="stat"><span class="stat-label">Diet</span><span class="stat-val">{label(creature.kind_diet)}</span></div>
    )}
    {creature.kind_solitary !== null && (
      <div class="stat"><span class="stat-label">Social</span><span class="stat-val">{extra.social_structure ? label(extra.social_structure) : (creature.kind_solitary ? 'Alone' : 'Groups')}</span></div>
    )}
  </div>

  {creature.kind_movement && creature.kind_movement.length > 0 && (
    <div class="tags-row">
      <span class="tags-label">Movement</span>
      {creature.kind_movement.map(m => <span class="tag">{m}</span>)}
    </div>
  )}

  {creature.habitat_biome && creature.habitat_biome.length > 0 && (
    <div class="tags-row">
      <span class="tags-label">Habitat</span>
      {creature.habitat_biome.map(h => <span class="tag">{h}</span>)}
    </div>
  )}

  {creature.food_notes && (
    <section class="detail-section">
      <h2>Food</h2>
      <p>{creature.food_notes}</p>
    </section>
  )}

  {creature.special_ability && (
    <section class="detail-section">
      <h2>Special powers</h2>
      <p>{creature.special_ability}</p>
    </section>
  )}

  {extra.sounds && (
    <section class="detail-section">
      <h2>Sounds</h2>
      <p>{extra.sounds}</p>
    </section>
  )}

  {extra.weaknesses && (
    <section class="detail-section">
      <h2>Weaknesses</h2>
      <p>{extra.weaknesses}</p>
    </section>
  )}

  {creature.lore_description && (
    <section class="detail-section story">
      <h2>Story</h2>
      <p class="story-text">{creature.lore_description}</p>
    </section>
  )}
</Base>

<style>
  .back-link {
    display: inline-block;
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .creature-header {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    margin-bottom: 2rem;
  }

  .creature-image {
    width: 220px;
    height: 220px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .creature-title h1 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .maker { color: var(--accent-hi); font-size: 1rem; margin: 0; }
  .age { color: var(--text-dim); font-size: 0.85rem; margin: 0.25rem 0 0; }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .stat {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.65rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-val {
    font-size: 0.9rem;
    color: var(--text);
    font-weight: 600;
  }

  .tags-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .tags-label {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-right: 0.25rem;
    min-width: 70px;
  }

  .tag {
    background: var(--surface-hi);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-dim);
    font-size: 0.8rem;
    padding: 0.2rem 0.5rem;
  }

  .detail-section {
    margin-top: 1.75rem;
  }

  .detail-section h2 {
    font-size: 1.1rem;
    color: var(--accent-hi);
    margin-bottom: 0.5rem;
  }

  .detail-section p {
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .story-text {
    white-space: pre-line;
    color: var(--text) !important;
    font-size: 1rem !important;
    line-height: 1.75 !important;
  }

  @media (max-width: 540px) {
    .creature-header { flex-direction: column; gap: 1rem; }
    .creature-image { width: 100%; height: auto; aspect-ratio: 1; }
  }
</style>
