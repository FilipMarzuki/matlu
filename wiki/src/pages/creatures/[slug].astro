---
/**
 * Creature detail page — FIL-433 (Creatures A3), FIL-333 (status ribbon + tracker).
 *
 * One page per approved creature slug. `getStaticPaths` fetches all approved
 * rows and all status history at build time; unapproved / missing slugs are
 * simply not generated (404).
 *
 * FIL-333 adds:
 *   - Status ribbon: full-width banner showing kid-friendly pipeline state.
 *   - Timeline: chronological list of state transitions from creature_status_history.
 *   - Tracker sidebar: link to the GitHub tracking issue if one was created.
 */
import Base from '../../layouts/Base.astro';
import {
  fetchApprovedCreatures,
  fetchAllCreatureHistory,
  imageUrl,
  getStatusDisplay,
} from '../../lib/supabase-creatures';
import type { Creature, CreatureStatusEntry } from '../../lib/supabase-creatures';

export async function getStaticPaths() {
  // Batch both queries in parallel to avoid sequential round-trips at build time.
  const [creatures, allHistory] = await Promise.all([
    fetchApprovedCreatures(),
    fetchAllCreatureHistory(),
  ]);
  return creatures.map(c => ({
    params: { slug: c.slug },
    props: {
      creature: c,
      history: allHistory[c.id] ?? [],
    },
  }));
}

interface Props {
  creature: Creature;
  history: CreatureStatusEntry[];
}
const { creature: c, history } = Astro.props;

const supabaseUrl = import.meta.env.VITE_SUPABASE_URL ?? '';
const img = imageUrl(supabaseUrl, c.art_path);

// Helper: render a labelled field only when value is present
function val(v: string | null | undefined): string {
  return v?.trim() ?? '';
}
function arr(v: string[] | null | undefined): string[] {
  return (v ?? []).filter(Boolean);
}

const sizeLabels: Record<string, string> = {
  tiny: 'Tiny (fits in your hand)', small: 'Small (like a cat or dog)',
  medium: 'Medium (like a person)', large: 'Large (like a horse or bear)',
  huge: 'Huge (bigger than a house)',
};
const dietLabels: Record<string, string> = {
  herbivore: 'Herbivore (plants only)', carnivore: 'Carnivore (meat only)',
  omnivore: 'Omnivore (plants and meat)', insectivore: 'Insectivore (insects)',
  other: 'Other / Unknown',
};
const threatLabels: Record<string, string> = {
  friendly: 'Friendly', shy: 'Shy', neutral: 'Neutral',
  territorial: 'Territorial', aggressive: 'Aggressive',
};
const climateLabels: Record<string, string> = {
  tropical: 'Tropical', temperate: 'Temperate', arid: 'Arid / Desert',
  cold: 'Cold / Polar', any: 'Adapts to any climate',
};

const movements = arr(c.kind_movement).map(m => m.charAt(0).toUpperCase() + m.slice(1));
const biomes = arr(c.habitat_biome).map(b => b.charAt(0).toUpperCase() + b.slice(1));

// Status display helpers
const status = getStatusDisplay(c.status);

// Show rejection note if set (already public — shown on the submission form after rejection)
const rejectionNote = c.status === 'rejected' && val(c.moderation_note)
  ? c.moderation_note
  : null;

// Format a timestamp as "Apr 20, 2026" for the timeline
function fmtDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
  });
}

const trackerUrl = c.tracker_issue_number !== null
  ? `https://github.com/FilipMarzuki/matlu/issues/${c.tracker_issue_number}`
  : null;
---

<Base
  title={c.creature_name}
  description={c.lore_description ? c.lore_description.slice(0, 160) : `A creature from the Matlu multiworld.`}
>
  <div class="breadcrumb">
    <a href="/creatures">&larr; All creatures</a>
  </div>

  <!-- Status ribbon (FIL-333 C1) -->
  <div class={`status-ribbon status-${c.status}`}>
    <span class="status-icon" aria-hidden="true">{status.icon}</span>
    <div class="status-body">
      <div class="status-label">{status.label}</div>
      <div class="status-copy">
        {status.copy}
        {rejectionNote && <span class="rejection-note"> {rejectionNote}</span>}
      </div>
      {status.eta && <div class="status-eta">{status.eta}</div>}
    </div>
  </div>

  <!-- Timeline (FIL-333 C1) — shown only when there are recorded transitions -->
  {history.length > 0 && (
    <ol class="status-timeline" aria-label="Creature journey">
      {history.map((entry, i) => {
        const d = getStatusDisplay(entry.to_status);
        const isCurrent = i === history.length - 1;
        return (
          <li class={`timeline-entry${isCurrent ? ' current' : ''}`}>
            <span class="tl-dot" aria-hidden="true"></span>
            <span class="tl-date">{fmtDate(entry.changed_at)}</span>
            <span class="tl-label">{isCurrent ? '(current) ' : ''}{d.label}</span>
          </li>
        );
      })}
    </ol>
  )}

  <article class="creature">

    <header class="creature-header">
      <div class="creature-title">
        <h1>{c.creature_name}</h1>
        {c.world_name && <p class="world-tag">{c.world_name}</p>}
        {c.creator_name && (
          <p class="creator">Created by <strong>{c.art_credit ?? c.creator_name}</strong></p>
        )}
      </div>

      <!-- Tracker sidebar (FIL-333 C2) — only shown when a GitHub tracker exists -->
      {trackerUrl && (
        <aside class="tracker-sidebar">
          <div class="tracker-title">Follow this creature's progress</div>
          <p class="tracker-desc">
            This creature has a tracker on GitHub where every update is posted.
          </p>
          <a
            href={trackerUrl}
            class="tracker-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open tracker on GitHub &rarr;
          </a>
          <p class="tracker-hint">Bookmark or subscribe to get notified when it moves forward.</p>
        </aside>
      )}
    </header>

    <!-- Art -->
    {img && (
      <div class="art-wrap">
        <img src={img} alt={`Drawing of ${c.creature_name}`} class="art" />
        {c.art_credit && c.art_credit !== c.creator_name && (
          <p class="art-credit">Art by {c.art_credit}</p>
        )}
      </div>
    )}

    <!-- What kind -->
    {(val(c.kind_size) || movements.length || c.kind_solitary !== null) && (
      <section class="detail-section">
        <h2>What kind of creature</h2>
        <dl>
          {val(c.kind_size) && (
            <>
              <dt>Size</dt>
              <dd>{sizeLabels[c.kind_size!] ?? c.kind_size}</dd>
            </>
          )}
          {movements.length > 0 && (
            <>
              <dt>Movement</dt>
              <dd>{movements.join(', ')}</dd>
            </>
          )}
          {c.kind_solitary !== null && (
            <>
              <dt>Social</dt>
              <dd>{c.kind_solitary ? 'Lives alone' : 'Lives in groups'}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Habitat -->
    {(biomes.length || val(c.habitat_climate) || val(c.habitat_notes)) && (
      <section class="detail-section">
        <h2>Where it lives</h2>
        <dl>
          {biomes.length > 0 && (
            <>
              <dt>Biome</dt>
              <dd>{biomes.join(', ')}</dd>
            </>
          )}
          {val(c.habitat_climate) && (
            <>
              <dt>Climate</dt>
              <dd>{climateLabels[c.habitat_climate!] ?? c.habitat_climate}</dd>
            </>
          )}
          {val(c.habitat_notes) && (
            <>
              <dt>Notes</dt>
              <dd>{c.habitat_notes}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Behaviour -->
    {(val(c.behaviour_threat) || val(c.behaviour_notes)) && (
      <section class="detail-section">
        <h2>Behaviour</h2>
        <dl>
          {val(c.behaviour_threat) && (
            <>
              <dt>Danger level</dt>
              <dd>{threatLabels[c.behaviour_threat!] ?? c.behaviour_threat}</dd>
            </>
          )}
          {val(c.behaviour_notes) && (
            <>
              <dt>Notes</dt>
              <dd>{c.behaviour_notes}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Food -->
    {(val(c.kind_diet) || val(c.food_notes)) && (
      <section class="detail-section">
        <h2>Food</h2>
        <dl>
          {val(c.kind_diet) && (
            <>
              <dt>Diet</dt>
              <dd>{dietLabels[c.kind_diet!] ?? c.kind_diet}</dd>
            </>
          )}
          {val(c.food_notes) && (
            <>
              <dt>Notes</dt>
              <dd>{c.food_notes}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Special -->
    {val(c.special_ability) && (
      <section class="detail-section">
        <h2>Special ability</h2>
        <p class="prose">{c.special_ability}</p>
      </section>
    )}

    <!-- Story -->
    {val(c.lore_description) && (
      <section class="detail-section">
        <h2>Story</h2>
        <p class="prose">{c.lore_description}</p>
        {val(c.lore_origin) && (
          <>
            <h3>Origin</h3>
            <p class="prose">{c.lore_origin}</p>
          </>
        )}
      </section>
    )}

  </article>

  <div class="back-link">
    <a href="/creatures">&larr; Back to all creatures</a>
  </div>
</Base>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--text-dim); }
  .breadcrumb a:hover { color: var(--accent-hi); }

  /* ── Status ribbon ────────────────────────────────────────────────── */
  .status-ribbon {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
  }
  /* Tint border by status group */
  .status-ribbon.status-in-game   { border-color: rgba(14,138,22,0.5);   background: rgba(14,138,22,0.08); }
  .status-ribbon.status-spriting  { border-color: rgba(217,63,11,0.4);   background: rgba(217,63,11,0.07); }
  .status-ribbon.status-rejected  { border-color: rgba(182,2,5,0.4);     background: rgba(182,2,5,0.07);   }
  .status-ribbon.status-approved  { border-color: rgba(45,164,78,0.4);   background: rgba(45,164,78,0.07); }

  .status-icon { font-size: 1.6rem; line-height: 1; flex-shrink: 0; margin-top: 0.1rem; }

  .status-body { display: flex; flex-direction: column; gap: 0.2rem; }
  .status-label {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--text);
  }
  .status-copy { font-size: 0.9rem; color: var(--text-dim); }
  .rejection-note { font-style: italic; }
  .status-eta  { font-size: 0.8rem; color: var(--text-dim); margin-top: 0.1rem; }

  /* ── Timeline ─────────────────────────────────────────────────────── */
  .status-timeline {
    list-style: none;
    padding: 0.75rem 1.25rem;
    margin-bottom: 1.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .timeline-entry {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.45rem 0;
    font-size: 0.88rem;
    color: var(--text-dim);
    position: relative;
  }
  /* Connecting line between dots */
  .timeline-entry:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 5px;
    top: calc(50% + 6px);
    width: 2px;
    height: calc(100% - 2px);
    background: var(--border);
  }
  .tl-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .timeline-entry.current .tl-dot { background: var(--accent-hi); }
  .timeline-entry.current { color: var(--text); }
  .tl-date {
    min-width: 100px;
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
  }
  .tl-label { color: inherit; }

  /* ── Header ───────────────────────────────────────────────────────── */
  .creature-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .creature-title h1 {
    font-size: 2.2rem;
    color: var(--accent-hi);
    margin: 0 0 0.3rem 0;
  }
  .world-tag {
    display: inline-block;
    font-family: var(--mono, monospace);
    font-size: 0.78rem;
    color: var(--green, #4ade80);
    border: 1px solid rgba(74,222,128,0.3);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.4rem;
  }
  .creator { font-size: 0.88rem; color: var(--text-dim); margin: 0; }
  .creator strong { color: var(--text); }

  /* ── Tracker sidebar ──────────────────────────────────────────────── */
  .tracker-sidebar {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.2rem;
    max-width: 260px;
    flex-shrink: 0;
  }
  .tracker-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--text);
    margin-bottom: 0.4rem;
  }
  .tracker-desc {
    font-size: 0.83rem;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }
  .tracker-link {
    display: block;
    background: var(--accent);
    color: #fff;
    text-align: center;
    padding: 0.5rem 0.85rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 0.6rem;
  }
  .tracker-link:hover { background: var(--accent-hi); color: #fff; text-decoration: none; }
  .tracker-hint {
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.45;
    margin: 0;
  }

  /* ── Art ──────────────────────────────────────────────────────────── */
  .art-wrap {
    margin-bottom: 2rem;
    max-width: 560px;
  }
  .art {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--border);
    display: block;
  }
  .art-credit { font-size: 0.8rem; color: var(--text-dim); margin: 0.4rem 0 0; }

  /* ── Detail sections ──────────────────────────────────────────────── */
  .detail-section {
    margin-bottom: 1.75rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }
  .detail-section:last-of-type { border-bottom: none; }

  .detail-section h2 {
    font-size: 1.05rem;
    color: var(--accent-hi);
    font-family: 'Syne', sans-serif;
    margin: 0 0 0.85rem 0;
  }
  .detail-section h3 {
    font-size: 0.95rem;
    color: var(--text);
    margin: 1.1rem 0 0.5rem;
  }

  dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.4rem 1.25rem;
    font-size: 0.9rem;
  }
  dt { color: var(--text-dim); font-weight: 500; white-space: nowrap; padding-top: 0.05em; }
  dd { color: var(--text); margin: 0; line-height: 1.5; }

  .prose {
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.7;
    max-width: 640px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ── Back link ────────────────────────────────────────────────────── */
  .back-link { margin-top: 2.5rem; font-size: 0.88rem; }
  .back-link a { color: var(--text-dim); }
  .back-link a:hover { color: var(--accent-hi); }

  @media (max-width: 520px) {
    dl { grid-template-columns: 1fr; }
    dt { font-size: 0.78rem; color: var(--text-dim); margin-bottom: -0.2rem; }
    .tracker-sidebar { max-width: 100%; }
    .tl-date { min-width: 80px; font-size: 0.8rem; }
  }
</style>
