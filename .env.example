# Supabase — Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
#
# Copy to `.env` or `.env.local` (Vite loads both; `.env.local` overrides).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Prefer the default publishable key (matches Supabase dashboard naming)
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key_here
# Optional fallback: legacy anon JWT if you do not set publishable
# VITE_SUPABASE_ANON_KEY=eyJ...

# Linear — https://linear.app/settings/api (Personal API keys)
# Never use VITE_ here: this must not be bundled into the Phaser client.
# Use in Node scripts, CI, or a backend / Edge function only.
LINEAR_API_KEY=lin_api_your_key_here

# Better Stack — https://betterstack.com → Logs → your source → "Source token"
# VITE_BETTERSTACK_DSN=your_source_token_here

# Better Stack SQL Query API (for CI/automation, not bundled to the client)
# Create credentials in Better Stack → Integrations → Connect.
BETTERSTACK_SQL_USER=your_connect_username
BETTERSTACK_SQL_PASSWORD=your_connect_password
# Optional override if your Connect hostname differs by region.
# BETTERSTACK_SQL_ENDPOINT=https://eu-fsn-3-connect.betterstackdata.com
