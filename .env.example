# Supabase — Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
#
# Copy to `.env` or `.env.local` (Vite loads both; `.env.local` overrides).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Prefer the default publishable key (matches Supabase dashboard naming)
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key_here
# Optional fallback: legacy anon JWT if you do not set publishable
# VITE_SUPABASE_ANON_KEY=eyJ...
