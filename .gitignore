node_modules
dist

# Local env (never commit secrets)
.env
.env.local
.env.*.local

# Claude Code symlink tree from `npx skills add` (canonical files: .agents/skills)
.claude/

# Uncompressed audio — commit OGG/MP3 only; WAVs are too large for git
*.wav
# Shapeforms preview pack — 130 MB of WAVs + promo materials, not game-ready assets
public/assets/audio/Shapeforms Audio Free Sound Effects/
# Duplicate download of Kenney Impact Sounds (macOS/Windows appends " (1)" on re-download)
public/assets/audio/kenney_impact-sounds (1)/

# Cursor IDE config
.cursor/

# Playwright test output
test-results/

# Generated screenshots (run `npm run screenshot` to regenerate)
/screenshots/

# Raw frames downloaded from PixelLab — assembled into spritesheets, not committed
public/assets/sprites/_raw/

# PixelLab job tracking — local state, regenerate by re-running generation
src/ai/asset-lock.json

# Arena bot session logs (generated by npm run arena-bot)
logs/arena-bot/

# Playwright ad-hoc screenshots saved to tests/ (not source assets)
tests/*.png
tests/*.jpg
tests/*.bak

# One-off patch scripts
gs_patch.py

# Concept art exports / HTML clippings (not game assets)
public/assets/Concept Art/

# Token usage log (local dev only)
token-log.json

# Astro generated files
dev/.astro/
wiki/.astro/settings.json

# Build-time issue cache written by github-issues.ts
wiki/.cache/
dev/.cache/

# Vercel deployment artifacts
wiki/.vercel/

# IDE workspace settings
.vscode/

# Macro-world generated outputs (large files, re-generated on demand)
macro-world/earth-reference/
