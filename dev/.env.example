# Supabase — reuse the same vars already set in Vercel for the main game
# Get from: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Notion — used for lore sync, blog drafts (server-side only)
NOTION_API_KEY=secret_...

# GitHub read token — fine-grained PAT, issues:read on FilipMarzuki/matlu.
# Used by github-issues.ts at build time to fetch the issue list.
# Set in Vercel project env vars (Settings → Environment Variables → GITHUB_TOKEN).
GITHUB_TOKEN=github_pat_...

# Cross-site link — Matlu Codex wiki
PUBLIC_WIKI_URL=https://matlu-codex.vercel.app
