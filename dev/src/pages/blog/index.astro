---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Filter drafts and sort newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Base title="Blog">
  <h1>Blog</h1>
  <p class="subtitle">Field notes on building Core Warden with AI agents — what works, what breaks, what's surprising.</p>

  {posts.length === 0 ? (
    <p class="empty">No posts yet.</p>
  ) : (
    <ul class="post-list">
      {posts.map(post => (
        <li class="post-card">
          <a href={`/blog/${post.id}/`} class="post-title">{post.data.title}</a>
          <div class="post-meta">
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            {post.data.tags.length > 0 && (
              <span class="tags">
                {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
              </span>
            )}
          </div>
          <p class="post-summary">{post.data.summary}</p>
        </li>
      ))}
    </ul>
  )}
</Base>

<style>
  h1 { margin-bottom: 0.4rem; }

  .subtitle {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 1.1rem 1.25rem;
    background: var(--surface);
  }

  .post-title {
    display: block;
    font-family: var(--mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent-hi);
    margin-bottom: 0.35rem;
  }
  .post-title:hover { text-decoration: underline; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  time {
    font-size: 0.8rem;
    color: var(--text-dim);
    font-family: var(--mono);
  }

  .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  .tag {
    font-size: 0.75rem;
    color: var(--text-dim);
    background: var(--surface-hi);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
    font-family: var(--mono);
  }

  .post-summary {
    font-size: 0.88rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.55;
  }

  .empty {
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 0.9rem;
  }
</style>
