---
import Base from '../layouts/Base.astro';
import { agents, promptUrl } from '../data/agents';

// ── Optional: fetch last week's nightly-agent outcomes from Supabase ─────────
// Reads from stats_weekly (populated by collect-stats.js each Sunday).
// Gracefully skipped if env vars are unset or the query fails.

interface WeeklyStats {
  week_of: string;
  agent_issues_processed: number | null;
  agent_outcome_success: number | null;
  agent_outcome_partial: number | null;
  agent_outcome_failed: number | null;
  agent_outcome_wrong_interp: number | null;
  agent_success_rate_pct: number | null;
  agent_failure_rate_pct: number | null;
}

let lastWeek: WeeklyStats | null = null;

const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY ?? import.meta.env.SUPABASE_ANON_KEY;

if (supabaseUrl && supabaseKey) {
  try {
    const res = await fetch(
      `${supabaseUrl}/rest/v1/stats_weekly?select=week_of,agent_issues_processed,agent_outcome_success,agent_outcome_partial,agent_outcome_failed,agent_outcome_wrong_interp,agent_success_rate_pct,agent_failure_rate_pct&order=week_of.desc&limit=1`,
      {
        headers: {
          apikey: supabaseKey,
          Authorization: `Bearer ${supabaseKey}`,
        },
      }
    );
    if (res.ok) {
      const rows: WeeklyStats[] = await res.json();
      if (rows.length > 0) lastWeek = rows[0];
    }
  } catch {
    // Silently skip — page renders fine without it
  }
}

function fmt(n: number | null | undefined): string {
  return n != null ? String(n) : '—';
}

function fmtPct(n: number | null | undefined): string {
  return n != null ? `${n.toFixed(1)}%` : '—';
}

function scheduleClass(cron: string | null): string {
  if (!cron) return 'schedule-event';
  // daily = 5 fields, last is '*' (any day of week)
  const parts = cron.split(' ');
  if (parts[4] === '*') return 'schedule-daily';
  return 'schedule-weekly';
}
---

<Base title="Agents">
  <h1>Agents</h1>
  <p class="subtitle">All scheduled agents in the Matlu automation stack — what each does, when it runs, and how it's performing.</p>

  {lastWeek ? (
    <div class="stats-bar">
      <span class="stats-label">Last week ({lastWeek.week_of})</span>
      <span class="stat"><span class="stat-val">{fmt(lastWeek.agent_issues_processed)}</span> issues</span>
      <span class="stat success"><span class="stat-val">{fmt(lastWeek.agent_outcome_success)}</span> success</span>
      <span class="stat partial"><span class="stat-val">{fmt(lastWeek.agent_outcome_partial)}</span> partial</span>
      <span class="stat failed"><span class="stat-val">{fmt(lastWeek.agent_outcome_failed)}</span> failed</span>
      <span class="stat rate">
        <span class="stat-val">{fmtPct(lastWeek.agent_success_rate_pct)}</span> success rate
      </span>
    </div>
  ) : (
    <div class="no-data">
      Outcome data not available — run <code>collect-stats.js</code> or set <code>SUPABASE_URL</code> + <code>SUPABASE_SERVICE_ROLE_KEY</code>.
    </div>
  )}

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Agent</th>
          <th>Schedule</th>
          <th>Description</th>
          <th>Last week</th>
          <th>Prompt</th>
        </tr>
      </thead>
      <tbody>
        {agents.map(agent => (
          <tr>
            <td class="name">{agent.name}</td>
            <td>
              <span class={`badge ${scheduleClass(agent.cron)}`}>
                {agent.schedule}
              </span>
            </td>
            <td class="desc">{agent.description}</td>
            <td class="outcomes">
              {/* Nightly Dev Agent is the only one with per-run outcome tracking via Linear labels */}
              {agent.name === 'Nightly Dev Agent' && lastWeek ? (
                <span class="outcome-row">
                  <span class="pill success">{fmt(lastWeek.agent_outcome_success)} ✓</span>
                  <span class="pill partial">{fmt(lastWeek.agent_outcome_partial)} ~</span>
                  <span class="pill failed">{fmt(lastWeek.agent_outcome_failed)} ✗</span>
                </span>
              ) : (
                <span class="dim">—</span>
              )}
            </td>
            <td>
              {agent.promptFile ? (
                <a href={promptUrl(agent.promptFile)} target="_blank" rel="noopener" class="prompt-link">
                  {agent.promptFile.split('/').pop()}
                </a>
              ) : (
                <span class="dim">script</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Base>

<style>
  h1 { margin-bottom: 0.5rem; }

  .subtitle {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  /* ── Stats bar ─────────────────────────────────────────────────────────── */
  .stats-bar {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
  }

  .stats-label {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .stat {
    display: flex;
    gap: 0.3rem;
    align-items: baseline;
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  .stat-val {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--text);
  }

  .stat.success .stat-val { color: var(--green); }
  .stat.partial  .stat-val { color: var(--amber); }
  .stat.failed   .stat-val { color: var(--red); }
  .stat.rate     .stat-val { color: var(--accent-hi); }

  .no-data {
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    padding: 0.6rem 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  }

  /* ── Table ─────────────────────────────────────────────────────────────── */
  .table-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  th {
    text-align: left;
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  td {
    padding: 0.65rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--surface); }

  .name {
    font-family: var(--mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
  }

  .desc {
    color: var(--text-dim);
    font-size: 0.85rem;
    max-width: 340px;
  }

  .dim { color: var(--text-dim); }

  /* ── Schedule badges ───────────────────────────────────────────────────── */
  .badge {
    font-family: var(--mono);
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    border: 1px solid;
  }

  .schedule-daily  { color: var(--accent-hi); border-color: var(--accent); background: rgba(124, 111, 247, 0.08); }
  .schedule-weekly { color: var(--amber);     border-color: rgba(251, 191, 36, 0.4); background: rgba(251, 191, 36, 0.06); }
  .schedule-event  { color: var(--text-dim);  border-color: var(--border); background: var(--surface-hi); }

  /* ── Outcome pills ─────────────────────────────────────────────────────── */
  .outcome-row {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .pill {
    font-family: var(--mono);
    font-size: 0.75rem;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .pill.success { background: rgba(74, 222, 128, 0.12); color: var(--green); }
  .pill.partial { background: rgba(251, 191, 36, 0.12); color: var(--amber); }
  .pill.failed  { background: rgba(248, 113, 113, 0.12); color: var(--red); }

  /* ── Prompt link ───────────────────────────────────────────────────────── */
  .prompt-link {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent-hi);
  }

  .prompt-link:hover { text-decoration: underline; }

  /* ── Mobile: card list ─────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    table, thead, tbody, th, td, tr { display: block; }

    thead { display: none; }

    tr {
      border: 1px solid var(--border);
      border-radius: 6px;
      margin-bottom: 0.75rem;
      padding: 0.75rem;
    }

    tr:hover td { background: transparent; }

    td {
      border: none;
      padding: 0.2rem 0;
      display: flex;
      gap: 0.5rem;
      align-items: flex-start;
    }

    td::before {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--text-dim);
      min-width: 80px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    td.name::before  { content: 'Agent'; }
    td:nth-child(2)::before { content: 'Schedule'; }
    td.desc::before  { content: 'About'; }
    td.outcomes::before { content: 'Last week'; }
    td:nth-child(5)::before { content: 'Prompt'; }
  }
</style>
