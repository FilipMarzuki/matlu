---
const navItems = [
  { href: '/',              label: 'Home'         },
  { href: '/metrics',       label: 'Metrics'      },
  { href: '/blog',          label: 'Blog'         },
  { href: '/architecture',  label: 'Architecture' },
  { href: '/agents',        label: 'Agents'       },
];

const pathname = Astro.url.pathname;
---

<nav>
  <a href="/" class="site-title">Agentic Experiments</a>
  <ul>
    {navItems.map(item => (
      <li>
        <a
          href={item.href}
          class={
            item.href !== '/' && pathname.startsWith(item.href)
              ? 'active'
              : pathname === item.href
              ? 'active'
              : ''
          }
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <!-- Cross-link to the game -->
  <a href={`${import.meta.env.PUBLIC_WIKI_URL ?? 'https://matlu-codex.vercel.app'}/playtest`} class="play-cta" target="_blank" rel="noopener">
    Play Core Warden →
  </a>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .site-title {
    color: var(--accent-hi);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
  ul {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    flex: 1;
  }
  a { color: var(--text-dim); font-size: 0.88rem; font-family: 'Inter', sans-serif; }
  a:hover, a.active { color: var(--text); text-decoration: none; }
  a.active { color: var(--accent-hi); }
  .play-cta {
    margin-left: auto;
    color: var(--accent-hi);
    font-size: 0.85rem;
    white-space: nowrap;
    border: 1px solid var(--border);
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    transition: border-color 0.15s, color 0.15s;
  }
  .play-cta:hover {
    border-color: var(--accent);
    color: var(--text);
    text-decoration: none;
  }
</style>
